def run_rf_inference(files: dict) -> Tuple[pd.DataFrame, pd.DataFrame, float]:
    """
    Load RF model, engineer features, and return per-scenario predictions.

    Returns
    -------
    macro_df   : engineered DataFrame (all rows from the H5 file)
    scen_df    : scenario-level summary  (scenario_id, has_incident, max_prob,
                 detected, ttd_seconds)
    threshold  : loaded decision threshold
    """
    print("\n" + "="*60)
    print("  RF MODEL INFERENCE")
    print("="*60)

    # Load model artifacts
    model      = joblib.load(files["rf_model"])
    with open(files["features"])   as f: feature_cols = json.load(f)
    with open(files["rf_threshold"]) as f: threshold = json.load(f)["threshold"]
    print(f"  threshold={threshold:.4f}   features={len(feature_cols)}")

    # Load macro data
    print(f"\n  Loading {files['macro_h5'].name} ...")
    raw_df = pd.read_hdf(files["macro_h5"], key="data")
    print(f"  {len(raw_df):,} rows  |  {raw_df['scenario_id'].nunique()} scenarios")

    has_incidents = "incident_active" in raw_df.columns and raw_df["incident_active"].sum() > 0
    if not has_incidents:
        print("  ℹ️  No incident rows detected — FAR-only evaluation.")

    # Feature engineering (per-scenario to avoid cross-contamination)
    print("  Engineering features ...")
    fe  = FeatureEngineer()
    eng = fe.engineer_features(raw_df)
    # Keep only columns the model was trained on
    missing_feat = [c for c in feature_cols if c not in eng.columns]
    if missing_feat:
        print(f"  ⚠️  {len(missing_feat)} feature(s) not found; filling with 0: {missing_feat[:5]}...")
        for c in missing_feat:
            eng[c] = 0.0

    X = eng[feature_cols].to_numpy(dtype=np.float32)
    y = eng["incident_active"].to_numpy() if "incident_active" in eng.columns else np.zeros(len(eng))

    # Predict
    proba = model.predict_proba(X)[:, 1]
    eng["rf_prob"]  = proba
    eng["rf_pred"]  = (proba >= threshold).astype(int)
    eng["y_true"]   = y

    # ── Scenario-level aggregation ──────────────────────────────────────────
    scen_rows = []
    for scen_id, grp in eng.groupby("scenario_id"):
        grp      = grp.sort_values("sim_time")
        has_inc  = int(grp["y_true"].max())
        probs    = grp["rf_prob"].values
        preds    = grp["rf_pred"].values
        max_prob = float(probs.max())
        detected = _check_persistent(preds, MIN_CONFIRMED)
        ttd      = _compute_ttd(grp, preds, has_inc, "sim_time") if has_inc else None
        scen_rows.append({
            "scenario_id": scen_id,
            "has_incident": has_inc,
            "rf_max_prob": max_prob,
            "rf_detected": int(detected),
            "rf_ttd": ttd,
        })

    scen_df = pd.DataFrame(scen_rows)
    print(f"  Scenarios: {len(scen_df)}  "
          f"(incident={scen_df['has_incident'].sum()}  "
          f"NI={( scen_df['has_incident']==0).sum()})")
    return eng, scen_df, threshold


