def plot_comparison_bar(
    rf_m: dict, cnn_m: Optional[dict], fusion_results: List[dict],
    has_incidents: bool,
) -> None:
    """Grouped bar chart comparing DR, FAR, F1 across all models."""
    all_models = [rf_m]
    if cnn_m:
        all_models.append(cnn_m)
    all_models.extend(fusion_results)

    names = [m["model"] for m in all_models]
    dr_vals  = [m.get("dr",  0) * 100 for m in all_models]
    far_vals = [m.get("far", 0) * 100 for m in all_models]
    f1_vals  = [m.get("f1",  0) * 100 for m in all_models]

    x = np.arange(len(names))
    w = 0.25
    fig, ax = plt.subplots(figsize=(max(10, len(names)*1.5), 6))
    if has_incidents:
        ax.bar(x - w, dr_vals,  w, label="Detection Rate (%)", color="steelblue")
    ax.bar(x,     far_vals, w, label="False Alarm Rate (%)", color="tomato")
    if has_incidents:
        ax.bar(x + w, f1_vals,  w, label="F1-score (%)",         color="seagreen")
    ax.set_xticks(x)
    ax.set_xticklabels(names, rotation=20, ha="right")
    ax.set_ylabel("Percentage (%)")
    ax.set_title("Model Comparison: RF vs CNN vs Fusion Strategies")
    ax.legend()
    ax.grid(axis="y", alpha=0.3)
    ax.set_ylim(0, 110)
    plt.tight_layout()
    path = OUTPUT_DIR / "comparison_bar.png"
    plt.savefig(path, dpi=150)
    plt.close()
    print(f"  💾 Comparison bar chart → {path.name}")


