def run_cnn_inference(files: dict, scen_ids: set) -> Optional[pd.DataFrame]:
    """
    Load CNN model and run inference on the image windows for the given scenarios.

    Uses AIDWindowDataset from cnn_model.py — masking (TriangleMask) is applied
    automatically as part of the transform pipeline, exactly as during training.

    Returns a scenario-level DataFrame or None if CNN model files are missing.
    """
    if not CNN_AVAILABLE or files["cnn_model"] is None:
        return None

    print("\n" + "="*60)
    print("  CNN MODEL INFERENCE")
    print("="*60)

    # ── Load meta ──────────────────────────────────────────────────────────
    with open(files["cnn_meta"]) as f:
        meta = json.load(f)
    n_frames  = meta["n_frames"]
    dropout   = meta["dropout"]
    threshold = meta["decision_threshold"]
    print(f"  threshold={threshold:.4f}   n_frames={n_frames}   "
          f"window={meta.get('window_size', WINDOW_SIZE)}  "
          f"stride={meta.get('window_stride', WINDOW_STRIDE)}")

    # ── Device ────────────────────────────────────────────────────────────
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    if torch.cuda.is_available():
        name = torch.cuda.get_device_name(0)
        mem  = torch.cuda.get_device_properties(0).total_memory / 1e9
        print(f"  [DEVICE] {name}  ({mem:.1f} GB)")
    else:
        print("  [DEVICE] CPU")

    # ── Load CNN ──────────────────────────────────────────────────────────
    cnn = TemporalEfficientNet(dropout=dropout, n_frames=n_frames)
    cnn.load_state_dict(
        torch.load(files["cnn_model"], map_location=device, weights_only=True)
    )
    cnn.to(device)
    cnn.eval()
    cnn._finetune_mode = False
    print(f"  Model loaded from {files['cnn_model'].name}")

    # ── Build dataset using the scenario IDs from the H5 file ─────────────
    # AIDWindowDataset reads master_metadata.csv from the standard dataset/
    # folder (DATASET_DIR from cnn_model.py) and filters to scen_ids.
    # TriangleMask is the first step in its transform pipeline.
    print(f"  Building image windows for {len(scen_ids)} scenarios ...")
    try:
        ds = AIDWindowDataset(
            scenario_ids = scen_ids,
            split_name   = "inference",
            n_frames     = n_frames,
            window_size  = meta.get("window_size", WINDOW_SIZE),
            stride       = meta.get("window_stride", WINDOW_STRIDE),
            augment      = False,
        )
    except (FileNotFoundError, ValueError) as e:
        print(f"  ⚠️  Cannot build CNN dataset: {e}")
        print("  CNN evaluation skipped.")
        return None

    if len(ds) == 0:
        print("  ⚠️  No windows found for the given scenario IDs.")
        return None

    loader = DataLoader(
        ds, batch_size=8, shuffle=False,
        num_workers=min(4, 4), pin_memory=True,
    )

    # ── Run inference ─────────────────────────────────────────────────────
    all_probs, all_labels = [], []
    with torch.no_grad():
        for frames, labels in tqdm(loader, desc="  CNN inference", leave=False):
            frames = frames.to(device, non_blocking=True)
            logits = cnn(frames)
            probs  = torch.sigmoid(logits).cpu().numpy()
            all_probs.extend(probs.tolist())
            all_labels.extend(labels.numpy().astype(int).tolist())

    all_probs  = np.array(all_probs)
    all_labels = np.array(all_labels)

    # ── Scenario-level aggregation ────────────────────────────────────────
    # Map window index → scenario_id using dataset.windows
    scen_probs: dict = defaultdict(list)
    scen_labels: dict = defaultdict(list)
    for i, (paths, label) in enumerate(ds.windows):
        # paths[0] is like: .../dataset/sXXXXX/images/frame_000000.png
        scen_id = Path(paths[0]).parts[-3]
        scen_probs[scen_id].append(all_probs[i])
        scen_labels[scen_id].append(label)

    cnn_rows = []
    for scen_id in scen_probs:
        probs    = np.array(scen_probs[scen_id])
        labels   = scen_labels[scen_id]
        has_inc  = int(max(labels))
        max_prob = float(probs.max())
        preds    = (probs >= threshold).astype(int)
        detected = _check_persistent(preds, MIN_CONFIRMED)
        # TTD for CNN: window index × stride × 0.5s/frame
        ttd      = None
        if has_inc and detected:
            first_inc_win = next((j for j, l in enumerate(labels) if l == 1), None)
            first_det_win = int(np.where(preds == 1)[0][0]) if detected else None
            if first_inc_win is not None and first_det_win is not None:
                ttd = (first_det_win - first_inc_win) * WINDOW_STRIDE * 0.5
        cnn_rows.append({
            "scenario_id": scen_id,
            "has_incident": has_inc,
            "cnn_max_prob": max_prob,
            "cnn_detected": int(detected),
            "cnn_ttd": ttd,
        })

    cnn_df = pd.DataFrame(cnn_rows)
    print(f"  Scenarios with image data: {len(cnn_df)}  "
          f"(incident={cnn_df['has_incident'].sum()}  "
          f"NI={(cnn_df['has_incident']==0).sum()})")

    # Clean up GPU memory
    del cnn, ds, loader
    gc.collect()
    if torch.cuda.is_available():
        torch.cuda.empty_cache()

    return cnn_df


