def find_input_files() -> dict:
    """
    Locate all required and optional files in the input folder.
    Returns a dict with resolved Path objects (or None for optional missing files).
    Prints a clear error and exits if a required file is missing.
    """
    print(f"\n📁 Scanning input folder: {INPUT_FOLDER}")

    def first(pattern) -> Optional[Path]:
        hits = sorted(INPUT_FOLDER.glob(pattern))
        return hits[0] if hits else None

    files = {
        "rf_model":       first("rf_model*.pkl") or first("*.pkl"),
        "features":       first("feature_columns*.json"),
        "rf_threshold":   first("*threshold*.json") or first("decision_threshold*.json"),
        "cnn_model":      first("cnn_model*.pt"),
        "cnn_meta":       first("cnn_meta*.json"),
        # Detection order determines mode:
        #   val.h5      → CALIBRATION  (sweep + save fusion_settings.json)
        #   test.h5     → EVALUATION   (load fusion_settings.json, apply locked params)
        #   all_data.h5 → EVALUATION   (NI set, FAR only, load locked params)
        "macro_h5": (first("val.h5") or first("test.h5")
                     or first("all_data.h5") or first("*.h5")),
    }

    required = ["rf_model", "features", "rf_threshold", "macro_h5"]
    missing  = [k for k in required if files[k] is None]
    if missing:
        print(f"\n❌ Missing required file(s) in {INPUT_FOLDER}:")
        labels = {
            "rf_model":     "rf_model.pkl  (from models/rf_model.pkl)",
            "features":     "feature_columns.json  (from models/feature_columns.json)",
            "rf_threshold": "decision_threshold.json  (from models/decision_threshold.json)",
            "macro_h5":     "test.h5 OR all_data.h5  (from data/)",
        }
        for k in missing:
            print(f"   • {labels.get(k, k)}")
        sys.exit(1)

    no_cnn = [k for k in ["cnn_model", "cnn_meta"] if files[k] is None]
    if no_cnn:
        print(f"  ⚠️  CNN model files not found — CNN evaluation will be skipped.")
        print(f"     To enable: copy models/cnn/cnn_model_final.pt and cnn_meta_final.json")

    h5_name = files["macro_h5"].name
    mode = _determine_mode(h5_name)
    mode_note = f"→ {mode.upper()} MODE"
    print(f"\n  ✅ RF model:       {files['rf_model'].name}")
    print(f"  ✅ Features:       {files['features'].name}")
    print(f"  ✅ RF threshold:   {files['rf_threshold'].name}")
    print(f"  ✅ Macro data:     {h5_name}  {mode_note}")
    if files["cnn_model"]:
        print(f"  ✅ CNN model:      {files['cnn_model'].name}")
        print(f"  ✅ CNN meta:       {files['cnn_meta'].name}")

    return files


