    # Mark the zero-FAR point
    if zero_far_row is not None:
        ax.axvline(zero_far_row["threshold"], color="seagreen", linestyle=":",
                   linewidth=1.5,
                   label=f"Zero-FAR point (thr={zero_far_row['threshold']:.2f}, "
                         f"DR={zero_far_row['dr']:.1f}%)")
        ax.scatter([zero_far_row["threshold"]], [zero_far_row["dr"]],
                   color="seagreen", s=90, marker="D", zorder=5)

    ax.set_xlabel("avg_prob threshold", fontsize=11)
    ax.set_ylabel("Rate (%)", fontsize=11)
    ax.set_title(
        "Post-hoc Threshold Sensitivity — Average-Probability Fusion\n"
        "⚠  Sweep performed on test data (data-leakage aware — for discussion only)",
        fontsize=10,
    )
    ax.legend(fontsize=9)
    ax.grid(alpha=0.3)
    ax.set_xlim(0, 1)
    ax.set_ylim(-2, 105)
    plt.tight_layout()
    path1 = OUTPUT_DIR / "threshold_sensitivity.png"
    plt.savefig(path1, dpi=150)
    plt.close()
    print(f"\n  💾 DR/FAR vs threshold → {path1.name}")

    # ── Figure 2: DR vs FAR trade-off curve ─────────────────────────────────
    fig, ax = plt.subplots(figsize=(7, 6))
    sc = ax.scatter(
        sweep_df["far"], sweep_df["dr"],
        c=sweep_df["threshold"], cmap="viridis_r",
        s=25, zorder=3,
    )
    ax.plot(sweep_df["far"], sweep_df["dr"],
            color="gray", linewidth=0.8, alpha=0.5, zorder=2)
    plt.colorbar(sc, ax=ax, label="avg_prob threshold")

    # Mark locked threshold
    ax.scatter([locked_far], [locked_dr], color="navy", s=120,
               marker="*", zorder=6,
               label=f"Locked (thr={locked_threshold:.2f})")

    # Mark zero-FAR point
    if zero_far_row is not None:
        ax.scatter([0], [zero_far_row["dr"]], color="seagreen", s=120,
                   marker="D", zorder=6,
                   label=f"Zero-FAR (thr={zero_far_row['threshold']:.2f}, "
                         f"DR={zero_far_row['dr']:.1f}%)")

    ax.set_xlabel("False Alarm Rate (%)", fontsize=11)
    ax.set_ylabel("Detection Rate (%)", fontsize=11)
    ax.set_title(
        "DR vs FAR Trade-off — Average-Probability Fusion\n"
        "⚠  Post-hoc sweep on test data (for discussion only)",
        fontsize=10,
    )
    ax.legend(fontsize=9)
    ax.grid(alpha=0.3)
    ax.set_xlim(-1, max(sweep_df["far"].max() * 1.1, 5))
    ax.set_ylim(-2, 105)
