def plot_precision_recall_curves(
    joint_df: pd.DataFrame, has_incidents: bool,
) -> None:
    """
    Precision-Recall curves for RF, CNN, and average-probability fusion.
    Average Precision (AP) shown in the legend.
    """
    from sklearn.metrics import precision_recall_curve, average_precision_score

    if not has_incidents or joint_df is None:
        return

    y = joint_df["has_incident"].values
    if y.sum() == 0:
        return

    cols = {
        "RF":           "rf_max_prob",
        "CNN":          "cnn_max_prob",
        "Average prob": "avg_prob",
        "Max prob":     "max_prob",
    }

    plt.figure(figsize=(7, 6))
    for label, col in cols.items():
        if col not in joint_df.columns:
            continue
        prec, rec, _ = precision_recall_curve(y, joint_df[col].values)
        ap = average_precision_score(y, joint_df[col].values)
        plt.plot(rec, prec, linewidth=1.8, label=f"{label}  (AP={ap:.3f})")

    # Baseline: random classifier
    baseline = y.mean()
    plt.axhline(baseline, color="gray", linestyle="--", alpha=0.5,
                label=f"Random (prevalence={baseline:.2f})")

    plt.xlabel("Recall (Detection Rate)", fontsize=11)
    plt.ylabel("Precision", fontsize=11)
    plt.title("Precision-Recall Curves — Scenario Level", fontsize=11)
    plt.legend(fontsize=9)
    plt.grid(alpha=0.3)
    plt.xlim(-0.02, 1.02)
    plt.ylim(-0.02, 1.08)
    plt.tight_layout()
    path = OUTPUT_DIR / "precision_recall_curves.png"
    plt.savefig(path, dpi=150)
    plt.close()
    print(f"  💾 Precision-Recall curves → {path.name}")


