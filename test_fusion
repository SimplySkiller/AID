# 8. Main pipeline
# ═══════════════════════════════════════════════════════════════════════════════

def main() -> None:
    wall_start = time.time()

    print("\n" + "="*70)
    print("  AID DUAL-MODEL FUSION EVALUATION")
    print("="*70)
    print("\n  This script evaluates the Random Forest (macro) and CNN (micro)")
    print("  models separately, then tests fusion strategies that combine them.\n")

    # ── 1. Find input files ───────────────────────────────────────────────
    files = find_input_files()
    mode = _determine_mode(files["macro_h5"].name)

    print(f"\n  {'─'*50}")
    if mode == "calibration":
        print(f"  MODE: CALIBRATION  (val.h5 detected)")
        print(f"  Will sweep fusion parameters and save to fusion_settings.json")
    else:
        print(f"  MODE: EVALUATION  ({files['macro_h5'].name} detected)")
        print(f"  Will load locked parameters from fusion_settings.json")
    print(f"  {'─'*50}")

    # ── 2. RF inference ───────────────────────────────────────────────────
    macro_eng, rf_scen_df, rf_threshold = run_rf_inference(files)
    scen_ids = set(rf_scen_df["scenario_id"].unique())
    has_incidents = rf_scen_df["has_incident"].sum() > 0

    # ── 3. CNN inference ──────────────────────────────────────────────────
    cnn_scen_df = run_cnn_inference(files, scen_ids) if CNN_AVAILABLE else None

    # ── 4. Individual evaluations ─────────────────────────────────────────
    print("\n" + "="*60)
    print("  INDIVIDUAL MODEL RESULTS  (scenario-level)")
    print("="*60)

    rf_metrics = evaluate_individual(
        rf_scen_df, "Random Forest (RF)",
        detected_col="rf_detected", prob_col="rf_max_prob",
        ttd_col="rf_ttd", threshold=rf_threshold,
    )
    rf_metrics["model"] = "RF"

    cnn_metrics = None
    if cnn_scen_df is not None:
        cnn_threshold = json.load(open(files["cnn_meta"]))["decision_threshold"]
        cnn_metrics = evaluate_individual(
            cnn_scen_df, "CNN (camera)",
            detected_col="cnn_detected", prob_col="cnn_max_prob",
            ttd_col="cnn_ttd", threshold=cnn_threshold,
        )
        cnn_metrics["model"] = "CNN"

    # ── 5. Fusion ─────────────────────────────────────────────────────────
    fusion_results = []
    joint_df = None
    fusion_val_df = None
    fusion_test_df = None
    best_w = 0.5   # default for weight-sweep plot

    if cnn_scen_df is not None:
        # Build joint DataFrame
        joint_df = rf_scen_df.merge(
            cnn_scen_df[["scenario_id", "has_incident",
                         "cnn_max_prob", "cnn_detected", "cnn_ttd"]],
            on="scenario_id", how="inner", suffixes=("", "_cnn"),
        )
        if "has_incident_cnn" in joint_df.columns:
            joint_df = joint_df.drop(columns=["has_incident_cnn"])

        print(f"\n  Joint scenarios (RF ∩ CNN): {len(joint_df)}")

        if mode == "calibration":
            # ── CALIBRATION: sweep on fusion-val, evaluate on fusion-test ───
            all_scen = joint_df["scenario_id"].values
            rng_fuse = np.random.default_rng(cfg.random_state)
            shuffled = rng_fuse.permutation(all_scen)
            n_val_fuse = max(1, len(shuffled) // 2)
            val_scen_ids  = set(shuffled[:n_val_fuse])
            test_scen_ids = set(shuffled[n_val_fuse:])
            fusion_val_df  = joint_df[joint_df["scenario_id"].isin(val_scen_ids)].copy()
            fusion_test_df = joint_df[joint_df["scenario_id"].isin(test_scen_ids)].copy()

            print(f"  Fusion-Val  : {len(fusion_val_df)} scenarios  "
                  f"(parameter selection, FAR constraint={MAX_FAR_CONSTRAINT*100:.1f}%)")
            print(f"  Fusion-Test : {len(fusion_test_df)} scenarios  (final reported numbers)")

            fusion_results = run_fusion_evaluation(fusion_val_df, fusion_test_df)

            # Extract best w and thresholds from sweep results, save to JSON
            settings_to_save = {"w_rf": 0.5, "thresholds": {
                "avg_prob": 0.5, "w_prob": 0.5, "max_prob": 0.5,
            }}
            for r in fusion_results:
                if "weight_rf" in r:
                    settings_to_save["w_rf"] = float(r["weight_rf"])
                    settings_to_save["thresholds"]["w_prob"] = float(r["threshold"])
                    best_w = r["weight_rf"]
                if r["model"] == "Average prob":
                    settings_to_save["thresholds"]["avg_prob"] = float(r["threshold"])
                if r["model"] == "Max prob":
                    settings_to_save["thresholds"]["max_prob"] = float(r["threshold"])

            with open(FUSION_SETTINGS_PATH, "w") as f:
                json.dump(settings_to_save, f, indent=2)
            print(f"\n  💾 Fusion settings saved → {FUSION_SETTINGS_PATH.name}")
            print(f"     w_rf={settings_to_save['w_rf']:.2f}  "
                  f"thresholds={settings_to_save['thresholds']}")

        else:
            # ── EVALUATION: load locked parameters, no sweep ─────────────
            if not FUSION_SETTINGS_PATH.exists():
                print(f"\n❌ Calibration required: Please run with val.h5 first.")
                print(f"   Expected settings file: {FUSION_SETTINGS_PATH}")
                print(f"   Steps:")
                print(f"     1. Place val.h5 in {INPUT_FOLDER.name}/")
                print(f"     2. Run: python test_fusion.py")
                print(f"     3. Then replace val.h5 with {files['macro_h5'].name} and re-run.")
                sys.exit(1)

            with open(FUSION_SETTINGS_PATH) as f:
                settings = json.load(f)
            print(f"\n  ✅ Loaded fusion_settings.json  "
                  f"(w_rf={settings['w_rf']:.2f})")

            fusion_results, joint_df = run_fusion_evaluation_locked(joint_df, settings)
            best_w = settings["w_rf"]
            # In evaluation mode both val and test are the full joint_df
            # (no split — parameters are already locked from calibration)
            fusion_val_df  = joint_df
            fusion_test_df = joint_df

    else:
        print("\n  ⚠️  Fusion skipped (CNN model not available).")

    # ── 6. Find best fusion method ────────────────────────────────────────
    if fusion_results:
        if has_incidents:
            best_fus = max(fusion_results, key=lambda x: x["dr"])
            print(f"\n  🏆 Best fusion (max DR, FAR≤{MAX_FAR_CONSTRAINT*100:.1f}%): "
                  f"{best_fus['model']}")
            print(f"     DR={best_fus['dr']:.2%}  FAR={best_fus['far']:.2%}  "
                  f"F1={best_fus['f1']:.4f}")
            if "selected_on" in best_fus:
                print(f"     Parameters selected on: {best_fus['selected_on']}")
        else:
            best_fus = min(fusion_results, key=lambda x: x["far"])
            print(f"\n  🏆 Lowest-FAR fusion  : {best_fus['model']}")
            print(f"     FAR={best_fus['far']:.2%}  "
                  f"(no incident data — DR not applicable)")

    # ── 7. Plots ──────────────────────────────────────────────────────────
    print(f"\n{'='*60}")
    print("  GENERATING PLOTS")
    print("="*60)

    plot_comparison_bar(rf_metrics, cnn_metrics, fusion_results, has_incidents)

    if joint_df is not None:
        plot_fusion_scatter(joint_df)
        plot_roc_overlay(fusion_test_df, has_incidents)
        plot_far_vs_threshold(fusion_test_df)
        if mode == "calibration":
            plot_fusion_weight_sweep(fusion_val_df, fusion_test_df, best_w, has_incidents)

    # ── 8. Save results JSON ──────────────────────────────────────────────
    save_payload = {
        "rf":     rf_metrics,
        "cnn":    cnn_metrics,
        "fusion": fusion_results,
        "has_incidents_in_test_set": bool(has_incidents),
        "n_scenarios": int(len(rf_scen_df)),
    }
    # Remove non-serialisable entries from metrics
    def clean(d):
        if d is None:
            return None
        return {k: (float(v) if isinstance(v, (np.floating, np.integer)) else v)
                for k, v in d.items()}
    save_payload["rf"]  = clean(rf_metrics)
    save_payload["cnn"] = clean(cnn_metrics)
    save_payload["fusion"] = [clean(m) for m in fusion_results]

    out_json = OUTPUT_DIR / "fusion_results.json"
    with open(out_json, "w") as f:
        json.dump(save_payload, f, indent=2, default=str)
    print(f"\n  💾 Full results → {out_json}")

    # ── 9. Summary ────────────────────────────────────────────────────────
    elapsed = time.time() - wall_start
    h, rem  = divmod(int(elapsed), 3600)
    m, s    = divmod(rem, 60)

    print(f"\n{'='*70}")
    print("  SUMMARY")
    print("="*70)
    print(f"\n  Mode      : {mode.upper()}")
    print(f"  Test set  : {files['macro_h5'].name}  "
          f"({'incidents present' if has_incidents else 'no incidents — FAR only'})")
    print(f"  Scenarios evaluated: {len(rf_scen_df)}")
    if mode == "calibration" and fusion_test_df is not None:
        print(f"  Fusion-Val / Fusion-Test split: "
              f"{len(fusion_val_df)} / {len(fusion_test_df)} scenarios")
        print(f"  Fusion numbers below are from Fusion-Test (unseen during param selection)")
    elif mode == "evaluation":
        print(f"  Fusion parameters locked from: {FUSION_SETTINGS_PATH.name}")
    print()
    print(f"  {'Model':<22} {'DR':>8} {'FAR':>8} {'F1':>8}")
    print(f"  {'-'*50}")

    def fmt(m_dict, has_inc):
        dr  = f"{m_dict['dr']:.2%}"  if has_inc else "N/A"
        far = f"{m_dict['far']:.2%}"
        f1  = f"{m_dict['f1']:.4f}" if has_inc else "N/A"
        return dr, far, f1

    dr, far, f1 = fmt(rf_metrics, has_incidents)
    print(f"  {'RF only':<22} {dr:>8} {far:>8} {f1:>8}")
    if cnn_metrics:
        dr, far, f1 = fmt(cnn_metrics, has_incidents)
        print(f"  {'CNN only':<22} {dr:>8} {far:>8} {f1:>8}")
    for fm in fusion_results:
        dr, far, f1 = fmt(fm, has_incidents)
        name = fm["model"][:22]
        print(f"  {name:<22} {dr:>8} {far:>8} {f1:>8}")

    print(f"\n  Output folder : {OUTPUT_DIR}")
    print(f"  Elapsed       : {h:02d}h {m:02d}m {s:02d}s")
    print(f"\n{'='*70}")


# ═══════════════════════════════════════════════════════════════════════════════
# How to run — Calibration → Evaluation workflow
# ═══════════════════════════════════════════════════════════════════════════════
#
# STEP 1 — CALIBRATION  (run once to select fusion parameters)
#   1. Copy val.h5 into the input folder (test_fusion_input/)
#   2. python test_fusion.py
#   → Sweeps w and threshold on fusion-val, evaluates on fusion-test (both
#     halves of val.h5).  Saves fusion_settings.json to the input folder.
#
# STEP 2 — EVALUATION on test.h5  (incident scenarios, final thesis numbers)
#   1. Remove val.h5 from the input folder.
#   2. Copy test.h5 into the input folder.
#   3. python test_fusion.py
#   → Loads fusion_settings.json, applies locked w and thresholds.
#     Reports DR, FAR, F1 — these are the numbers for your thesis.
#
# STEP 3 — EVALUATION on all_data.h5  (NI set, FAR robustness check)
#   1. Remove test.h5 from the input folder.
#   2. Copy all_data.h5 (from --no-incident-only run) into the input folder.
#   3. python test_fusion.py
#   → Loads the same fusion_settings.json, reports FAR only (DR = N/A).
#     This confirms the locked parameters don't trigger false alarms on
#     real normal traffic.
#
# To test without the CNN (RF only, much faster):
#   Simply do not place cnn_model_final.pt / cnn_meta_final.json in the
#   input folder.  The script will run RF only and skip fusion.
# ═══════════════════════════════════════════════════════════════════════════════

if __name__ == "__main__":
    main()
