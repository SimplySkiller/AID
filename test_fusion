def run_fusion_evaluation(
    val_df: pd.DataFrame,
    test_df: pd.DataFrame,
) -> List[dict]:
    """
    Evaluate all fusion strategies with proper val/test separation.

    Parameters
    ----------
    val_df  : Fusion-Val scenarios  (used to PICK w and threshold)
    test_df : Fusion-Test scenarios (used to REPORT final numbers)

    Optimization criterion: maximize DR subject to FAR ≤ MAX_FAR_CONSTRAINT.

    AND and OR use the individual model thresholds that were already chosen
    during RF/CNN training — no additional parameter selection needed.
    """
    print("\n" + "="*60)
    print("  FUSION EVALUATION")
    print(f"  Val  : {len(val_df)} scenarios  (parameter selection)")
    print(f"  Test : {len(test_df)} scenarios  (final reported numbers)")
    print("="*60)

    has_val_inc  = val_df["has_incident"].sum()  > 0
    has_test_inc = test_df["has_incident"].sum() > 0
    results = []

    def _apply_probs(df: pd.DataFrame, w_rf: float) -> pd.DataFrame:
        """Add fused probability columns to a copy of df."""
        df = df.copy()
        df["avg_prob"] = (df["rf_max_prob"] + df["cnn_max_prob"]) / 2
        df["w_prob"]   = w_rf * df["rf_max_prob"] + (1 - w_rf) * df["cnn_max_prob"]
        df["max_prob"] = df[["rf_max_prob", "cnn_max_prob"]].max(axis=1)
        return df

    def _eval(df, col, thr):
        preds = (df[col] >= thr).astype(int)
        tp = int(((df["has_incident"] == 1) & (preds == 1)).sum())
        fn = int(((df["has_incident"] == 1) & (preds == 0)).sum())
        fp = int(((df["has_incident"] == 0) & (preds == 1)).sum())
        tn = int(((df["has_incident"] == 0) & (preds == 0)).sum())
        return dict(tp=tp, fn=fn, fp=fp, tn=tn,
                    dr=tp/max(tp+fn,1), far=fp/max(fp+tn,1),
                    f1=2*tp/max(2*tp+fp+fn,1),
                    precision=tp/max(tp+fp,1), recall=tp/max(tp+fn,1))

    # ── AND (no threshold to select — uses individual model decisions) ────
    for df in [val_df, test_df]:
        df["and_detected"] = ((df["rf_detected"]==1) & (df["cnn_detected"]==1)).astype(int)
        df["or_detected"]  = ((df["rf_detected"]==1) | (df["cnn_detected"]==1)).astype(int)

    for tag, col in [("AND", "and_detected"), ("OR", "or_detected")]:
        m_test = _scenario_metrics(test_df, col)
        m_test["model"] = tag
        m_test["threshold"] = "individual model thresholds"
        m_test["selected_on"] = "N/A (no free parameters)"
        results.append(m_test)
        print(f"\n  {tag:<5}: DR={m_test['dr']:.2%}  FAR={m_test['far']:.2%}  F1={m_test['f1']:.4f}")

    # ── Average prob ──────────────────────────────────────────────────────
    val_a  = _apply_probs(val_df,  0.5)
    test_a = _apply_probs(test_df, 0.5)
    best_avg = _sweep_threshold(val_a, "avg_prob", has_val_inc, MAX_FAR_CONSTRAINT)
    m_test = _eval(test_a, "avg_prob", best_avg["threshold"])
    test_a["avg_detected"] = (test_a["avg_prob"] >= best_avg["threshold"]).astype(int)
    m_test.update(_scenario_metrics(test_a, "avg_detected"))
    m_test["model"] = "Average prob"
    m_test["threshold"] = best_avg["threshold"]
    m_test["selected_on"] = "fusion-val"
    results.append(m_test)
    print(f"  Avg  : DR={m_test['dr']:.2%}  FAR={m_test['far']:.2%}  F1={m_test['f1']:.4f}"
          f"  (thr={best_avg['threshold']:.2f}  selected on val)")

    # ── Weighted avg — sweep w on val_df ──────────────────────────────────
    print("  Weighted avg sweep on fusion-val ...")
    best_score  = -np.inf
    best_w      = 0.5
    best_w_thr  = 0.5

    for w in np.arange(0.0, 1.01, 0.05):
        w = round(w, 2)
        val_w = val_df.copy()
        val_w["w_prob"] = w * val_w["rf_max_prob"] + (1-w) * val_w["cnn_max_prob"]
        res = _sweep_threshold(val_w, "w_prob", has_val_inc, MAX_FAR_CONSTRAINT)
        # Score: DR if FAR constraint met, else penalise
        score = res["dr"] if res["far"] <= MAX_FAR_CONSTRAINT else -res["far"]
        if score > best_score:
            best_score = score
            best_w     = w
            best_w_thr = res["threshold"]

    test_w = _apply_probs(test_df, best_w)
    test_w["w_detected"] = (test_w["w_prob"] >= best_w_thr).astype(int)
    m_test = _scenario_metrics(test_w, "w_detected")
    m_test["model"]       = f"Weighted(w_rf={best_w:.2f})"
    m_test["threshold"]   = best_w_thr
    m_test["weight_rf"]   = best_w
    m_test["selected_on"] = "fusion-val"
    results.append(m_test)
    print(f"  Wgt  : DR={m_test['dr']:.2%}  FAR={m_test['far']:.2%}  F1={m_test['f1']:.4f}"
          f"  (w_rf={best_w:.2f}  thr={best_w_thr:.2f}  selected on val)")

    # Attach the selected w/thr to test_df for the weight-sweep plot
    test_df["w_prob"]   = best_w * test_df["rf_max_prob"] + (1-best_w) * test_df["cnn_max_prob"]
    val_df["w_prob"]    = best_w * val_df["rf_max_prob"]  + (1-best_w) * val_df["cnn_max_prob"]
    test_df["avg_prob"] = (test_df["rf_max_prob"] + test_df["cnn_max_prob"]) / 2
    val_df["avg_prob"]  = (val_df["rf_max_prob"]  + val_df["cnn_max_prob"])  / 2
    test_df["max_prob"] = test_df[["rf_max_prob","cnn_max_prob"]].max(axis=1)
    val_df["max_prob"]  = val_df[["rf_max_prob","cnn_max_prob"]].max(axis=1)

    # ── Max prob ──────────────────────────────────────────────────────────
    best_max = _sweep_threshold(val_df, "max_prob", has_val_inc, MAX_FAR_CONSTRAINT)
    test_df["max_detected"] = (test_df["max_prob"] >= best_max["threshold"]).astype(int)
    m_test = _scenario_metrics(test_df, "max_detected")
    m_test["model"]       = "Max prob"
    m_test["threshold"]   = best_max["threshold"]
    m_test["selected_on"] = "fusion-val"
    results.append(m_test)
    print(f"  Max  : DR={m_test['dr']:.2%}  FAR={m_test['far']:.2%}  F1={m_test['f1']:.4f}"
          f"  (thr={best_max['threshold']:.2f}  selected on val)")

    # Store selected params for the weight-sweep plot
    results[-1]["best_w"]       = best_w
    results[-1]["best_w_thr"]   = best_w_thr

    return results


def _sweep_threshold(
    df: pd.DataFrame,
    prob_col: str,
    has_incidents: bool,
    max_far: Optional[float] = None,
) -> dict:
    """
    Sweep thresholds 0.02–0.98 and return the best result.

    Optimization criterion (in priority order):
      1. If max_far is set (safety constraint mode):
           Maximize DR subject to FAR ≤ max_far.
           Falls back to lowest-FAR threshold if no threshold satisfies
           the constraint (e.g. very small val set).
      2. Else if has_incidents: maximize F1.
      3. Else (NI-only): minimize FAR.

    Bug-fix note: uses a separate `best_score` float to track the running
    best, so the NI-mode score (-far, a negative float) is never compared
    against the f1 field (which is 0 in NI mode) of the stored best dict.
    """
    best_score: float = -np.inf
    best = {"f1": 0.0, "threshold": 0.5, "dr": 0.0, "far": 1.0}

    for thr in np.arange(0.02, 0.99, 0.02):
        preds = (df[prob_col] >= thr).astype(int)
        tp = int(((df["has_incident"] == 1) & (preds == 1)).sum())
        fn = int(((df["has_incident"] == 1) & (preds == 0)).sum())
        fp = int(((df["has_incident"] == 0) & (preds == 1)).sum())
        tn = int(((df["has_incident"] == 0) & (preds == 0)).sum())
        f1  = 2 * tp / max(2 * tp + fp + fn, 1)
        dr  = tp / max(tp + fn, 1)
        far = fp / max(fp + tn, 1)

        if max_far is not None:
            # Safety-constraint mode: maximize DR, discard anything above FAR ceiling
            score = dr if far <= max_far else -1.0
        elif has_incidents:
            score = f1
        else:
            score = -far   # NI-only: minimize false alarms

        if score > best_score:
            best_score = score
            best = {"f1": f1, "threshold": float(thr), "dr": dr, "far": far}

    return best


