# 10. Additional diagnostic plots
# ═══════════════════════════════════════════════════════════════════════════════

def plot_confusion_matrices(
    rf_m: dict,
    cnn_m: Optional[dict],
    cal_m: Optional[dict],
    best_fusion_m: Optional[dict],
    has_incidents: bool,
) -> None:
    """
    Side-by-side confusion-matrix heatmaps for every available model.
    Normalised by true label (rows sum to 1) so absolute scenario counts
    don't distort the visual when set sizes differ.
    """
    if not has_incidents:
        return

    panels = [("RF", rf_m)]
    if cnn_m:
        panels.append(("CNN", cnn_m))
    if cal_m:
        panels.append(("Cal. Alg.", cal_m))
    if best_fusion_m:
        label = best_fusion_m.get("model", "Best fusion")[:14]
        panels.append((label, best_fusion_m))

    n = len(panels)
    fig, axes = plt.subplots(1, n, figsize=(4 * n, 3.8))
    if n == 1:
        axes = [axes]

    for ax, (name, m) in zip(axes, panels):
        tp = m.get("tp", 0)
        fn = m.get("fn", 0)
        fp = m.get("fp", 0)
        tn = m.get("tn", 0)
        # Normalise rows (actual positives / actual negatives)
        pos_total = max(tp + fn, 1)
        neg_total = max(fp + tn, 1)
        mat = np.array([
            [tp / pos_total, fn / pos_total],
            [fp / neg_total, tn / neg_total],
        ])
        im = ax.imshow(mat, cmap="Blues", vmin=0, vmax=1)
        for (r, c), val in np.ndenumerate(mat):
            ax.text(c, r, f"{val:.2f}", ha="center", va="center",
                    fontsize=11,
