# 9b. California Algorithm — calibration (val.h5)
# ═══════════════════════════════════════════════════════════════════════════════

def run_california_calibration(
    macro_df: pd.DataFrame, has_incidents: bool,
) -> dict:
    """
    CALIBRATION MODE: sweep the full grid on val.h5, select best configuration
    under FAR ≤ MAX_FAR_CONSTRAINT, and save to california_settings.json.

    This mirrors exactly what run_fusion_evaluation() does for ML fusion:
    parameters are selected on val.h5 ONLY and locked before any test set
    is evaluated.

    Returns a metrics dict for the calibration-set summary (indicative;
    final thesis numbers come from the locked evaluation on test.h5).
    """
    print("\n" + "="*60)
    print("  CALIFORNIA ALGORITHM — CALIBRATION")
    print("="*60)
    print(f"  Alarm : det3_speed < V  AND  det3_occ > O  for P seconds")
    print(f"  Goal  : maximize DR  subject to FAR ≤ {MAX_FAR_CONSTRAINT*100:.1f}%")

    try:
        grouped = _group_macro_for_cal(macro_df)
    except ValueError as e:
        print(f"  ❌ {e}\n  California Algorithm skipped.")
        return {}

    results_df = _cal_grid_sweep(grouped)
    best = _best_cal_row(results_df)

    constrained_ok = float(best["far"]) <= MAX_FAR_CONSTRAINT
    if not constrained_ok:
        print(f"  ⚠️  No config satisfies FAR ≤ {MAX_FAR_CONSTRAINT*100:.1f}% "
              f"— saving lowest-FAR config.")

    settings = {
        "speed_thr": float(best["speed_thr"]),
        "occ_thr":   float(best["occ_thr"]),
        "persist_s": int(best["persist_s"]),
    }
    with open(CAL_SETTINGS_PATH, "w") as f:
        json.dump(settings, f, indent=2)

    print(f"\n  Selected config (val.h5):")
    print(f"    Speed < {best['speed_thr']:.1f} m/s ({best['speed_thr']*3.6:.0f} km/h)  |  "
          f"Occ > {best['occ_thr']*100:.0f}%  |  Persist {int(best['persist_s'])}s")
    print(f"    DR={best['dr']:.2%}  FAR={best['far']:.2%}  F1={best['f1']:.4f}")
    print(f"  💾 california_settings.json saved → {CAL_SETTINGS_PATH.name}")
    print(f"     Parameters LOCKED — will not change on test/NI evaluation runs.")

    csv_path = OUTPUT_DIR / "california_calibration_sweep.csv"
    results_df.to_csv(csv_path, index=False)
    print(f"  💾 Calibration sweep → {csv_path.name}")

    if has_incidents:
        _plot_california_heatmap(results_df, title_suffix="calibration — val.h5")

    return _cal_row_to_metrics(best, selected_on="val.h5 calibration")


# ═══════════════════════════════════════════════════════════════════════════════
# 9c. California Algorithm — evaluation (test.h5 / all_data.h5)
# ═══════════════════════════════════════════════════════════════════════════════

def run_california_evaluation(
    macro_df: pd.DataFrame, settings: dict, has_incidents: bool,
) -> Tuple[dict, List[Optional[float]]]:
    """
    EVALUATION MODE: apply locked parameters from california_settings.json.
    No sweeping — parameters are fixed from calibration.

    Returns (metrics_dict, ttd_list).
    ttd_list contains one entry per incident scenario: the TTD in seconds, or
    None if the scenario was not detected.  Used for the TTD comparison plot.
    """
    print("\n" + "="*60)
    print("  CALIFORNIA ALGORITHM — EVALUATION  (locked parameters)")
    print("="*60)

    v = float(settings["speed_thr"])
    o = float(settings["occ_thr"])
    p = int(settings["persist_s"])
    print(f"  Speed < {v:.1f} m/s ({v*3.6:.0f} km/h)  |  "
          f"Occ > {o*100:.0f}%  |  Persist {p}s")
    print(f"  (locked from {CAL_SETTINGS_PATH.name})")

    try:
        grouped = _group_macro_for_cal(macro_df)
    except ValueError as e:
        print(f"  ❌ {e}\n  California Algorithm skipped.")
        return {}, []

    result = _eval_cal_scenarios(grouped, v, o, p)
    ttd_list = result.pop("ttd_list")

    print(f"\n  TP={result['tp']}  FN={result['fn']}  FP={result['fp']}  TN={result['tn']}")
    print(f"  DR={result['dr']:.2%}  FAR={result['far']:.2%}  F1={result['f1']:.4f}")
    if has_incidents:
        valid = [t for t in ttd_list if t is not None]
        if valid:
            print(f"  Median TTD: {np.median(valid):.1f}s  "
                  f"(n_detected={len(valid)})")

    metrics = _cal_row_to_metrics(pd.Series(result), selected_on="locked from val.h5")
    return metrics, ttd_list


