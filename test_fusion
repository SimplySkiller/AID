# POST-HOC ANALYSIS A: Threshold Sensitivity Sweep
# ═══════════════════════════════════════════════════════════════════════════════
#
#  ⚠️  DATA-LEAKAGE DISCLAIMER
#  This analysis sweeps the avg_prob threshold AFTER seeing the test results.
#  It is intentionally post-hoc and exploratory. The locked threshold saved in
#  fusion_settings.json (calibrated on val.h5 only) is the primary thesis
#  result.  This sweep is included ONLY to illustrate the DR/FAR trade-off
#  curve and to identify the "zero-FAR operating point" for discussion.
#  Label any resulting figure in the thesis:
#    "Post-hoc threshold sensitivity — shown for discussion only;
#     threshold was locked on val.h5 prior to test-set evaluation."
# ═══════════════════════════════════════════════════════════════════════════════

def run_threshold_sensitivity_analysis(
    joint_df: pd.DataFrame,
    locked_threshold: float,
    has_incidents: bool,
) -> Optional[dict]:
    """
    Post-hoc sweep of avg_prob threshold (0.02 → 0.99, step 0.01).

    Returns a dict summarising the zero-FAR operating point, or None if no
    incident data is available (FAR-only mode makes this analysis trivial).

    Saves:
      threshold_sensitivity.png  — DR and FAR vs threshold (primary figure)
      threshold_sensitivity_drfar.png — DR vs FAR trade-off curve
      threshold_sensitivity.csv  — full sweep table
    """
    if not has_incidents:
        print("\n  ⚠️  Threshold sensitivity skipped — no incident scenarios in this set.")
        return None

    print(f"\n{'═'*70}")
    print("  POST-HOC ANALYSIS A: AVG-PROB THRESHOLD SENSITIVITY")
    print("═" * 70)
    print("""
  ⚠️  DATA-LEAKAGE DISCLAIMER
  The threshold is swept on the SAME data used for final evaluation.
  This is intentionally post-hoc. The locked threshold (fusion_settings.json)
  remains the primary result. Presented for thesis discussion only.
""")

    thresholds = np.arange(0.02, 1.00, 0.01)
    rows = []
    for thr in thresholds:
        preds = (joint_df["avg_prob"] >= thr).astype(int)
        tp = int(((joint_df["has_incident"] == 1) & (preds == 1)).sum())
        fn = int(((joint_df["has_incident"] == 1) & (preds == 0)).sum())
        fp = int(((joint_df["has_incident"] == 0) & (preds == 1)).sum())
        tn = int(((joint_df["has_incident"] == 0) & (preds == 0)).sum())
        dr  = tp / max(tp + fn, 1) * 100
        far = fp / max(fp + tn, 1) * 100
        f1  = 2 * tp / max(2 * tp + fp + fn, 1)
        rows.append(dict(threshold=round(float(thr), 2), dr=dr, far=far, f1=f1,
                         tp=tp, fn=fn, fp=fp, tn=tn))

    sweep_df = pd.DataFrame(rows)

    # ── Key operating points ────────────────────────────────────────────────
    # 1. The locked threshold (primary result)
    locked_row = sweep_df.iloc[(sweep_df["threshold"] - locked_threshold).abs().argsort()[:1]]

    # 2. Zero-FAR threshold: highest threshold where FAR=0
    zero_far_rows = sweep_df[sweep_df["far"] == 0.0]
    if not zero_far_rows.empty:
        zero_far_row = zero_far_rows.loc[zero_far_rows["threshold"].idxmin()]  # lowest thr → highest DR at FAR=0
    else:
        zero_far_row = None

    # 3. Best F1 operating point
    best_f1_row = sweep_df.loc[sweep_df["f1"].idxmax()]

    print(f"  Locked threshold (from val.h5 calibration):  "
          f"thr={locked_threshold:.2f}  "
