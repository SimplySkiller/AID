    print(f"\n── {model_name} ─────────────────────────────────────")
    print(f"  threshold={threshold:.4f}")
    print(f"  TP={m['tp']}  FN={m['fn']}  FP={m['fp']}  TN={m['tn']}")
    print(f"  Detection Rate : {m['dr']:.2%}")
    print(f"  False Alarm Rate: {m['far']:.2%}")
    print(f"  F1 (scenario)  : {m['f1']:.4f}")

    if has_incidents and scen_df[ttd_col].notna().any():
        med_ttd = scen_df[ttd_col].median()
        print(f"  Median TTD     : {med_ttd:.1f}s")
        m["median_ttd"] = float(med_ttd)

    m["model"] = model_name
    m["threshold"] = threshold
    return m


