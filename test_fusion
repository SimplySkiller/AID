# 4. Helper utilities
# ═══════════════════════════════════════════════════════════════════════════════

def _check_persistent(preds: np.ndarray, min_count: int) -> bool:
    """True if there are at least min_count consecutive positive predictions."""
    count = 0
    for p in preds:
        count = count + 1 if p == 1 else 0
        if count >= min_count:
            return True
    return False


def _compute_ttd(
    grp: pd.DataFrame,
    preds: np.ndarray,
    has_inc: int,
    time_col: str,
) -> Optional[float]:
    """Time-to-detection: seconds from incident_active=1 first appearing
    to first persistent prediction of 1. None if not detected or no incident."""
    if not has_inc:
        return None
    inc_rows = grp[grp["y_true"] == 1]
    if inc_rows.empty:
        return None
    inc_start = float(inc_rows[time_col].iloc[0])
    consec = 0
    for idx, (_, row) in enumerate(grp.iterrows()):
        consec = consec + 1 if preds[idx] == 1 else 0
        if consec >= MIN_CONFIRMED:
            return float(row[time_col]) - inc_start
    return None


def _scenario_metrics(
    scen_df: pd.DataFrame,
    detected_col: str,
    label_col: str = "has_incident",
) -> dict:
    """Compute TP/FN/FP/TN and derived rates from a scenario-level DataFrame."""
    tp = int(((scen_df[label_col] == 1) & (scen_df[detected_col] == 1)).sum())
    fn = int(((scen_df[label_col] == 1) & (scen_df[detected_col] == 0)).sum())
    fp = int(((scen_df[label_col] == 0) & (scen_df[detected_col] == 1)).sum())
    tn = int(((scen_df[label_col] == 0) & (scen_df[detected_col] == 0)).sum())
    dr  = tp / max(tp + fn, 1)
    far = fp / max(fp + tn, 1)
    f1  = 2*tp / max(2*tp + fp + fn, 1)
    return dict(tp=tp, fn=fn, fp=fp, tn=tn,
                dr=dr, far=far, f1=f1,
                precision=tp/max(tp+fp,1), recall=dr)


