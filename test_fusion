# 9a. California Algorithm — shared helpers
# ═══════════════════════════════════════════════════════════════════════════════

_CAL_REQUIRED_COLS = [
    "det3_occupancy", "det3_speed_mean",
    "scenario_id", "sim_time", "incident_active", "has_incident",
]


def _group_macro_for_cal(macro_df: pd.DataFrame) -> dict:
    """Pre-group macro DataFrame by scenario_id. Raises ValueError if columns missing."""
    missing = [c for c in _CAL_REQUIRED_COLS if c not in macro_df.columns]
    if missing:
        raise ValueError(f"Missing columns for California Algorithm: {missing}")
    return {sid: grp.sort_values("sim_time").reset_index(drop=True)
            for sid, grp in macro_df.groupby("scenario_id")}


def _eval_cal_scenarios(
    grouped: dict, v_thr: float, o_thr: float, p_s: int
) -> dict:
    """
    Evaluate one parameter configuration on a pre-grouped scenario dict.

    Returns aggregate metrics PLUS per-scenario TTD list (None = not detected).
    This is the single evaluation kernel shared by calibration, locked evaluation,
    and the post-hoc sweep.
    """
    tp = fn = fp = tn = 0
    ttd_list: List[Optional[float]] = []

    for sid, grp in grouped.items():
        has_inc     = int(grp["has_incident"].max())
        speed       = grp["det3_speed_mean"].values
        occ         = grp["det3_occupancy"].values
        inc_act     = grp["incident_active"].values
        times       = grp["sim_time"].values
        cond        = ((speed < v_thr) & (occ > o_thr)).astype(int)
        consec      = 0
        alarm_t     = None
        inc_start_t = None

        for i in range(len(cond)):
            if inc_act[i] == 1 and inc_start_t is None:
                inc_start_t = float(times[i])
            consec = consec + 1 if cond[i] == 1 else 0
            if consec >= p_s and alarm_t is None:
                alarm_t = float(times[i])

        alarm_after = (alarm_t is not None and inc_start_t is not None
                       and alarm_t >= inc_start_t)

        if has_inc:
            if alarm_after:
                tp += 1
                ttd_list.append(float(alarm_t - inc_start_t))
            else:
                fn += 1
                ttd_list.append(None)
        else:
            if alarm_t is not None:
                fp += 1
            else:
                tn += 1

    dr  = tp / max(tp + fn, 1)
    far = fp / max(fp + tn, 1)
    f1  = 2 * tp / max(2 * tp + fp + fn, 1)
    return dict(tp=tp, fn=fn, fp=fp, tn=tn, dr=dr, far=far, f1=f1,
                ttd_list=ttd_list, speed_thr=v_thr, occ_thr=o_thr, persist_s=p_s)


def _cal_grid_sweep(grouped: dict) -> pd.DataFrame:
    """Run the full CAL_SPEED_THRS × CAL_OCC_THRS × CAL_PERSIST_SEC grid.
    Returns a tidy DataFrame (ttd_list excluded — not serialisable)."""
    n = len(CAL_SPEED_THRS) * len(CAL_OCC_THRS) * len(CAL_PERSIST_SEC)
    print(f"  Sweeping {n} parameter combinations ...")
    rows = []
    for v in CAL_SPEED_THRS:
        for o in CAL_OCC_THRS:
            for p in CAL_PERSIST_SEC:
                r = _eval_cal_scenarios(grouped, v, o, p)
                r.pop("ttd_list")
                rows.append(r)
    return pd.DataFrame(rows)


def _best_cal_row(results_df: pd.DataFrame) -> pd.Series:
    """Maximize DR subject to FAR ≤ MAX_FAR_CONSTRAINT; fall back to lowest-FAR."""
    constrained = results_df[results_df["far"] <= MAX_FAR_CONSTRAINT]
    if not constrained.empty:
        return constrained.loc[constrained["dr"].idxmax()]
    return results_df.loc[results_df["far"].idxmin()]


def _cal_row_to_metrics(row: pd.Series, selected_on: str) -> dict:
    """Convert a grid-sweep result row into a standard metrics dict."""
    tp, fp = int(row["tp"]), int(row["fp"])
    return {
        "model":       "California Alg.",
        "dr":          float(row["dr"]),
        "far":         float(row["far"]),
        "f1":          float(row["f1"]),
        "tp":          tp,
        "fn":          int(row["fn"]),
        "fp":          fp,
        "tn":          int(row["tn"]),
        "precision":   tp / max(tp + fp, 1),
        "recall":      float(row["dr"]),
        "threshold":   (f"V<{row['speed_thr']:.0f}m/s & "
                        f"O>{row['occ_thr']*100:.0f}%, "
                        f"persist={int(row['persist_s'])}s"),
        "selected_on": selected_on,
    }


