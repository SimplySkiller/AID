def plot_fusion_weight_sweep(
    val_df: pd.DataFrame,
    test_df: pd.DataFrame,
    best_w: float,
    has_incidents: bool,
) -> None:
    """
    Plot DR and FAR across all RF weights (0.0 → 1.0) evaluated on test_df,
    with the threshold for each weight chosen on val_df (no leakage).

    The selected best_w is marked with a vertical line. This plot visually
    justifies the chosen fusion weight for the thesis: it shows the trade-off
    between DR and FAR as the contribution of each model is varied.

    X-axis: RF weight (0 = CNN only, 1 = RF only)
    Y-axis: Detection Rate and False Alarm Rate (%)
    """
    if not has_incidents:
        # NI-only mode: only FAR is meaningful
        weights = np.arange(0.0, 1.01, 0.05)
        far_vals = []
        for w in weights:
            w = round(w, 2)
            val_tmp = val_df.copy()
            val_tmp["w_prob"] = w * val_tmp["rf_max_prob"] + (1-w) * val_tmp["cnn_max_prob"]
            res = _sweep_threshold(val_tmp, "w_prob", False, MAX_FAR_CONSTRAINT)
            thr = res["threshold"]
            test_tmp = test_df.copy()
            test_tmp["w_prob"] = w * test_tmp["rf_max_prob"] + (1-w) * test_tmp["cnn_max_prob"]
            preds = (test_tmp["w_prob"] >= thr).astype(int)
            fp = int(((test_tmp["has_incident"] == 0) & (preds == 1)).sum())
            tn = int(((test_tmp["has_incident"] == 0) & (preds == 0)).sum())
            far_vals.append(fp / max(fp + tn, 1) * 100)

        fig, ax = plt.subplots(figsize=(9, 5))
        ax.plot(weights, far_vals, color="tomato", linewidth=2, label="FAR (%)")
        ax.axvline(best_w, color="navy", linestyle="--",
                   label=f"Selected w_rf={best_w:.2f}")
        ax.axhline(MAX_FAR_CONSTRAINT * 100, color="gray", linestyle=":",
                   label=f"FAR constraint ({MAX_FAR_CONSTRAINT*100:.1f}%)")
        ax.set_xlabel("RF weight  (0 = CNN only,  1 = RF only)")
        ax.set_ylabel("False Alarm Rate (%)")
        ax.set_title("Fusion Weight Sweep — FAR vs RF Weight (NI mode)")
        ax.legend()
        ax.grid(alpha=0.3)
    else:
        weights = np.arange(0.0, 1.01, 0.05)
        dr_vals, far_vals = [], []
        for w in weights:
            w = round(w, 2)
            val_tmp = val_df.copy()
            val_tmp["w_prob"] = w * val_tmp["rf_max_prob"] + (1-w) * val_tmp["cnn_max_prob"]
            res = _sweep_threshold(val_tmp, "w_prob", True, MAX_FAR_CONSTRAINT)
            thr = res["threshold"]
            test_tmp = test_df.copy()
            test_tmp["w_prob"] = w * test_tmp["rf_max_prob"] + (1-w) * test_tmp["cnn_max_prob"]
            preds = (test_tmp["w_prob"] >= thr).astype(int)
            tp = int(((test_tmp["has_incident"] == 1) & (preds == 1)).sum())
            fn = int(((test_tmp["has_incident"] == 1) & (preds == 0)).sum())
            fp = int(((test_tmp["has_incident"] == 0) & (preds == 1)).sum())
            tn = int(((test_tmp["has_incident"] == 0) & (preds == 0)).sum())
            dr_vals.append(tp / max(tp + fn, 1) * 100)
            far_vals.append(fp / max(fp + tn, 1) * 100)

        fig, ax = plt.subplots(figsize=(9, 5))
        ax.plot(weights, dr_vals,  color="steelblue", linewidth=2, label="Detection Rate (%)")
        ax.plot(weights, far_vals, color="tomato",    linewidth=2, label="False Alarm Rate (%)")
        ax.axvline(best_w, color="navy", linestyle="--",
                   label=f"Selected w_rf={best_w:.2f}")
        ax.axhline(MAX_FAR_CONSTRAINT * 100, color="gray", linestyle=":",
                   label=f"FAR constraint ({MAX_FAR_CONSTRAINT*100:.1f}%)")
        ax.set_xlabel("RF weight  (0 = CNN only,  1 = RF only)")
        ax.set_ylabel("Rate (%)")
        ax.set_title("Fusion Weight Sweep — DR and FAR vs RF Weight\n"
                     "(threshold selected on fusion-val at each weight)")
        ax.legend()
        ax.grid(alpha=0.3)
        ax.set_ylim(-2, 105)

    plt.tight_layout()
    path = OUTPUT_DIR / "fusion_weight_sweep.png"
