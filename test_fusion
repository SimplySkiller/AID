# 9d. California Algorithm — post-hoc data-leakage sweep (stays at the end)
# ═══════════════════════════════════════════════════════════════════════════════

def run_california_posthoc_sweep(
    macro_df: pd.DataFrame, has_incidents: bool,
) -> Optional[dict]:
    """
    POST-HOC: sweep the parameter grid on the SAME data used for evaluation.

    ⚠️  DATA-LEAKAGE DISCLAIMER
    Parameters are selected on the test set itself.  This is intentionally
    post-hoc.  The locked config from california_settings.json (calibrated
    on val.h5) is the primary result.  This sweep is shown only to illustrate
    the best theoretically achievable performance of the California Algorithm
    and to identify operating points for thesis discussion.
    Label any resulting figure:
      "Post-hoc parameter sweep — shown for discussion only;
       parameters were locked on val.h5 prior to test-set evaluation."
    """
    print(f"\n{'═'*70}")
    print("  POST-HOC ANALYSIS B: CALIFORNIA ALGORITHM — DATA-LEAKAGE SWEEP")
    print("═" * 70)
    print("""
  ⚠️  DATA-LEAKAGE DISCLAIMER
  Parameters selected on the SAME data used for evaluation.
  The locked config (california_settings.json) is the primary result.
  Presented for thesis discussion / upper-bound reference only.
""")

    try:
        grouped = _group_macro_for_cal(macro_df)
    except ValueError as e:
        print(f"  ❌ {e}\n  Post-hoc sweep skipped.")
        return None

    results_df = _cal_grid_sweep(grouped)
    best = _best_cal_row(results_df)

    constrained = results_df[results_df["far"] <= MAX_FAR_CONSTRAINT]
    note = (f"FAR ≤ {MAX_FAR_CONSTRAINT*100:.1f}% satisfied"
            if not constrained.empty
            else f"⚠  No config satisfies FAR ≤ {MAX_FAR_CONSTRAINT*100:.1f}%")

    best_f1_row = results_df.loc[results_df["f1"].idxmax()]

    print(f"  {note}")
    print(f"\n  Best (maximize DR, FAR≤{MAX_FAR_CONSTRAINT*100:.1f}%):")
    print(f"    Speed < {best['speed_thr']:.1f} m/s ({best['speed_thr']*3.6:.0f} km/h)  |  "
          f"Occ > {best['occ_thr']*100:.0f}%  |  Persist {int(best['persist_s'])}s")
    print(f"    DR={best['dr']:.2%}  FAR={best['far']:.2%}  F1={best['f1']:.4f}")

    if best_f1_row["f1"] > best["f1"]:
        print(f"\n  Best-F1 (post-hoc reference):")
        print(f"    Speed < {best_f1_row['speed_thr']:.1f} m/s  |  "
              f"Occ > {best_f1_row['occ_thr']*100:.0f}%  |  "
              f"Persist {int(best_f1_row['persist_s'])}s")
        print(f"    DR={best_f1_row['dr']:.2%}  FAR={best_f1_row['far']:.2%}  "
              f"F1={best_f1_row['f1']:.4f}")

    if has_incidents:
        _plot_california_heatmap(results_df, title_suffix="post-hoc — test data ⚠ leakage")

    csv_path = OUTPUT_DIR / "california_posthoc_sweep.csv"
    results_df.to_csv(csv_path, index=False)
    print(f"\n  💾 Post-hoc sweep → {csv_path.name}")

    return _cal_row_to_metrics(best, selected_on="post-hoc (test set — data leakage)")


def _plot_california_heatmap(
    results_df: pd.DataFrame,
    title_suffix: str = "",
) -> None:
    """DR and FAR heatmaps across speed_thr × occ_thr, best persistence per cell."""
    speed_thrs = sorted(results_df["speed_thr"].unique())
    occ_thrs   = sorted(results_df["occ_thr"].unique())

    dr_grid  = np.full((len(speed_thrs), len(occ_thrs)), np.nan)
    far_grid = np.full((len(speed_thrs), len(occ_thrs)), np.nan)
    persist_grid = np.full((len(speed_thrs), len(occ_thrs)), np.nan)

    for i, v in enumerate(speed_thrs):
        for j, o in enumerate(occ_thrs):
            cell = results_df[
                (results_df["speed_thr"] == v) & (results_df["occ_thr"] == o)
            ]
            constrained = cell[cell["far"] <= MAX_FAR_CONSTRAINT]
            best = (constrained.loc[constrained["dr"].idxmax()]
                    if not constrained.empty
                    else cell.loc[cell["far"].idxmin()])
            dr_grid[i, j]      = best["dr"] * 100
            far_grid[i, j]     = best["far"] * 100
            persist_grid[i, j] = best["persist_s"]

    speed_labels = [f"{v*3.6:.0f}" for v in speed_thrs]
    occ_labels   = [f"{o*100:.0f}%" for o in occ_thrs]

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    for ax, grid, metric_name, cmap in [
        (axes[0], dr_grid,  "Detection Rate (%)",   "Blues"),
        (axes[1], far_grid, "False Alarm Rate (%)", "Reds"),
    ]:
        im = ax.imshow(grid, cmap=cmap, aspect="auto", vmin=0, vmax=100)
        plt.colorbar(im, ax=ax)
        ax.set_xticks(range(len(occ_thrs)))
        ax.set_xticklabels(occ_labels, fontsize=8)
        ax.set_yticks(range(len(speed_thrs)))
        ax.set_yticklabels(speed_labels, fontsize=8)
        ax.set_xlabel("Occupancy threshold", fontsize=10)
        ax.set_ylabel("Speed threshold (km/h)", fontsize=10)
        ax.set_title(
            f"California Algorithm — {metric_name}\n"
            f"({title_suffix}  |  best persist per cell, "
            f"FAR≤{MAX_FAR_CONSTRAINT*100:.1f}% preferred)",
            fontsize=9,
        )
        for i in range(len(speed_thrs)):
            for j in range(len(occ_thrs)):
                val = grid[i, j]
                p_s = int(persist_grid[i, j])
                ax.text(j, i, f"{val:.0f}\n({p_s}s)", ha="center", va="center",
                        fontsize=6.5,
                        color="white" if val > 55 else "black")

    tag = title_suffix.replace(" ", "_").replace("—", "").replace("⚠", "").strip("_")
    plt.suptitle(
        f"California Algorithm — Parameter Grid  ({title_suffix})",
        fontsize=10,
    )
    plt.tight_layout()
    fname = f"california_heatmap_{tag}.png" if tag else "california_heatmap.png"
    path = OUTPUT_DIR / fname
    plt.savefig(path, dpi=150)
    plt.close()
    print(f"  💾 California heatmap → {path.name}")


