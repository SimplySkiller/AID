def _determine_mode(h5_name: str) -> str:
    """
    Return 'calibration' if the input is val.h5, else 'evaluation'.

    calibration : sweep w and threshold on the data, save fusion_settings.json
    evaluation  : load fusion_settings.json, apply locked params, no sweep
    """
    return "calibration" if h5_name == "val.h5" else "evaluation"


def run_fusion_evaluation_locked(
    joint_df: pd.DataFrame,
    settings: dict,
) -> List[dict]:
    """
    Apply fusion strategies using parameters locked in fusion_settings.json.
    No sweeping — each strategy uses the threshold saved during calibration.

    AND and OR still use individual model thresholds (no free parameters).
    Weighted, Average, and Max use their saved thresholds from calibration.
    """
    print("\n" + "="*60)
    print("  FUSION EVALUATION  (locked parameters from calibration)")
    print(f"  w_rf={settings['w_rf']:.2f}  "
          f"thresholds: avg={settings['thresholds']['avg_prob']:.2f}  "
          f"weighted={settings['thresholds']['w_prob']:.2f}  "
          f"max={settings['thresholds']['max_prob']:.2f}")
    print("="*60)

    results = []

    # Pre-compute fused probability columns
    w = settings["w_rf"]
    joint_df = joint_df.copy()
    joint_df["avg_prob"] = (joint_df["rf_max_prob"] + joint_df["cnn_max_prob"]) / 2
    joint_df["w_prob"]   = w * joint_df["rf_max_prob"] + (1-w) * joint_df["cnn_max_prob"]
    joint_df["max_prob"] = joint_df[["rf_max_prob", "cnn_max_prob"]].max(axis=1)

    # AND / OR — no threshold to lock
    for tag, col in [("AND", "and_detected"), ("OR", "or_detected")]:
        if tag == "AND":
            joint_df[col] = (
                (joint_df["rf_detected"] == 1) & (joint_df["cnn_detected"] == 1)
            ).astype(int)
        else:
            joint_df[col] = (
                (joint_df["rf_detected"] == 1) | (joint_df["cnn_detected"] == 1)
            ).astype(int)
        m = _scenario_metrics(joint_df, col)
        m["model"] = tag
        m["threshold"] = "individual model thresholds"
        results.append(m)
        print(f"\n  {tag:<5}: DR={m['dr']:.2%}  FAR={m['far']:.2%}  F1={m['f1']:.4f}")

    # Average prob, Weighted, Max — use locked thresholds
    for tag, prob_col, thr_key, extra in [
        ("Average prob",              "avg_prob", "avg_prob", {}),
        (f"Weighted(w_rf={w:.2f})",   "w_prob",   "w_prob",  {"weight_rf": w}),
        ("Max prob",                  "max_prob",  "max_prob", {}),
    ]:
        thr = settings["thresholds"][thr_key]
        joint_df[f"{prob_col}_det"] = (joint_df[prob_col] >= thr).astype(int)
        m = _scenario_metrics(joint_df, f"{prob_col}_det")
        m["model"]     = tag
        m["threshold"] = thr
        m.update(extra)
        results.append(m)
        print(f"  {tag[:22]:<22}: DR={m['dr']:.2%}  FAR={m['far']:.2%}  "
              f"F1={m['f1']:.4f}  (thr={thr:.2f}  locked)")

    return results, joint_df


