class CarlaManager:
    """
    Manages the CARLA process, world, camera, and mirrored vehicle actors.
    Identical to Map 1 except _sumo_to_carla uses COORD_OFFSET_X = -1000.
    """

    def __init__(self) -> None:
        self._process:     Optional[subprocess.Popen] = None
        self._client       = None
        self._world        = None
        self._camera       = None
        self._bp_lib       = None
        self._image_queue: queue.Queue = queue.Queue()
        self._actor_pool:  Dict[str, object] = {}
        self._carla        = None

    def start(self) -> None:
        import carla as _carla
        self._carla = _carla

        self._client = _carla.Client(CARLA_HOST, CARLA_PORT)
        self._client.set_timeout(5.0)
        already_running = False
        try:
            self._client.get_server_version()
            already_running = True
        except Exception:
            pass

        if already_running:
            pass
        else:
            if USE_PACKAGED_BUILD:
                if not os.path.exists(CARLA_PACKAGED_EXE):
                    raise FileNotFoundError(
                        f"Packaged CARLA not found:\n  {CARLA_PACKAGED_EXE}\n"
                        "Update CARLA_PACKAGED_EXE at the top of this file."
                    )
                launch_cmd = [
                    CARLA_PACKAGED_EXE,
                    "-RenderOffScreen",
                    f"-carla-port={CARLA_PORT}",
                    "-quality-level=Low",
                    "-benchmark",
                    "-fps=2",
                ]
                print("[CARLA] Launching packaged CarlaUE4.exe headless ...")
            else:
                if not os.path.exists(UE4_EDITOR_EXE):
                    raise FileNotFoundError(
                        f"UE4Editor not found:\n  {UE4_EDITOR_EXE}\n"
                        "Update UE4_EDITOR_EXE at the top of this file."
                    )
                if not os.path.exists(CARLA_UPROJECT):
                    raise FileNotFoundError(
                        f"CarlaUE4.uproject not found:\n  {CARLA_UPROJECT}\n"
                        "Update CARLA_UPROJECT at the top of this file."
                    )
                launch_cmd = [
                    UE4_EDITOR_EXE, CARLA_UPROJECT,
                    "-RenderOffScreen", "-nullrhi",
                    f"-carla-port={CARLA_PORT}",
                    "-quality-level=Low",
                    "-nosplash", "-noSound", "-unattended", "-nopause",
                ]
                print("[CARLA] Launching source-build via UE4Editor ...")

            self._process = subprocess.Popen(
                launch_cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

            self._client.set_timeout(5.0)
            print(f"[CARLA] Waiting for server (up to {CARLA_BOOT_TIMEOUT}s) ...")
            deadline  = time.time() + CARLA_BOOT_TIMEOUT
            connected = False
            while time.time() < deadline:
                try:
                    self._client.get_server_version()
                    connected = True
                    break
                except Exception:
                    time.sleep(3.0)

            if not connected:
                self._process.kill()
                raise RuntimeError(
                    f"CARLA did not respond within {CARLA_BOOT_TIMEOUT}s.\n"
                    "Try launching CarlaUE4.exe manually first, then re-run the script.\n"
                    f"Expected exe: {CARLA_PACKAGED_EXE if USE_PACKAGED_BUILD else UE4_EDITOR_EXE}"
                )

        self._client.set_timeout(30.0)
        ver = self._client.get_server_version()
        if not getattr(CarlaManager, "_server_logged", False):
            print(f"[CARLA] Server v{ver} on port {CARLA_PORT}.")
            CarlaManager._server_logged = True
        self._load_map()
        self._set_synchronous(True)
        self._spawn_camera()

    def warmup(self) -> None:
        print(f"[CARLA] Warming up ({CARLA_WARMUP_TICKS} ticks) ...", end="", flush=True)
        for _ in range(CARLA_WARMUP_TICKS):
            self._world.tick()
            try:
                self._image_queue.get(timeout=5.0)
            except queue.Empty:
                pass
        print(" done.")

    def stop(self) -> None:
        print("[CARLA] Shutting down ...")
        self._teardown_camera()
        self._destroy_all_actors()
        if self._world is not None:
            try:
                self._set_synchronous(False)
            except Exception:
                pass
        if self._process is not None:
            try:
                self._process.terminate()
            except Exception:
                pass
            self._process = None

    def _load_map(self) -> None:
        # Source-build workflow: user presses Play in UE4 with the correct map
        # already open.  Just call get_world() — never call load_world().
        #
        # load_world() triggers CARLA to re-parse the OpenDRIVE XML which fails
        # on source builds and also overrides Unreal-baked lighting (road goes black).
        # Your test script did the same: client.get_world() directly, no load_world().
        self._world  = self._client.get_world()
        self._bp_lib = self._world.get_blueprint_library()

        # Log the active map name once so you can confirm the right map is loaded.
        try:
            active_map = self._world.get_map().name.split("/")[-1]
        except Exception:
            active_map = "(unknown)"
        if not getattr(CarlaManager, "_map_logged", False):
            print(f"[CARLA] Active map: '{active_map}'  "
                  f"(expected '{CARLA_MAP_NAME}').")
            if active_map.lower() != CARLA_MAP_NAME.lower() and active_map != "(unknown)":
                print(f"[CARLA] WARNING: map name mismatch.  "
                      f"Make sure you pressed Play with '{CARLA_MAP_NAME}' open in UE4.")
            CarlaManager._map_logged = True

        # Purge stale vehicle actors left over from a previous scenario.
        try:
            stale = list(self._world.get_actors().filter('vehicle.*'))
            if stale:
                for actor in stale:
                    try:
                        actor.destroy()
                    except Exception:
                        pass
                print(f"[CARLA] Purged {len(stale)} stale vehicle actor(s) from world.")
        except Exception:
            pass

    def _set_synchronous(self, enabled: bool) -> None:
        settings = self._world.get_settings()
        settings.synchronous_mode    = enabled
        settings.fixed_delta_seconds = cfg.sim_step_length if enabled else 0.0
        self._world.apply_settings(settings)

    def _spawn_camera(self) -> None:
        bp = self._bp_lib.find("sensor.camera.rgb")
        bp.set_attribute("image_size_x",               str(CAM_IMAGE_X))
        bp.set_attribute("image_size_y",               str(CAM_IMAGE_Y))
        bp.set_attribute("fov",                        str(CAM_FOV))
        bp.set_attribute("enable_postprocess_effects", "True")
        bp.set_attribute("exposure_mode",              CAM_EXPOSURE_MODE)
        bp.set_attribute("exposure_compensation",      str(CAM_EXPOSURE_COMP))
        bp.set_attribute("iso",                        str(CAM_ISO))
        bp.set_attribute("gamma",                      str(CAM_GAMMA))
        bp.set_attribute("shutter_speed",              str(CAM_SHUTTER))

        transform = self._carla.Transform(
            self._carla.Location(**CAM_LOCATION),
            self._carla.Rotation(**CAM_ROTATION),
        )
        self._camera = self._world.spawn_actor(bp, transform)
        self._camera.listen(self._image_queue.put)
        if not getattr(self, "_camera_spawn_logged", False):
            cx, cy, cz = CAM_LOCATION["x"], CAM_LOCATION["y"], CAM_LOCATION["z"]
            print(f"[CARLA] Camera at x={cx}, y={cy}, z={cz}  (logged once).")
            self._camera_spawn_logged = True

    def _teardown_camera(self) -> None:
        if self._camera is not None:
            try:
                self._camera.stop()
                self._camera.destroy()
            except Exception:
                pass
            self._camera = None

    def sync_vehicles(
        self,
        vehicle_states: Dict[str, Tuple[float, float, float]],
    ) -> None:
        current_ids = set(vehicle_states)
        pool_ids    = set(self._actor_pool)

        for vid in pool_ids - current_ids:
            try:
                self._actor_pool[vid].destroy()
            except Exception:
                pass
            del self._actor_pool[vid]

        for vid, (sx, sy, heading) in vehicle_states.items():
            cx, cy, cz = self._sumo_to_carla(sx, sy)
            yaw        = self._sumo_heading_to_carla(heading)
            transform  = self._carla.Transform(
                self._carla.Location(x=cx, y=cy, z=cz),
                self._carla.Rotation(yaw=yaw),
            )
            if vid in self._actor_pool:
                self._actor_pool[vid].set_transform(transform)
            else:
                bp = self._bp_lib.find(random.choice(VEHICLE_BLUEPRINTS))
                if bp.has_attribute("color"):
                    color_choices = bp.get_attribute("color").recommended_values
                    if color_choices:
                        bp.set_attribute("color", random.choice(color_choices))
                actor = self._world.try_spawn_actor(bp, transform)
                if actor is not None:
                    actor.set_simulate_physics(False)
                    self._actor_pool[vid] = actor

    def _destroy_all_actors(self) -> None:
        for actor in self._actor_pool.values():
            try:
                actor.destroy()
            except Exception:
                pass
        self._actor_pool.clear()

    def tick(self) -> None:
        self._world.tick()

    def capture_image(self, out_path) -> bool:
        try:
            image = self._image_queue.get(timeout=5.0)
        except queue.Empty:
            return False
        while not self._image_queue.empty():
            try:
                image = self._image_queue.get_nowait()
            except queue.Empty:
                break
        if out_path is not None:
            image.save_to_disk(str(out_path), self._carla.ColorConverter.Raw)
        return True

    @staticmethod
    def _sumo_to_carla(sx: float, sy: float) -> Tuple[float, float, float]:
        # Map 2: CARLA x = SUMO cartesian x − 1000  (COORD_OFFSET_X = -1000)
        cx = sx + COORD_OFFSET_X
        cy = -(sy + COORD_OFFSET_Y)
        return cx, cy, SPAWN_Z

    @staticmethod
    def _sumo_heading_to_carla(sumo_heading: float) -> float:
        # SUMO 0 deg = North CW.  CARLA yaw 0 deg = East CCW.
        return -(sumo_heading - 90.0)


