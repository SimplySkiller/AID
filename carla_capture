class AIDScenarioRunner:
    """
    Runs one scenario (NI or incident) with SUMO + optional CARLA capture.
    Identical to Map 1 except:
    - run() accepts onramp_flow parameter
    - edge_starts dict includes all map-2 merge edges
    - cam_sumo_x uses CAM_SUMO_X constant (not CAM_LOCATION["x"])
    """

    def __init__(self, dry_run: bool = False) -> None:
        self.dry_run       = dry_run
        self.sumo          = SUMOSimulator(gui_mode=False)
        self.all_macro_rows: list = []
        self.discarded_scenarios: list = []
        self.warn_scenarios: list = []

    def run(
        self,
        scenario_id:       int,
        flow_total:        int,
        onramp_flow:       int,
        speed_factor_mean: float,
        incident_position: Optional[float],
    ) -> List[dict]:
        """
        Run one scenario.
        - incident_position=None: SUMO only, macro data logged, no camera.
        - incident_position=float: SUMO + two-window CARLA capture.
        Returns per-frame metadata rows (empty for no-incident scenarios).
        """
        has_incident = incident_position is not None

        random.seed(cfg.random_state + scenario_id)

        if not has_incident:
            # ── Non-incident scenario ─────────────────────────────────────────
            scen_label = f"s{scenario_id:05d}"
            print(f"[{scen_label}] flow={flow_total} veh/h  ramp={onramp_flow} veh/h  "
                  f"sf={speed_factor_mean:.2f}  NO INCIDENT")
            route_file = cfg.base_dir / f"routes_temp_{scenario_id}.rou.xml"
            self.sumo.generate_route_file(flow_total, onramp_flow, speed_factor_mean, route_file)
            _fix_depart_lanes(route_file)
            self.sumo.start_simulation(route_file, scenario_id)
            self.sumo.logging_active           = False
            self.sumo.first_vehicle_completed  = False
            self.sumo.baseline_speeds          = {}
            self.sumo.baseline_occupancies     = {}
            self.sumo.log_data                 = []
            last_detector_log_time = -999.0
            last_capture_time      = -999.0
            completed_vehicles:    set = set()
            all_spawned_vehicles:  set = set()
            steady_state_achieved_time = None

            NI_CAP_START = 200.0
            cap_start_t  = NI_CAP_START
            cap_end_t    = NI_CAP_START + NI_CAPTURE_DURATION
            ni_carla     = None
            ni_frame_id  = 0
            ni_metadata: List[dict] = []
            img_dir_ni   = DATASET_DIR / scen_label / "images"

            try:
                while True:
                    traci.simulationStep()
                    self.sumo.current_step += 1
                    t = traci.simulation.getTime()
                    if t > cfg.max_simulation_time:
                        break
                    current_vehicles = set(traci.vehicle.getIDList())
                    all_spawned_vehicles.update(current_vehicles)
                    newly = all_spawned_vehicles - current_vehicles - completed_vehicles
                    completed_vehicles.update(newly)
                    if not self.sumo.first_vehicle_completed and completed_vehicles:
                        self.sumo.first_vehicle_completed = True
                        steady_state_achieved_time = t + cfg.steady_state_buffer_time
                    if (not self.sumo.logging_active
                            and self.sumo.first_vehicle_completed
                            and steady_state_achieved_time is not None
                            and t >= steady_state_achieved_time):
                        self.sumo.logging_active = True
                    if self.sumo.logging_active and t - last_detector_log_time >= cfg.log_frequency:
                        data_point = self.sumo.collect_detector_data(update_baseline=True)
                        data_point['scenario_id']      = scen_label
                        data_point['flow_total']        = flow_total
                        data_point['speed_factor_mean'] = speed_factor_mean
                        data_point['has_incident']      = 0
                        data_point['incident_position'] = 0
                        data_point['incident_active']   = 0
                        self.sumo.log_data.append(data_point)
                        last_detector_log_time = t
                    if self.sumo.logging_active and steady_state_achieved_time is not None:
                        if t - steady_state_achieved_time >= 1650:
                            print(f"\n  [SIM] t={t:.0f}s - 1650s logged, no-incident complete.")
                            break
                    ni_frames_done = len(ni_metadata)
                    in_cap = (t >= cap_start_t and ni_frames_done < FRAMES_NI)
                    if not self.dry_run and in_cap:
                        if ni_carla is None:
                            img_dir_ni.mkdir(parents=True, exist_ok=True)
                            ni_carla = CarlaManager()
                            ni_carla.start()
                            ni_carla.warmup()
                        if t - last_capture_time >= CAPTURE_INTERVAL:
                            vehicle_states = {}
                            for vid in current_vehicles:
                                vx, vy = traci.vehicle.getPosition(vid)
                                dist_ahead = CAM_SUMO_X - vx
                                if 0 <= dist_ahead <= VEHICLE_SYNC_RADIUS:
                                    vehicle_states[vid] = (vx, vy, traci.vehicle.getAngle(vid))
                            ni_carla.sync_vehicles(vehicle_states)
                            ni_carla.tick()
                            fname = f"frame_{ni_frame_id:06d}.png"
                            saved = ni_carla.capture_image(img_dir_ni / fname)
                            if saved:
                                last_capture_time = t
                                ni_metadata.append({
                                    "scenario_id":         scen_label,
                                    "sim_time":            round(t, 2),
                                    "frame_id":            ni_frame_id,
                                    "filename":            fname,
                                    "incident_label":      0,
                                    "capture_window":      "NI",
                                    "mainline_flow":       flow_total,
                                    "onramp_flow":         onramp_flow,
                                    "speed_factor":        speed_factor_mean,
                                    "incident_position":   0,
                                    "incident_lane":       0,
                                    "incident_start_time": 0,
                                    "incident_clear_time": 0,
                                })
                                ni_frame_id += 1
                    if self.sumo.logging_active and int(t) % 60 == 0 and t != last_detector_log_time:
                        rows = len(self.sumo.log_data)
                        phase = f"CAP({ni_frames_done}/{FRAMES_NI})" if in_cap else "LOG"
                        print(f"  [no-incident] t={t:.0f}s  {phase}  rows={rows}  vehicles={len(current_vehicles)}", end="\r")
            except Exception as exc:
                print(f"[SIM] Error in no-incident run: {exc}")
            finally:
                if ni_carla is not None:
                    try:
                        ni_carla._teardown_camera()
                        ni_carla._destroy_all_actors()
                        ni_carla._set_synchronous(False)
                    except Exception:
                        pass
                try:
                    traci.close()
                    time.sleep(0.5)
                except Exception:
                    pass
                for _ in range(3):
                    try:
                        if route_file.exists():
                            route_file.unlink()
                        break
                    except PermissionError:
                        time.sleep(0.5)
            if self.sumo.log_data:
                self.all_macro_rows.extend(self.sumo.log_data)
                self.sumo.log_data = []
            if ni_metadata:
                if len(ni_metadata) < FRAMES_NI:
                    warn = f"only {len(ni_metadata)}/{FRAMES_NI} label=0 frames captured"
                    self.warn_scenarios.append((scen_label, warn))
                    print(f"  [WARN] {scen_label}: {warn}")
                scen_csv_ni = DATASET_DIR / scen_label / "metadata.csv"
                _write_csv(scen_csv_ni, ni_metadata)
                print(f"[OUT] {scen_label}: {len(ni_metadata)} frames (label=0, no-incident).")
                return ni_metadata
            else:
                if not self.dry_run:
                    warn = "0 label=0 frames captured - capture window may have been before steady state"
                    self.warn_scenarios.append((scen_label, warn))
                    print(f"  [WARN] {scen_label}: {warn}")
                print(f"[OUT] {scen_label}: macro only (dry-run or capture window missed).")
                return []

        # ── Incident scenario ─────────────────────────────────────────────────
        t_lo = max(200.0, min(cfg.incident_start_time_min, cfg.incident_start_time_max))
        t_hi = max(200.0, max(cfg.incident_start_time_min, cfg.incident_start_time_max))
        incident_start      = random.uniform(t_lo, t_hi) if t_hi > t_lo else float(t_lo)
        incident_lane       = random.choice(cfg.incident_lane_distribution)
        incident_position   = random.uniform(CAM_STOP_MIN, CAM_STOP_MAX)
        recovery_duration   = random.uniform(900, 1800)
        incident_clear_time = incident_start + 300 + recovery_duration

        win_b_start = None
        win_b_end   = None
        sim_end     = incident_clear_time

        has_camera  = not self.dry_run

        scen_label = f"s{scenario_id:05d}"
        img_dir    = DATASET_DIR / scen_label / "images"
        img_dir.mkdir(parents=True, exist_ok=True)

        scen_csv = DATASET_DIR / scen_label / "metadata.csv"
        if not scen_csv.exists():
            orphans = list(img_dir.glob("frame_*.png"))
            if orphans:
                print(f"  [CLEANUP] {scen_label}: removing {len(orphans)} orphaned PNGs "
                      f"from a previous failed run ...")
                for png in orphans:
                    try:
                        png.unlink()
                    except Exception:
                        pass

        if scen_csv.exists():
            import csv as _csv
            with open(scen_csv, newline="", encoding="utf-8") as fh:
                existing_count = sum(1 for _ in _csv.DictReader(fh))
            if existing_count > 0:
                print(f"[SKIP] {scen_label} already has {existing_count} frames - skipping.")
                return []

        print(f"\n{'─'*60}")
        print(f"[{scen_label}] flow={flow_total} veh/h  ramp={onramp_flow} veh/h  "
              f"sf={speed_factor_mean:.2f}  stop@x={incident_position:.0f}m  lane={incident_lane}")
        print(f"  Inject: t>={incident_start:.1f}s  searches [{incident_position - STOP_SEARCH_UPSTREAM:.0f}-{incident_position:.0f}]m upstream")
        print(f"  Capture: A={FRAMES_PRE} frames label=0 (pre)  +  B={FRAMES_INCIDENT} frames label=1 (jam)")
        print(f"{'─'*60}")

        route_file = cfg.base_dir / f"routes_temp_{scenario_id}.rou.xml"
        self.sumo.generate_route_file(flow_total, onramp_flow, speed_factor_mean, route_file)
        _fix_depart_lanes(route_file)

        incident_lane_sumo = incident_lane

        self.sumo.start_simulation(route_file, scenario_id)
        self.sumo.logging_active          = False
        self.sumo.first_vehicle_completed = False
        self.sumo.baseline_speeds         = {}
        self.sumo.baseline_occupancies    = {}
        self.sumo.log_data                = []

        metadata_rows:            List[dict]  = []
        frame_id                  = 0
        last_capture_time         = -999.0
        last_detector_log_time    = -999.0
        last_print_time           = -999.0
        incident_injected         = False
        incident_vehicle          = None
        incident_injection_attempts = 0
        injection_failed          = False
        actual_inject_time        = None
        actual_stop_time          = None
        _eff_min_brake            = MIN_BRAKE_DIST
        completed_vehicles:       set = set()
        all_spawned_vehicles:     set = set()
        steady_state_achieved_time: Optional[float] = None
        carla: Optional[CarlaManager] = None
        carla_start_t = max(0.0, incident_start - PRE_INCIDENT_WINDOW)

        try:
            while True:
                traci.simulationStep()
                self.sumo.current_step += 1
                t = traci.simulation.getTime()

                if t > cfg.max_simulation_time:
                    print(f"\n[SIM] Hard timeout at t={t:.1f}s")
                    break

                if t >= sim_end:
                    print(f"\n[SIM] t={t:.1f}s - incident cleared, stopping.")
                    break

                current_vehicles = set(traci.vehicle.getIDList())
                all_spawned_vehicles.update(current_vehicles)
                newly_completed  = all_spawned_vehicles - current_vehicles - completed_vehicles
                completed_vehicles.update(newly_completed)

                if not self.sumo.first_vehicle_completed and completed_vehicles:
                    self.sumo.first_vehicle_completed  = True
                    steady_state_achieved_time         = t + cfg.steady_state_buffer_time

                if (not self.sumo.logging_active
                        and self.sumo.first_vehicle_completed
                        and steady_state_achieved_time is not None
                        and t >= steady_state_achieved_time):
                    self.sumo.logging_active = True

                # ── Incident injection ────────────────────────────────────────
                if (not incident_injected
                        and self.sumo.logging_active
                        and t >= incident_start):
                    stop_x = incident_position
                    if stop_x < STOP_DET3_START:
                        effective_stop_edge = "before_det3"
                        stop_lane_pos = stop_x - STOP_BEFORE_DET3_START
                    else:
                        effective_stop_edge = "det3"
                        stop_lane_pos = stop_x - STOP_DET3_START
                    search_min_x = stop_x - STOP_SEARCH_UPSTREAM

                    # Edge starts in SUMO cartesian x — Map 2 includes all merge edges.
                    # 700m upstream from x≈2420 reaches back to x≈1720, spanning
                    # before_det2c through before_det3.
                    edge_starts = {
                        "before_det1":   0.0,
                        "det1":          1200.0,
                        "before_det2a":  1300.0,
                        "before_det2b":  1352.1,
                        "before_det2ba": 1743.7,
                        "before_det2bb": 1745.4,
                        "before_det2c":  1754.0,
                        "det2":          1800.0,
                        "before_det3":   1900.0,
                        "det3":          2400.0,
                        "after_det3":    2500.0,
                    }
                    candidates = []
                    for vid in current_vehicles:
                        try:
                            edge     = traci.vehicle.getRoadID(vid)
                            lane_idx = traci.vehicle.getLaneIndex(vid)
                            if lane_idx != incident_lane_sumo:
                                continue
                            if edge not in edge_starts:
                                continue
                            lane_pos     = traci.vehicle.getLanePosition(vid)
                            abs_x        = edge_starts[edge] + lane_pos
                            dist_to_stop = stop_x - abs_x
                            if _eff_min_brake <= dist_to_stop <= STOP_SEARCH_UPSTREAM:
                                candidates.append((vid, abs_x, dist_to_stop))
                        except Exception:
                            continue

                    if candidates:
                        candidates.sort(key=lambda c: c[2], reverse=True)
                        injected_ok = False
                        for chosen_vid, chosen_x, chosen_dist in candidates:
                            try:
                                INCIDENT_DECEL           = 14.0
                                INCIDENT_EMERGENCY_DECEL = 15.0
                                traci.vehicle.setDecel(chosen_vid, INCIDENT_DECEL)
                                traci.vehicle.setEmergencyDecel(chosen_vid, INCIDENT_EMERGENCY_DECEL)
                                traci.vehicle.setStop(
                                    chosen_vid, effective_stop_edge,
                                    pos=float(stop_lane_pos),
                                    laneIndex=incident_lane_sumo,
                                    duration=float(recovery_duration),
                                )
                                traci.vehicle.setLaneChangeMode(chosen_vid, 0)
                                traci.vehicle.setColor(chosen_vid, (255, 0, 0, 255))
                                incident_vehicle    = chosen_vid
                                incident_injected   = True
                                actual_inject_time  = t
                                win_b_start         = t + JAM_CAPTURE_OFFSET
                                win_b_end           = win_b_start + JAM_CAPTURE_DURATION
                                incident_clear_time = t + 300 + recovery_duration
                                sim_end             = incident_clear_time
                                injected_ok         = True
                                print(f"  [INJ] t={t:.1f}s  vehicle={chosen_vid}  "
                                      f"now@x={chosen_x:.0f}  ({chosen_dist:.0f}m to stop)  "
                                      f"edge={effective_stop_edge}  lane_pos={stop_lane_pos:.0f}  "
                                      f"stop@x={stop_x:.0f}")
                                break
                            except Exception:
                                continue
                        if not injected_ok:
                            incident_injection_attempts += 1
                    else:
                        incident_injection_attempts += 1

                    if not incident_injected:
                        if incident_injection_attempts % 200 == 0:
                            print(f"  [WAIT] t={t:.0f}s  no suitable vehicle "
                                  f"[{_eff_min_brake:.0f}-{STOP_SEARCH_UPSTREAM:.0f}]m "
                                  f"upstream of x={stop_x:.0f}m "
                                  f"(attempts={incident_injection_attempts})...", end="\r")
                        if t > incident_start + 300 and _eff_min_brake > 50.0:
                            _eff_min_brake = 50.0
                            print(f"\n  [RELAX] t={t:.0f}s — 300s elapsed, "
                                  f"relaxing min brake distance to {_eff_min_brake:.0f}m")

                # ── Track actual stop ─────────────────────────────────────────
                if incident_injected and actual_stop_time is None and incident_vehicle:
                    try:
                        spd = traci.vehicle.getSpeed(incident_vehicle)
                        if spd < 1.0:
                            actual_stop_time    = t
                            incident_clear_time = actual_stop_time + recovery_duration
                            sim_end             = incident_clear_time
                            print(f"  [STOP] t={t:.1f}s  fully stopped  (speed={spd:.2f} m/s)  "
                                  f"clear@t={incident_clear_time:.0f}s")
                    except Exception:
                        pass

                # ── CARLA capture ─────────────────────────────────────────────
                if has_camera and carla is None and t >= carla_start_t:
                    carla = CarlaManager()
                    carla.start()
                    carla.warmup()

                if has_camera and carla is not None and t - last_capture_time >= CAPTURE_INTERVAL:
                    vehicle_states = {}
                    for vid in current_vehicles:
                        vx, vy = traci.vehicle.getPosition(vid)
                        dist_ahead = CAM_SUMO_X - vx
                        if 0 <= dist_ahead <= VEHICLE_SYNC_RADIUS:
                            vehicle_states[vid] = (vx, vy, traci.vehicle.getAngle(vid))
                    carla.sync_vehicles(vehicle_states)
                    carla.tick()

                    label  = 1 if (actual_stop_time is not None) else 0
                    window = "B" if label == 1 else "A"
                    fname  = f"frame_{frame_id:06d}.png"
                    saved  = carla.capture_image(img_dir / fname)
                    if saved:
                        last_capture_time = t
                        metadata_rows.append({
                            "scenario_id":         scen_label,
                            "sim_time":            round(t, 2),
                            "frame_id":            frame_id,
                            "filename":            fname,
                            "incident_label":      label,
                            "capture_window":      window,
                            "mainline_flow":       flow_total,
                            "onramp_flow":         onramp_flow,
                            "speed_factor":        speed_factor_mean,
                            "incident_position":   round(incident_position, 1),
                            "incident_lane":       incident_lane,
                            "incident_start_time": round(actual_inject_time if actual_inject_time else incident_start, 2),
                            "incident_clear_time": round(incident_clear_time, 2),
                        })
                        frame_id += 1

                    if actual_stop_time is not None:
                        n_b = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
                        if n_b >= FRAMES_INCIDENT:
                            break

                # Progress print every 30s
                if int(t) % 30 == 0 and t - last_print_time >= 29.0:
                    if not incident_injected and t >= carla_start_t:
                        in_win = "WIN-A"
                    elif actual_stop_time and actual_stop_time <= t < actual_stop_time + JAM_CAPTURE_DURATION:
                        in_win = "WIN-B"
                    else:
                        in_win = "---"
                    phase = ("INCIDENT" if incident_injected
                             else "WAIT-ZONE" if self.sumo.logging_active and t >= incident_start
                             else "WARMUP" if not self.sumo.logging_active
                             else "PRE-INC")
                    fa = sum(1 for r in metadata_rows if r.get("capture_window") == "A")
                    fb = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
                    print(f"  t={t:.0f}s  {phase}  {in_win}  vehicles={len(current_vehicles)}  A={fa}/{FRAMES_PRE}  B={fb}/{FRAMES_INCIDENT}", end="\r")
                    last_print_time = t

                # ── Detector logging ──────────────────────────────────────────
                if self.sumo.logging_active and t - last_detector_log_time >= cfg.log_frequency:
                    update_baseline = not incident_injected
                    data_point = self.sumo.collect_detector_data(update_baseline=update_baseline)
                    data_point['scenario_id']       = scen_label
                    data_point['flow_total']         = flow_total
                    data_point['speed_factor_mean']  = speed_factor_mean
                    data_point['has_incident']       = 1
                    data_point['incident_position']  = incident_position
                    data_point['incident_active']    = 1 if incident_injected else 0
                    self.sumo.log_data.append(data_point)
                    last_detector_log_time = t

                elif self.dry_run and t - last_print_time >= 10.0:
                    if t >= carla_start_t:
                        status = "INCIDENT" if incident_injected else "PRE-INCIDENT"
                    else:
                        status = "FAST-FORWARD"
                    print(f"  [dry-run] t={t:.1f}s  {status}  "
                          f"vehicles={len(current_vehicles)}",
                          end="\r")
                    last_print_time = t

        except KeyboardInterrupt:
            print("\n[SIM] Interrupted.")
        except Exception as exc:
            print(f"\n[SIM] Error: {exc}")
            import traceback
            traceback.print_exc()
        finally:
            if carla is not None:
                carla._destroy_all_actors()
                carla._teardown_camera()
                while not carla._image_queue.empty():
                    try:
                        carla._image_queue.get_nowait()
                    except Exception:
                        break
                try:
                    carla._set_synchronous(False)
                except Exception:
                    pass
                carla = None
            import gc
            gc.collect()
            try:
                traci.close()
                time.sleep(0.5)
            except Exception:
                pass
            for _ in range(3):
                try:
                    if route_file.exists():
                        route_file.unlink()
                    break
                except PermissionError:
                    time.sleep(0.5)

        if not incident_injected and not injection_failed:
            injection_failed = True
            reason_disc = (f"sim ended at t≈{sim_end:.0f}s without finding a vehicle "
                           f">={_eff_min_brake:.0f}m upstream of x={incident_position:.0f}m "
                           f"(flow={flow_total} veh/h is very sparse)")
            self.discarded_scenarios.append((scen_label, reason_disc))
            print(f"\n[DISCARD] {scen_label}: {reason_disc}.")

        if injection_failed:
            self.sumo.log_data = []
            print(f"[DISCARD] {scen_label}: cleaning up {frame_id} orphaned images ...")
            deleted = 0
            for png in img_dir.glob("frame_*.png"):
                try:
                    png.unlink()
                    deleted += 1
                except Exception:
                    pass
            if deleted:
                print(f"  Deleted {deleted} orphaned PNG files from {img_dir.name}/images/")
            return []

        if self.sumo.log_data:
            self.all_macro_rows.extend(self.sumo.log_data)
            print(f"[OUT] {scen_label}: {len(self.sumo.log_data)} macro rows accumulated.")
            self.sumo.log_data = []

        if metadata_rows:
            metadata_rows = self._trim_incident_frames(scen_label, metadata_rows, img_dir)
            n_pre      = sum(1 for r in metadata_rows if r.get("capture_window") == "A")
            n_incident = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
            if n_pre < FRAMES_PRE:
                warn = f"only {n_pre}/{FRAMES_PRE} label=0 pre-incident frames captured"
                self.warn_scenarios.append((scen_label, warn))
                print(f"  [WARN] {scen_label}: {warn}")
            if n_incident < FRAMES_INCIDENT:
                warn = f"only {n_incident}/{FRAMES_INCIDENT} label=1 frames captured"
                self.warn_scenarios.append((scen_label, warn))
                print(f"  [WARN] {scen_label}: {warn}")
            scen_csv = DATASET_DIR / scen_label / "metadata.csv"
            _write_csv(scen_csv, metadata_rows)
            print(f"[OUT] {scen_label}: {len(metadata_rows)} frames  "
                  f"(A={n_pre} label=0 / B={n_incident} label=1).")
        else:
            warn = "0 frames captured - possible CARLA error"
            self.warn_scenarios.append((scen_label, warn))
            print(f"  [WARN] {scen_label}: {warn}")

        return metadata_rows

    @staticmethod
    def _trim_incident_frames(
        scen_label: str,
        rows: List[dict],
        img_dir: Path,
    ) -> List[dict]:
        a_rows = [r for r in rows if r.get("capture_window") == "A"]
        b_rows = [r for r in rows if r.get("capture_window") == "B"]
        a_rows.sort(key=lambda r: r["frame_id"])
        b_rows.sort(key=lambda r: r["frame_id"])

        if len(a_rows) > FRAMES_PRE:
            drop_a = a_rows[: len(a_rows) - FRAMES_PRE]
            keep_a = a_rows[len(a_rows) - FRAMES_PRE :]
            for r in drop_a:
                p = img_dir / r["filename"]
                try:
                    p.unlink(missing_ok=True)
                except Exception:
                    pass
            n_trimmed_a = len(drop_a)
        else:
            keep_a = a_rows
            n_trimmed_a = 0

        if len(b_rows) > FRAMES_INCIDENT:
            keep_b = b_rows[:FRAMES_INCIDENT]
            drop_b = b_rows[FRAMES_INCIDENT:]
            for r in drop_b:
                p = img_dir / r["filename"]
                try:
                    p.unlink(missing_ok=True)
                except Exception:
                    pass
        else:
            keep_b = b_rows

        kept = keep_a + keep_b
        if n_trimmed_a:
            print(f"  [TRIM] {scen_label}: discarded {n_trimmed_a} earliest label=0 frames "
                  f"({len(kept)} remain)")

        for new_id, r in enumerate(kept):
            old_fname = r["filename"]
            new_fname = f"frame_{new_id:06d}.png"
            if old_fname != new_fname:
                old_path = img_dir / old_fname
                new_path = img_dir / new_fname
                try:
                    old_path.rename(new_path)
                except Exception:
                    pass
            r["frame_id"] = new_id
            r["filename"] = new_fname

        return kept


