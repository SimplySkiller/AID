# ============================================================================
# Route file lane-index fix
# ============================================================================

def _fix_depart_lanes(route_file: Path) -> None:
    """
    Remap departLane indices in a generated route file to match the actual
    driving lanes in this highway network.

    Network lane layout (5 lanes per edge):
        0  shoulder  - no passenger vehicles allowed
        1  driving   - right / slow lane
        2  driving   - left  / fast lane
        3  shoulder
        4  shoulder

    generate_route_file() produces departLane="0" and departLane="1"
    based on config.lane0_preference / lane1_preference.
    Lane 0 is a shoulder -> SUMO rejects the vehicle at load time.

    Remap:  "0" -> "1"   (right driving lane)
            "1" -> "2"   (left  driving lane)
    """
    LANE_MAP = {"0": "1", "1": "2"}

    tree = ET.parse(str(route_file))
    root = tree.getroot()
    changed = 0
    for veh in root.iter("vehicle"):
        dl = veh.get("departLane")
        if dl in LANE_MAP:
            veh.set("departLane", LANE_MAP[dl])
            changed += 1
    tree.write(str(route_file), encoding="utf-8", xml_declaration=True)
    print(f"  [lane-fix] remapped departLane for {changed} vehicles (0->1, 1->2)")


