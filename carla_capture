MACRO_H5 = cfg.data_dir / "all_data.h5"

_MACRO_COLUMNS = [
    "scenario_id", "sim_time", "has_incident", "incident_active", "incident_position",
    "flow_total", "speed_factor_mean",
    "det1_speed_mean", "det1_speed_std", "det1_speed_min", "det1_flow", "det1_occupancy", "det1_vehicle_count",
    "det2_speed_mean", "det2_speed_std", "det2_speed_min", "det2_flow", "det2_occupancy", "det2_vehicle_count",
    "det3_speed_mean", "det3_speed_std", "det3_speed_min", "det3_flow", "det3_occupancy", "det3_vehicle_count",
]


def _write_csv(path: Path, rows: List[dict]) -> None:
    all_fields: list = []
    seen = set()
    for r in rows:
        for k in r.keys():
            if k not in seen and k is not None:
                all_fields.append(k)
                seen.add(k)
    with open(path, "w", newline="", encoding="utf-8") as fh:
        writer = csv.DictWriter(fh, fieldnames=all_fields, extrasaction="ignore")
        writer.writeheader()
        writer.writerows(rows)


MASTER_CSV = DATASET_DIR / "master_metadata.csv"


def _append_master_csv(rows: List[dict]) -> None:
    if not rows:
        return
    needs_header = not MASTER_CSV.exists()
    with open(MASTER_CSV, "a", newline="", encoding="utf-8") as fh:
        writer = csv.DictWriter(fh, fieldnames=list(rows[0].keys()))
        if needs_header:
            writer.writeheader()
        writer.writerows(rows)


# ============================================================================
# Train / val / test split
# ============================================================================

def write_split_csvs() -> None:
    if not MASTER_CSV.exists():
        print("[SPLIT] master_metadata.csv not found - run scenarios first.")
        return
    with open(MASTER_CSV, newline="", encoding="utf-8") as fh:
        rows = list(csv.DictReader(fh))
    if not rows:
        print("[SPLIT] master_metadata.csv is empty.")
        return
    scen_ids = sorted(set(r["scenario_id"] for r in rows))
    rng      = random.Random(cfg.random_state)
    rng.shuffle(scen_ids)
    n       = len(scen_ids)
    n_train = int(n * cfg.train_ratio)
    n_val   = int(n * cfg.val_ratio)
    train_ids = set(scen_ids[:n_train])
    val_ids   = set(scen_ids[n_train:n_train + n_val])
    test_ids  = set(scen_ids[n_train + n_val:])
    for split_name, id_set in [("train", train_ids), ("val", val_ids), ("test", test_ids)]:
        split_rows = [r for r in rows if r["scenario_id"] in id_set]
        out        = DATASET_DIR / f"{split_name}_metadata.csv"
        if split_rows:
            _write_csv(out, split_rows)
        n_scen = len(set(r["scenario_id"] for r in split_rows))
        print(f"[SPLIT] {split_name:5s}: {len(split_rows):6d} frames  "
              f"({n_scen} scenarios)  ->  {out}")


# ============================================================================
# Scenario enumeration  (Map 2 — includes onramp_flow dimension)
# ============================================================================

def enumerate_scenarios() -> List[dict]:
    """
    Return all scenarios for Map 2.

    Outer loops: mainline flow × onramp flow × speed factor × incident position.
    NI scenarios are listed first (same ordering convention as Map 1).
    """
    scenarios = []
    sid       = 0

    sf_values = [
        round(cfg.speed_factor_min + i * cfg.speed_factor_step, 2)
        for i in range(
            int(round((cfg.speed_factor_max - cfg.speed_factor_min)
                      / cfg.speed_factor_step)) + 1
        )
    ]

    # Non-incident scenarios
    for flow in range(cfg.flow_min, cfg.flow_max + 1, cfg.flow_step):
        for onramp in range(cfg.onramp_flow_min, cfg.onramp_flow_max + 1, cfg.onramp_flow_step):
            for sf in sf_values:
                for _ in cfg.incident_positions:
                    scenarios.append(dict(
                        scenario_id       = sid,
                        flow_total        = flow,
                        onramp_flow       = onramp,
                        speed_factor_mean = sf,
                        incident_position = None,
                    ))
                    sid += 1

    n_noincident = sid

    # Incident scenarios
    for flow in range(cfg.flow_min, cfg.flow_max + 1, cfg.flow_step):
        for onramp in range(cfg.onramp_flow_min, cfg.onramp_flow_max + 1, cfg.onramp_flow_step):
            for sf in sf_values:
                for inc_pos in cfg.incident_positions:
                    scenarios.append(dict(
                        scenario_id       = sid,
                        flow_total        = flow,
                        onramp_flow       = onramp,
                        speed_factor_mean = sf,
                        incident_position = float(inc_pos),
                    ))
                    sid += 1

    n_incident = sid - n_noincident
    print(f"[CONFIG] {len(scenarios)} scenarios: {n_noincident} NI + {n_incident} incident.")
    print(f"         mainline {cfg.flow_min}–{cfg.flow_max} veh/h  |  "
          f"onramp {cfg.onramp_flow_min}–{cfg.onramp_flow_max} veh/h  |  "
          f"sf {cfg.speed_factor_min}–{cfg.speed_factor_max}")
    return scenarios


# ============================================================================
# Entry point
# ============================================================================

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Merged SUMO + CARLA AID Dataset Generator — Map 2 (with on-ramp)."
    )
    parser.add_argument("--dry-run", action="store_true",
                        help="SUMO only, no CARLA.")
    parser.add_argument("--limit", type=int, default=None,
                        help="Stop after N scenarios.")
    parser.add_argument("--split-only", action="store_true",
                        help="Rebuild train/val/test split CSVs only.")
    parser.add_argument("--no-incident-only", action="store_true",
                        help="Run NI scenarios only (CARLA image capture still active).")
    args = parser.parse_args()

    wall_start = time.time()

    if args.split_only:
        write_split_csvs()
        elapsed = time.time() - wall_start
        print(f"\n[MAIN] Split rebuild done in {elapsed:.1f}s.")
        return

    scenarios = enumerate_scenarios()

    if args.no_incident_only:
        scenarios = [s for s in scenarios if s["incident_position"] is None]
        print(f"[MODE] --no-incident-only: {len(scenarios)} NI scenarios.")

    if args.limit:
        scenarios = scenarios[: args.limit]

    print(f"[MAIN] Running {len(scenarios)} scenario(s).  "
          f"dry_run={args.dry_run}  no_incident_only={args.no_incident_only}")
    if not args.dry_run:
        print()
        print("[CARLA] Start CARLA first:")
        print(f"  {CARLA_PACKAGED_EXE}"
              f" -quality-level=Low -benchmark -fps=2 -RenderOffScreen"
              f" -carla-port={CARLA_PORT}")
        print("  Wait ~30s for map load, then this script auto-connects.")
        print()

    effective_dry_run = args.dry_run
    runner = AIDScenarioRunner(dry_run=effective_dry_run)

    try:
        for i, sc in enumerate(scenarios, start=1):
            elapsed_so_far = time.time() - wall_start
            h, m = divmod(int(elapsed_so_far), 3600)
            m, s = divmod(m, 60)
            print(f"\n[MAIN] Scenario {i}/{len(scenarios)}  "
                  f"(elapsed {h:02d}:{m:02d}:{s:02d})")
            rows = runner.run(**sc)
            _append_master_csv(rows)
    except KeyboardInterrupt:
        print("\n[MAIN] Interrupted by user.")
    finally:
        if runner.discarded_scenarios or runner.warn_scenarios:
            print("\n" + "="*60)
            print("[SUMMARY] Issues during run:")
            if runner.discarded_scenarios:
                print(f"  DISCARDED ({len(runner.discarded_scenarios)} scenarios):")
                for sid, reason in runner.discarded_scenarios:
                    print(f"    {sid}: {reason}")
            if runner.warn_scenarios:
                print(f"  WARNINGS ({len(runner.warn_scenarios)} scenarios):")
                for sid, reason in runner.warn_scenarios:
                    print(f"    {sid}: {reason}")
            print("="*60)
        else:
            print("\n[SUMMARY] No discards or warnings.")
        try:
            traci.close()
        except Exception:
            pass
        import subprocess as _sp
        _sp.run(["taskkill", "/f", "/im", "CarlaUE4.exe"],
                stdout=_sp.DEVNULL, stderr=_sp.DEVNULL)
        print("[MAIN] Cleanup done.")

    # ── Save all macro data ───────────────────────────────────────────────────
    if runner.all_macro_rows:
        print(f"\n[MAIN] Saving macro data: {len(runner.all_macro_rows)} total rows ...")
        combined_df = pd.DataFrame(runner.all_macro_rows)
        combined_df = combined_df.drop(columns=["step"], errors="ignore")
        combined_df.to_hdf(MACRO_H5, key="data", mode="w", format="table",
                           data_columns=["scenario_id", "sim_time", "incident_active", "has_incident"])
        print(f"[MAIN] Macro data saved to {MACRO_H5.name}  ({len(combined_df):,} rows).")

        scenario_ids = combined_df["scenario_id"].unique()
        import numpy as _np
        rng = _np.random.default_rng(cfg.random_state)
        rng.shuffle(scenario_ids)
        n_train = int(len(scenario_ids) * cfg.train_ratio)
        n_val   = int(len(scenario_ids) * cfg.val_ratio)
        train_ids = scenario_ids[:n_train]
        val_ids   = scenario_ids[n_train:n_train+n_val]
        test_ids  = scenario_ids[n_train+n_val:]
        combined_df[combined_df["scenario_id"].isin(train_ids)].to_hdf(
            cfg.train_h5, key="data", mode="w", format="table")
        combined_df[combined_df["scenario_id"].isin(val_ids)].to_hdf(
            cfg.val_h5,   key="data", mode="w", format="table")
        combined_df[combined_df["scenario_id"].isin(test_ids)].to_hdf(
            cfg.test_h5,  key="data", mode="w", format="table")
        print(f"[MAIN] Macro split: train={len(train_ids)} val={len(val_ids)} test={len(test_ids)} scenarios.")

    # ── Integrity check ───────────────────────────────────────────────────────
    print("\n[CHECK] Running integrity checks...")
    issues = []
    if MACRO_H5.exists():
        try:
            df_check = pd.read_hdf(MACRO_H5, key="data")
            n_scenarios = df_check["scenario_id"].nunique()
            n_rows      = len(df_check)
            n_incident  = df_check["has_incident"].sum()
            n_no_inc    = (df_check["has_incident"] == 0).sum()
            print(f"  Macro HDF5:  {n_rows:,} rows  |  {n_scenarios} scenarios  "
                  f"|  {n_incident} incident rows  |  {n_no_inc} no-incident rows")
            if not args.no_incident_only and n_incident == 0:
                issues.append("No incident rows in macro data!")
            if n_no_inc == 0:
                issues.append("No non-incident rows in macro data!")
            missing_cols = [c for c in ["sim_time","det3_speed_mean","incident_active"] if c not in df_check.columns]
            if missing_cols:
                issues.append(f"Missing macro columns: {missing_cols}")
        except Exception as e:
            issues.append(f"Cannot read macro HDF5: {e}")
    else:
        issues.append("macro HDF5 (all_data.h5) not found!")
    if not args.no_incident_only:
        if MASTER_CSV.exists():
            import csv as _csv2
            with open(MASTER_CSV, newline="", encoding="utf-8") as fh:
                rows_img = list(_csv2.DictReader(fh))
            n_img  = len(rows_img)
            n_NI   = sum(1 for r in rows_img if r.get("capture_window") == "NI")
            n_A    = sum(1 for r in rows_img if r.get("capture_window") == "A")
            n_B    = sum(1 for r in rows_img if r.get("capture_window") == "B")
            n_scen = len({r["scenario_id"] for r in rows_img})
            total_label0 = n_NI + n_A
            print(f"  Image CSV:   {n_img} frames  |  {n_scen} scenarios  "
                  f"|  label=0: {total_label0} (NI={n_NI} + pre={n_A})  |  label=1: {n_B}")
            if abs(total_label0 - n_B) > n_scen * 2:
                issues.append(f"Class imbalance: {total_label0} label=0 vs {n_B} label=1")
        else:
            issues.append("master_metadata.csv not found - no images captured?")
    if issues:
        print("  [!] Issues found:")
        for iss in issues:
            print(f"      - {iss}")
    else:
        print("  [OK] All checks passed.")

    if not args.no_incident_only:
        print(f"\n[MAIN] Rebuilding train/val/test split CSVs ...")
        write_split_csvs()

    total_elapsed = time.time() - wall_start
    h, rem = divmod(int(total_elapsed), 3600)
    m, s   = divmod(rem, 60)
    print(f"\n[MAIN] All done.  Dataset root: {DATASET_DIR}")
    print(f"[MAIN] Total wall-clock time: {h:02d}h {m:02d}m {s:02d}s")


if __name__ == "__main__":
    main()

