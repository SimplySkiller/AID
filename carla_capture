# ============================================================================
# Route file lane-index fix
# ============================================================================

def _fix_depart_lanes(route_file: Path) -> None:
    """
    Remap departLane indices in a generated route file to match the actual
    driving lanes in this highway network.

    Network lane layout (5 lanes per edge):
        0  shoulder  - no passenger vehicles allowed
        1  driving   - right / slow lane
        2  driving   - left  / fast lane
        3  shoulder
        4  shoulder

    generate_route_file() produces departLane="0" and departLane="1"
    based on config.lane0_preference / lane1_preference.
    Lane 0 is a shoulder -> SUMO rejects the vehicle at load time.

    Remap:  "0" -> "1"   (right driving lane)
            "1" -> "2"   (left  driving lane)
    """
    LANE_MAP = {"0": "1", "1": "2"}

    tree = ET.parse(str(route_file))
    root = tree.getroot()
    changed = 0
    for veh in root.iter("vehicle"):
        dl = veh.get("departLane")
        if dl in LANE_MAP:
            veh.set("departLane", LANE_MAP[dl])
            changed += 1
    tree.write(str(route_file), encoding="utf-8", xml_declaration=True)
    print(f"  [lane-fix] remapped departLane for {changed} vehicles (0->1, 1->2)")


# ============================================================================
# CARLA Manager
# ============================================================================

class CarlaManager:
    """
    Manages the CARLA process, world, camera, and mirrored vehicle actors.

    Lifecycle
    ---------
    start()         - launches headless CarlaUE4.exe, loads OpenDRIVE map,
                      configures sync mode, spawns camera.
    warmup()        - ticks CARLA_WARMUP_TICKS times without saving, burning
                      through the asset-loading period so the first saved frame
                      has a fully rendered road and environment.
    tick()          - advances CARLA one synchronous step (every SUMO step
                      during the capture window).
    capture_image() - saves the latest rendered frame to disk.
    stop()          - destroys actors, restores async mode, kills process.

    Vehicle mirroring
    -----------------
    sync_vehicles() reconciles the actor pool with the current SUMO snapshot.
    Physics is disabled on all actors; positions are driven by SUMO.
    """

    def __init__(self) -> None:
        self._process:     Optional[subprocess.Popen] = None
        self._client       = None
        self._world        = None
        self._camera       = None
        self._bp_lib       = None
        self._image_queue: queue.Queue = queue.Queue()
        self._actor_pool:  Dict[str, object] = {}
        self._carla        = None

    # ---- Lifecycle -----------------------------------------------------------

    def start(self) -> None:
        try:
            import carla as _carla
        except ImportError:
            sys.exit(
                "FATAL: 'carla' package not importable.\n"
                f"Check that the egg exists at:\n  {_CARLA_EGG}"
            )
        self._carla = _carla

        # ── Step 1: connect to an already-running CARLA, or launch one ────────
        #
        # Strategy: try to connect first (fast path for manual launch or
        # re-use across scenarios).  Only spawn a new process if port is closed.
        #
        self._client = _carla.Client(CARLA_HOST, CARLA_PORT)
        self._client.set_timeout(5.0)
        already_running = False
        try:
            self._client.get_server_version()
            already_running = True
        except Exception:
            pass

        if already_running:
            pass
        else:
            # Launch the packaged build (or fall back to UE4Editor)
            if USE_PACKAGED_BUILD:
                if not os.path.exists(CARLA_PACKAGED_EXE):
                    raise FileNotFoundError(
                        f"Packaged CARLA not found:\n  {CARLA_PACKAGED_EXE}\n"
                        "Update CARLA_PACKAGED_EXE at the top of this file."
                    )
                launch_cmd = [
                    CARLA_PACKAGED_EXE,
                    "-RenderOffScreen",
                    f"-carla-port={CARLA_PORT}",
                    "-quality-level=Low",
                    "-benchmark",
                    "-fps=2",   # match capture rate - no point rendering faster than we capture
                ]
                print("[CARLA] Launching packaged CarlaUE4.exe headless ...")
            else:
                if not os.path.exists(UE4_EDITOR_EXE):
                    raise FileNotFoundError(
                        f"UE4Editor not found:\n  {UE4_EDITOR_EXE}\n"
                        "Update UE4_EDITOR_EXE at the top of this file."
                    )
                if not os.path.exists(CARLA_UPROJECT):
                    raise FileNotFoundError(
                        f"CarlaUE4.uproject not found:\n  {CARLA_UPROJECT}\n"
                        "Update CARLA_UPROJECT at the top of this file."
                    )
                launch_cmd = [
                    UE4_EDITOR_EXE, CARLA_UPROJECT,
                    "-RenderOffScreen", "-nullrhi",
                    f"-carla-port={CARLA_PORT}",
                    "-quality-level=Low",
                    "-nosplash", "-noSound", "-unattended", "-nopause",
                ]
                print("[CARLA] Launching source-build via UE4Editor ...")
                print(f"        (first launch ~5-10 min for shader compilation)")

            self._process = subprocess.Popen(
                launch_cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

            # Poll until the server accepts connections
            self._client.set_timeout(5.0)
            print(f"[CARLA] Waiting for server (up to {CARLA_BOOT_TIMEOUT}s) ...")
            deadline  = time.time() + CARLA_BOOT_TIMEOUT
            connected = False
            while time.time() < deadline:
                try:
                    self._client.get_server_version()
                    connected = True
                    break
                except Exception:
                    time.sleep(3.0)

            if not connected:
                self._process.kill()
                raise RuntimeError(
                    f"CARLA did not respond within {CARLA_BOOT_TIMEOUT}s.\n"
                    "Try launching CarlaUE4.exe manually first, then re-run the script.\n"
                    f"Expected exe: {CARLA_PACKAGED_EXE if USE_PACKAGED_BUILD else UE4_EDITOR_EXE}"
                )

        # In CARLA 0.9.10, client.set_timeout() controls how long world.tick()
        # will wait for a rendered frame before raising RuntimeError.
        # 30s is conservative for a GPU under heavy load.
        self._client.set_timeout(30.0)
        ver = self._client.get_server_version()
        if not getattr(CarlaManager, "_server_logged", False):
            print(f"[CARLA] Server v{ver} on port {CARLA_PORT}.")
            CarlaManager._server_logged = True
        self._load_map()
        self._set_synchronous(True)
        self._spawn_camera()

    def warmup(self) -> None:
        """
        Tick CARLA_WARMUP_TICKS times and drain the image queue without saving.
        Call this once after start(), before any capture window opens.

        CARLA needs ~40 frames after scene load before road surfaces, terrain,
        and lighting are fully rendered. Without this warmup the first ~40
        saved frames show a black road/sky, and the capture windows end up
        short because those dead frames are counted against the budget.
        """
        print(f"[CARLA] Warming up ({CARLA_WARMUP_TICKS} ticks) ...", end="", flush=True)
        for _ in range(CARLA_WARMUP_TICKS):
            self._world.tick()
            try:
                self._image_queue.get(timeout=5.0)
            except queue.Empty:
                pass
        print(" done.")

    def stop(self) -> None:
        print("[CARLA] Shutting down ...")
        self._teardown_camera()
        self._destroy_all_actors()
        if self._world is not None:
            try:
                self._set_synchronous(False)
            except Exception:
                pass
        if self._process is not None:
            self._process.terminate()
            try:
                self._process.wait(timeout=20)
            except subprocess.TimeoutExpired:
                self._process.kill()
        self._world  = None
        self._client = None
        self._carla  = None
        print("[CARLA] Stopped.")

    # ---- Map -----------------------------------------------------------------

    def _load_map(self) -> None:
        # Load Highway1 explicitly - the packaged build may default to a different map.
        # We do NOT call set_weather() after loading: the map has Unreal-baked lighting
        # and calling set_weather() overrides it, causing the black road surface.
        # training_simulator.py used get_world() (no reload) which also skips set_weather.
        current = self._client.get_world().get_map().name.split("/")[-1]
        if current.lower() != CARLA_MAP_NAME.lower():
            print(f"[CARLA] Current map is '{current}', loading '{CARLA_MAP_NAME}' ...")
            available = self._client.get_available_maps()
            matched = [m for m in available if m.split("/")[-1].lower() == CARLA_MAP_NAME.lower()]
            if not matched:
                segments = [m.split("/")[-1] for m in available]
                raise RuntimeError(
                    f"Map '{CARLA_MAP_NAME}' not found. Available: {segments}\n"
                    f"Update CARLA_MAP_NAME at the top of this file."
                )
            self._world = self._client.load_world(matched[0])
            # Wait for the world to settle after loading
            import time as _time
            _time.sleep(2.0)
        else:
            self._world = self._client.get_world()
        self._bp_lib = self._world.get_blueprint_library()
        # Purge any vehicle actors left over from the previous scenario.
        # _destroy_all_actors() only cleans the Python pool; actors that failed
        # to spawn (or were left by a crashed run) linger in the CARLA world and
        # can appear as a ghost car in the first frames of the next scenario.
        try:
            stale = list(self._world.get_actors().filter('vehicle.*'))
            if stale:
                for actor in stale:
                    try:
                        actor.destroy()
                    except Exception:
                        pass
                print(f"[CARLA] Purged {len(stale)} stale vehicle actor(s) from world.")
        except Exception:
            pass
        if not getattr(CarlaManager, "_map_logged", False):
            print(f"[CARLA] Map: {self._world.get_map().name}  (Unreal lighting, no set_weather).")
            CarlaManager._map_logged = True

    def _set_synchronous(self, enabled: bool) -> None:
        settings = self._world.get_settings()
        settings.synchronous_mode    = enabled
        settings.fixed_delta_seconds = cfg.sim_step_length if enabled else 0.0
        self._world.apply_settings(settings)

    # ---- Camera --------------------------------------------------------------

    def _spawn_camera(self) -> None:
        bp = self._bp_lib.find("sensor.camera.rgb")
        bp.set_attribute("image_size_x",               str(CAM_IMAGE_X))
        bp.set_attribute("image_size_y",               str(CAM_IMAGE_Y))
        bp.set_attribute("fov",                        str(CAM_FOV))
        # Exact settings from training_simulator.py (tested and working)
        bp.set_attribute("enable_postprocess_effects", "True")
        bp.set_attribute("exposure_mode",              CAM_EXPOSURE_MODE)
        bp.set_attribute("exposure_compensation",      str(CAM_EXPOSURE_COMP))
        bp.set_attribute("iso",                        str(CAM_ISO))
        bp.set_attribute("gamma",                      str(CAM_GAMMA))
        bp.set_attribute("shutter_speed",              str(CAM_SHUTTER))

        transform = self._carla.Transform(
            self._carla.Location(**CAM_LOCATION),
            self._carla.Rotation(**CAM_ROTATION),
        )
        self._camera = self._world.spawn_actor(bp, transform)
        self._camera.listen(self._image_queue.put)
        if not getattr(self, "_camera_spawn_logged", False):
            cx, cy, cz = CAM_LOCATION["x"], CAM_LOCATION["y"], CAM_LOCATION["z"]
            print(f"[CARLA] Camera at x={cx}, y={cy}, z={cz}  (logged once).")
            self._camera_spawn_logged = True

    def _teardown_camera(self) -> None:
        if self._camera is not None:
            try:
                self._camera.stop()
                self._camera.destroy()
            except Exception:
                pass
            self._camera = None

    # ---- Vehicle actor pool --------------------------------------------------

    def sync_vehicles(
        self,
        vehicle_states: Dict[str, Tuple[float, float, float]],
    ) -> None:
        """
        Reconcile CARLA actor pool with current SUMO vehicle snapshot.

        Parameters
        ----------
        vehicle_states : {sumo_vid: (sumo_x, sumo_y, heading_deg)}
        """
        current_ids = set(vehicle_states)
        pool_ids    = set(self._actor_pool)

        for vid in pool_ids - current_ids:
            try:
                self._actor_pool[vid].destroy()
            except Exception:
                pass
            del self._actor_pool[vid]

        for vid, (sx, sy, heading) in vehicle_states.items():
            cx, cy, cz = self._sumo_to_carla(sx, sy)
            yaw        = self._sumo_heading_to_carla(heading)
            transform  = self._carla.Transform(
                self._carla.Location(x=cx, y=cy, z=cz),
                self._carla.Rotation(yaw=yaw),
            )
            if vid in self._actor_pool:
                self._actor_pool[vid].set_transform(transform)
            else:
                bp = self._bp_lib.find(random.choice(VEHICLE_BLUEPRINTS))
                # Randomise color so blueprints don't always appear in their
                # default color (e.g. Tesla always blue, Mustang always red).
                if bp.has_attribute("color"):
                    color_choices = bp.get_attribute("color").recommended_values
                    if color_choices:
                        bp.set_attribute("color", random.choice(color_choices))
                actor = self._world.try_spawn_actor(bp, transform)
                if actor is not None:
                    actor.set_simulate_physics(False)
                    self._actor_pool[vid] = actor

    def _destroy_all_actors(self) -> None:
        for actor in self._actor_pool.values():
            try:
                actor.destroy()
            except Exception:
                pass
        self._actor_pool.clear()

    # ---- Tick & capture ------------------------------------------------------

    def tick(self) -> None:
        self._world.tick()

    def capture_image(self, out_path) -> bool:
        """
        Save the image produced by the most recent tick().
        If out_path is None, drains the queue without saving (used between windows).
        Uses a blocking get() so we wait for the camera callback to fire.
        Returns True if an image was received (regardless of whether it was saved).
        """
        try:
            image = self._image_queue.get(timeout=5.0)   # wait up to 5s
        except queue.Empty:
            return False  # timeout: CARLA didn't produce a frame
        # Drain any extra frames that built up (shouldn't happen in sync mode)
        while not self._image_queue.empty():
            try:
                image = self._image_queue.get_nowait()   # keep latest
            except queue.Empty:
                break
        if out_path is not None:
            image.save_to_disk(str(out_path), self._carla.ColorConverter.Raw)
        return True

    # ---- Coordinate helpers --------------------------------------------------

    @staticmethod
    def _sumo_to_carla(sx: float, sy: float) -> Tuple[float, float, float]:
        # SUMO: right-handed, y north.  CARLA/UE4: left-handed, y south.
        cx = sx + COORD_OFFSET_X
        cy = -(sy + COORD_OFFSET_Y)
        return cx, cy, SPAWN_Z

    @staticmethod
    def _sumo_heading_to_carla(sumo_heading: float) -> float:
        # SUMO 0 deg = North, CW.  CARLA yaw 0 deg = East, CCW.
        return -(sumo_heading - 90.0)


# ============================================================================
# AID Scenario Runner
# ============================================================================

class AIDScenarioRunner:
    """
    Runs one incident scenario with SUMO (via imported SUMOSimulator) and
    optionally CARLA image capture.

    Phase 1  (SUMO only, no GPU):
        t = 0  ->  capture_start  (= incident_start - PRE_INCIDENT_WINDOW)
        SUMO steps at full speed.  CARLA is not launched yet.

    Phase 2  (SUMO + CARLA):
        t = capture_start  ->  incident_clear_time
        CARLA renders each step; images saved at CAPTURE_FPS.
        Incident vehicle injected at incident_start_time.
        Scenario ends at incident_clear_time (clean label boundary).
    """

    def __init__(self, dry_run: bool = False) -> None:
        self.dry_run       = dry_run
        self.sumo          = SUMOSimulator(gui_mode=False)
        self.all_macro_rows: list = []   # accumulates all scenarios, saved once at end
        self.discarded_scenarios: list = []   # (scen_label, reason) for summary report
        self.warn_scenarios: list = []         # (scen_label, reason) non-fatal warnings

    def run(
        self,
        scenario_id:       int,
        flow_total:        int,
        speed_factor_mean: float,
        incident_position: Optional[float],   # None = no-incident scenario
    ) -> List[dict]:
        """
        Run one scenario.
        - incident_position=None: SUMO only, macro data logged, no camera.
        - incident_position=float: SUMO + two-window CARLA capture.
        Returns per-frame metadata rows (empty for no-incident scenarios).
        """

        has_incident = incident_position is not None
        onramp_flow  = 0

        # Deterministic randomness per scenario (same seed logic as simulation.py)
        random.seed(cfg.random_state + scenario_id)

        if not has_incident:
            # ── Non-incident scenario ─────────────────────────────────────────
            # Run SUMO for macro detector data.
            # Also capture FRAMES_PER_WINDOW images (label=0) from a random
            # steady-state window, so label=0 training data comes from genuinely
            # normal traffic - not from "30s before something bad happens".
            scen_label = f"s{scenario_id:05d}"
            print(f"[{scen_label}] flow={flow_total} veh/h  sf={speed_factor_mean:.2f}  NO INCIDENT")
            route_file = cfg.base_dir / f"routes_temp_{scenario_id}.rou.xml"
            self.sumo.generate_route_file(flow_total, onramp_flow, speed_factor_mean, route_file)
            _fix_depart_lanes(route_file)
            self.sumo.start_simulation(route_file, scenario_id)
            self.sumo.logging_active           = False
            self.sumo.first_vehicle_completed  = False
            self.sumo.baseline_speeds          = {}
            self.sumo.baseline_occupancies     = {}
            self.sumo.log_data                 = []
            last_detector_log_time = -999.0
            last_capture_time      = -999.0
            completed_vehicles:    set = set()
            all_spawned_vehicles:  set = set()
            steady_state_achieved_time = None

            # Capture window: fixed at t=200s (same across all non-incident scenarios).
            # 200s matches MIN_INCIDENT_TIME used in incident scenarios, ensuring
            # steady state has been reached and the road has plenty of traffic.
            NI_CAP_START = 200.0
            cap_start_t  = NI_CAP_START
            cap_end_t    = NI_CAP_START + NI_CAPTURE_DURATION   # 60s = 120 frames
            ni_carla     = None
            ni_frame_id  = 0
            ni_metadata: List[dict] = []
            img_dir_ni   = DATASET_DIR / scen_label / "images"

            try:
                while True:
                    traci.simulationStep()
                    self.sumo.current_step += 1
                    t = traci.simulation.getTime()
                    if t > cfg.max_simulation_time:
                        break
                    current_vehicles = set(traci.vehicle.getIDList())
                    all_spawned_vehicles.update(current_vehicles)
                    newly = all_spawned_vehicles - current_vehicles - completed_vehicles
                    completed_vehicles.update(newly)
                    # Detect first vehicle exit -> steady-state countdown
                    if not self.sumo.first_vehicle_completed and completed_vehicles:
                        self.sumo.first_vehicle_completed = True
                        steady_state_achieved_time = t + cfg.steady_state_buffer_time
                        pass  # cap_start_t is fixed at NI_CAP_START=200s
                    # Start macro logging once steady-state confirmed
                    if (not self.sumo.logging_active
                            and self.sumo.first_vehicle_completed
                            and steady_state_achieved_time is not None
                            and t >= steady_state_achieved_time):
                        self.sumo.logging_active = True
                    # Detector logging at 1 Hz
                    if self.sumo.logging_active and t - last_detector_log_time >= cfg.log_frequency:
                        data_point = self.sumo.collect_detector_data(update_baseline=True)
                        data_point['scenario_id']      = scen_label
                        data_point['flow_total']        = flow_total
                        data_point['speed_factor_mean'] = speed_factor_mean
                        data_point['has_incident']      = 0
                        data_point['incident_position'] = 0
                        data_point['incident_active']   = 0
                        self.sumo.log_data.append(data_point)
                        last_detector_log_time = t
                    # Exit after 1650s of logged data
                    if self.sumo.logging_active and steady_state_achieved_time is not None:
                        if t - steady_state_achieved_time >= 1650:
                            print(f"\n  [SIM] t={t:.0f}s - 1650s logged, no-incident complete.")
                            break
                    # ── CARLA capture (label=0, runs from t=200 until FRAMES_NI reached) ──
                    # No time-based end: keep going until frame count is hit.
                    # last_capture_time only updates on SUCCESS so missed frames are retried.
                    ni_frames_done = len(ni_metadata)
                    in_cap = (t >= cap_start_t and ni_frames_done < FRAMES_NI)
                    if not self.dry_run and in_cap:
                        if ni_carla is None:
                            img_dir_ni.mkdir(parents=True, exist_ok=True)
                            ni_carla = CarlaManager()
                            ni_carla.start()
                            ni_carla.warmup()   # burn through loading frames before counting
                        if t - last_capture_time >= CAPTURE_INTERVAL:
                            cam_sumo_x = CAM_LOCATION["x"]
                            vehicle_states = {}
                            for vid in current_vehicles:
                                vx, vy = traci.vehicle.getPosition(vid)
                                dist_ahead = cam_sumo_x - vx
                                if 0 <= dist_ahead <= VEHICLE_SYNC_RADIUS:
                                    vehicle_states[vid] = (vx, vy, traci.vehicle.getAngle(vid))
                            ni_carla.sync_vehicles(vehicle_states)
                            ni_carla.tick()
                            fname = f"frame_{ni_frame_id:06d}.png"
                            saved = ni_carla.capture_image(img_dir_ni / fname)
                            if saved:
                                last_capture_time = t   # only advance timer on success
                                ni_metadata.append({
                                    "scenario_id":         scen_label,
                                    "sim_time":            round(t, 2),
                                    "frame_id":            ni_frame_id,
                                    "filename":            fname,
                                    "incident_label":      0,
                                    "capture_window":      "NI",
                                    "mainline_flow":       flow_total,
                                    "speed_factor":        speed_factor_mean,
                                    "incident_position":   0,
                                    "incident_lane":       0,
                                    "incident_start_time": 0,
                                    "incident_clear_time": 0,
                                })
                                ni_frame_id += 1
                            # last_capture_time already set above on success
                    # Progress print every 60s
                    if self.sumo.logging_active and int(t) % 60 == 0 and t != last_detector_log_time:
                        rows = len(self.sumo.log_data)
                        phase = f"CAP({ni_frames_done}/{FRAMES_NI})" if in_cap else "LOG"
                        print(f"  [no-incident] t={t:.0f}s  {phase}  rows={rows}  vehicles={len(current_vehicles)}", end="\r")
            except Exception as exc:
                print(f"[SIM] Error in no-incident run: {exc}")
            finally:
                if ni_carla is not None:
                    try:
                        ni_carla._teardown_camera()
                        ni_carla._destroy_all_actors()
                        ni_carla._set_synchronous(False)
                    except Exception:
                        pass
                try:
                    traci.close()
                    time.sleep(0.5)
                except Exception:
                    pass
                for _ in range(3):
                    try:
                        if route_file.exists():
                            route_file.unlink()
                        break
                    except PermissionError:
                        time.sleep(0.5)
            # Accumulate macro data
            if self.sumo.log_data:
                self.all_macro_rows.extend(self.sumo.log_data)
                self.sumo.log_data = []
            # Write image metadata and accumulate
            if ni_metadata:
                if len(ni_metadata) < FRAMES_NI:
                    warn = f"only {len(ni_metadata)}/{FRAMES_NI} label=0 frames captured"
                    self.warn_scenarios.append((scen_label, warn))
                    print(f"  [WARN] {scen_label}: {warn}")
                scen_csv_ni = DATASET_DIR / scen_label / "metadata.csv"
                _write_csv(scen_csv_ni, ni_metadata)
                print(f"[OUT] {scen_label}: {len(ni_metadata)} frames (label=0, no-incident).")
                return ni_metadata
            else:
                if not self.dry_run:
                    warn = "0 label=0 frames captured - capture window may have been before steady state"
                    self.warn_scenarios.append((scen_label, warn))
                    print(f"  [WARN] {scen_label}: {warn}")
                print(f"[OUT] {scen_label}: macro only (dry-run or capture window missed).")
                return []

        # ── Incident scenario below ───────────────────────────────────────────
        # Earliest eligible time for injection (after steady state).
        # Actual injection searches upstream for a vehicle via setStop.
        t_lo = max(200.0, min(cfg.incident_start_time_min, cfg.incident_start_time_max))
        t_hi = max(200.0, max(cfg.incident_start_time_min, cfg.incident_start_time_max))
        incident_start      = random.uniform(t_lo, t_hi) if t_hi > t_lo else float(t_lo)
        incident_lane       = random.choice(cfg.incident_lane_distribution)
        # Random stop position within camera stop zone - varied per scenario
        incident_position   = random.uniform(CAM_STOP_MIN, CAM_STOP_MAX)
        recovery_duration   = random.uniform(900, 1800)
        incident_clear_time = incident_start + 300 + recovery_duration  # conservative init

        # ── Capture strategy ─────────────────────────────────────────────────
        # win_a runs from carla_start_t (incident_start - 30s) until injection
        # win_b runs from injection for JAM_CAPTURE_DURATION seconds
        win_b_start = None
        win_b_end   = None
        sim_end     = incident_clear_time   # updated after actual injection

        has_camera  = not self.dry_run

        scen_label = f"s{scenario_id:05d}"
        img_dir    = DATASET_DIR / scen_label / "images"
        img_dir.mkdir(parents=True, exist_ok=True)

        # Skip already-completed scenarios so re-runs are safe.
        scen_csv = DATASET_DIR / scen_label / "metadata.csv"
        if scen_csv.exists():
            import csv as _csv
            with open(scen_csv, newline="", encoding="utf-8") as fh:
                existing_count = sum(1 for _ in _csv.DictReader(fh))
            if existing_count > 0:
                print(f"[SKIP] {scen_label} already has {existing_count} frames - skipping.")
                return []

        print(f"\n{'─'*60}")
        print(f"[{scen_label}] flow={flow_total} veh/h  sf={speed_factor_mean:.2f}  "
              f"stop@x={incident_position:.0f}m  lane={incident_lane}")
        print(f"  Inject: t>={incident_start:.1f}s  searches [{incident_position - STOP_SEARCH_UPSTREAM:.0f}-{incident_position:.0f}]m upstream")
        print(f"  Capture: A={FRAMES_PRE} frames label=0 (pre)  +  B={FRAMES_INCIDENT} frames label=1 (jam)")
        print(f"{'─'*60}")

        # Route file - uses simulation.py's proven generator
        route_file = cfg.base_dir / f"routes_temp_{scenario_id}.rou.xml"
        self.sumo.generate_route_file(flow_total, onramp_flow, speed_factor_mean, route_file)
        _fix_depart_lanes(route_file)

        incident_lane_sumo = incident_lane

        # Start SUMO
        self.sumo.start_simulation(route_file, scenario_id)

        # Reset SUMOSimulator state variables
        self.sumo.logging_active          = False
        self.sumo.first_vehicle_completed = False
        self.sumo.baseline_speeds         = {}
        self.sumo.baseline_occupancies    = {}
        self.sumo.log_data                = []

        # Local state
        metadata_rows:            List[dict]  = []
        frame_id                  = 0
        last_capture_time         = -999.0
        last_detector_log_time    = -999.0
        last_print_time           = -999.0
        incident_injected         = False
        incident_vehicle          = None
        incident_injection_attempts = 0
        injection_failed          = False
        actual_inject_time        = None
        actual_stop_time          = None   # when speed < 1 m/s after injection
        completed_vehicles:       set = set()
        all_spawned_vehicles:     set = set()
        steady_state_achieved_time: Optional[float] = None
        carla: Optional[CarlaManager] = None
        # CARLA starts 60s before incident_start, giving a comfortable pre-incident
        # buffer of label=0 frames. We capture continuously until window B is full,
        # then _trim_incident_frames() keeps the last FRAMES_PRE label=0 frames and
        # the first FRAMES_INCIDENT label=1 frames - always exactly 240 frames total,
        # with the transition at frame 61 (no gaps between frames 60 and 61).
        carla_start_t = max(0.0, incident_start - 60.0)

        try:
            while True:
                traci.simulationStep()
                self.sumo.current_step += 1
                t = traci.simulation.getTime()

                # Hard timeout
                if t > cfg.max_simulation_time:
                    print(f"\n[SIM] Hard timeout at t={t:.1f}s")
                    break

                # Stop simulation after incident clears (macro data complete)
                if t >= sim_end:
                    print(f"\n[SIM] t={t:.1f}s - incident cleared, stopping.")
                    break

                # Vehicle tracking (mirrors simulation.py)
                current_vehicles = set(traci.vehicle.getIDList())
                all_spawned_vehicles.update(current_vehicles)
                newly_completed  = all_spawned_vehicles - current_vehicles - completed_vehicles
                completed_vehicles.update(newly_completed)

                if not self.sumo.first_vehicle_completed and completed_vehicles:
                    self.sumo.first_vehicle_completed  = True
                    steady_state_achieved_time         = t + cfg.steady_state_buffer_time

                if (not self.sumo.logging_active
                        and self.sumo.first_vehicle_completed
                        and steady_state_achieved_time is not None
                        and t >= steady_state_achieved_time):
                    self.sumo.logging_active = True

                # ── Incident injection: setStop at exact camera position ────────────
                #
                # setStop(edge, pos) tells SUMO exactly WHERE to stop.
                # SUMO deceleration physics are handled automatically.
                #
                # "too close to brake" error: vehicle is so close to the stop point
                # that SUMO can't fit a smooth deceleration curve.  Fix: only offer
                # vehicles that are at least MIN_BRAKE_DIST metres upstream, and
                # try candidates from farthest to closest so we always prefer vehicles
                # with the most braking room.  Skip any that still fail and move on.
                #
                # The stop target (incident_position) is randomised across the visible
                # range each scenario so cars stop at varied positions in the frame.
                if (not incident_injected
                        and self.sumo.logging_active
                        and t >= incident_start):
                    stop_x        = incident_position
                    # Choose STOP_EDGE dynamically based on actual edge geometry
                    # (before_det3 ends at x=2400; det3 spans 2400-2500).
                    if stop_x < STOP_DET3_START:
                        effective_stop_edge = "before_det3"
                        stop_lane_pos = stop_x - STOP_BEFORE_DET3_START
                    else:
                        effective_stop_edge = "det3"
                        stop_lane_pos = stop_x - STOP_DET3_START
                    search_min_x  = stop_x - STOP_SEARCH_UPSTREAM
                    # Corrected edge_starts (SUMO cartesian x from highway_net.xml shapes):
                    edge_starts   = {
                        "before_det1": 0.0,     "det1":        1200.0,
                        "before_det2": 1300.0,  "det2":        1800.0,
                        "before_det3": 1900.0,  "det3":        2400.0,
                        "after_det3":  2500.0,
                    }
                    candidates = []
                    for vid in current_vehicles:
                        try:
                            edge     = traci.vehicle.getRoadID(vid)
                            lane_idx = traci.vehicle.getLaneIndex(vid)
                            if lane_idx != incident_lane_sumo:
                                continue
                            if edge not in edge_starts:
                                continue
                            lane_pos = traci.vehicle.getLanePosition(vid)
                            abs_x    = edge_starts[edge] + lane_pos
                            dist_to_stop = stop_x - abs_x
                            # Must be upstream and have enough room to brake
                            if MIN_BRAKE_DIST <= dist_to_stop <= STOP_SEARCH_UPSTREAM:
                                candidates.append((vid, abs_x, dist_to_stop))
                        except Exception:
                            continue

                    if candidates:
                        # Try from farthest to closest - most braking room first
                        candidates.sort(key=lambda c: c[2], reverse=True)
                        injected_ok = False
                        for chosen_vid, chosen_x, chosen_dist in candidates:
                            try:
                                # ── Abrupt-braking fix ──────────────────────────────
                                # EIDM comfortable decel (~4 m/s²) gives a 160m stopping
                                # distance from 130 km/h - far too gradual.
                                # 14 m/s² cuts that to ~46m: sharp emergency braking,
                                # realistic for an incident/breakdown event.
                                # emergencyDecel must be raised to match so SUMO doesn't cap it.
                                # Set BEFORE setStop so SUMO uses this decel in its check.
                                INCIDENT_DECEL           = 14.0   # m/s²  (was EIDM ~4; 7→14)
                                INCIDENT_EMERGENCY_DECEL = 15.0   # m/s²
                                traci.vehicle.setDecel(chosen_vid, INCIDENT_DECEL)
                                traci.vehicle.setEmergencyDecel(chosen_vid, INCIDENT_EMERGENCY_DECEL)
                                # ── End abrupt-braking fix ──────────────────────────
                                traci.vehicle.setStop(
                                    chosen_vid, effective_stop_edge,
                                    pos=float(stop_lane_pos),
                                    laneIndex=incident_lane_sumo,
                                    duration=float(recovery_duration),
                                )
                                traci.vehicle.setLaneChangeMode(chosen_vid, 0)
                                traci.vehicle.setColor(chosen_vid, (255, 0, 0, 255))
                                incident_vehicle    = chosen_vid
                                incident_injected   = True
                                actual_inject_time  = t
                                win_b_start         = t + JAM_CAPTURE_OFFSET
                                win_b_end           = win_b_start + JAM_CAPTURE_DURATION
                                incident_clear_time = t + 300 + recovery_duration
                                sim_end             = incident_clear_time
                                injected_ok         = True
                                print(f"  [INJ] t={t:.1f}s  vehicle={chosen_vid}  "
                                      f"now@x={chosen_x:.0f}  ({chosen_dist:.0f}m to stop)  "
                                      f"edge={effective_stop_edge}  lane_pos={stop_lane_pos:.0f}  "
                                      f"stop@x={stop_x:.0f}")
                                break
                            except Exception:
                                # This candidate is too close - silently skip to next
                                continue
                        if not injected_ok:
                            incident_injection_attempts += 1
                    else:
                        incident_injection_attempts += 1

                    if not incident_injected:
                        if incident_injection_attempts % 100 == 0:
                            print(f"  [WAIT] t={t:.0f}s  no suitable vehicle "
                                  f"[{MIN_BRAKE_DIST:.0f}-{STOP_SEARCH_UPSTREAM:.0f}]m "
                                  f"upstream of x={stop_x:.0f}m...", end="\r")
                        if t > incident_start + 600:
                            reason_disc = (f"no vehicle with >={MIN_BRAKE_DIST:.0f}m brake room "
                                           f"upstream of x={stop_x:.0f}m after 600s")
                            self.discarded_scenarios.append((scen_label, reason_disc))
                            print(f"\n[DISCARD] {scen_label}: {reason_disc}.")
                            injection_failed = True
                            break

                # ── Track when vehicle actually comes to a full stop ─────────────
                if incident_injected and actual_stop_time is None and incident_vehicle:
                    try:
                        spd = traci.vehicle.getSpeed(incident_vehicle)
                        if spd < 1.0:
                            actual_stop_time    = t
                            incident_clear_time = actual_stop_time + recovery_duration
                            sim_end             = incident_clear_time
                            print(f"  [STOP] t={t:.1f}s  fully stopped  (speed={spd:.2f} m/s)  "
                                  f"clear@t={incident_clear_time:.0f}s")
                    except Exception:
                        pass

                # ── CARLA capture: continuous from carla_start_t ─────────────────
                # Capture every frame. Label=0 before car is fully stopped,
                # label=1 once actual_stop_time is set. No gaps, no jumps.
                # Post-run trim keeps last FRAMES_PRE label=0 + first FRAMES_INCIDENT label=1.

                # Start CARLA 60s before incident_start
                if has_camera and carla is None and t >= carla_start_t:
                    carla = CarlaManager()
                    carla.start()
                    carla.warmup()

                if has_camera and carla is not None and t - last_capture_time >= CAPTURE_INTERVAL:
                    cam_sumo_x = CAM_LOCATION["x"]
                    vehicle_states = {}
                    for vid in current_vehicles:
                        vx, vy = traci.vehicle.getPosition(vid)
                        dist_ahead = cam_sumo_x - vx
                        if 0 <= dist_ahead <= VEHICLE_SYNC_RADIUS:
                            vehicle_states[vid] = (vx, vy, traci.vehicle.getAngle(vid))
                    carla.sync_vehicles(vehicle_states)
                    carla.tick()

                    # label=0 until fully stopped, label=1 from actual_stop_time onward
                    label  = 1 if (actual_stop_time is not None) else 0
                    window = "B" if label == 1 else "A"
                    fname  = f"frame_{frame_id:06d}.png"
                    saved  = carla.capture_image(img_dir / fname)
                    if saved:
                        last_capture_time = t
                        metadata_rows.append({
                            "scenario_id":         scen_label,
                            "sim_time":            round(t, 2),
                            "frame_id":            frame_id,
                            "filename":            fname,
                            "incident_label":      label,
                            "capture_window":      window,
                            "mainline_flow":       flow_total,
                            "speed_factor":        speed_factor_mean,
                            "incident_position":   round(incident_position, 1),
                            "incident_lane":       incident_lane,
                            "incident_start_time": round(actual_inject_time if actual_inject_time else incident_start, 2),
                            "incident_clear_time": round(incident_clear_time, 2),
                        })
                        frame_id += 1

                    # Stop capturing once we have enough label=1 frames
                    if actual_stop_time is not None:
                        n_b = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
                        if n_b >= FRAMES_INCIDENT:
                            break   # window B full - exit main loop early

                # Progress print every 30s
                if int(t) % 30 == 0 and t - last_print_time >= 29.0:
                    if not incident_injected and t >= carla_start_t:
                        in_win = "WIN-A"
                    elif actual_stop_time and actual_stop_time <= t < actual_stop_time + JAM_CAPTURE_DURATION:
                        in_win = "WIN-B"
                    else:
                        in_win = "---"
                    phase = ("INCIDENT" if incident_injected
                             else "WAIT-ZONE" if self.sumo.logging_active and t >= incident_start
                             else "WARMUP" if not self.sumo.logging_active
                             else "PRE-INC")
                    fa = sum(1 for r in metadata_rows if r.get("capture_window") == "A")
                    fb = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
                    print(f"  t={t:.0f}s  {phase}  {in_win}  vehicles={len(current_vehicles)}  A={fa}/{FRAMES_PRE}  B={fb}/{FRAMES_INCIDENT}", end="\r")
                    last_print_time = t

                # ── Detector data logging (1 Hz, same as simulation.py) ────────
                if self.sumo.logging_active and t - last_detector_log_time >= cfg.log_frequency:
                    update_baseline = not incident_injected
                    data_point = self.sumo.collect_detector_data(update_baseline=update_baseline)
                    data_point['scenario_id']       = scen_label
                    data_point['flow_total']         = flow_total
                    data_point['speed_factor_mean']  = speed_factor_mean
                    data_point['has_incident']       = 1
                    data_point['incident_position']  = incident_position
                    data_point['incident_active']    = 1 if incident_injected else 0
                    self.sumo.log_data.append(data_point)
                    last_detector_log_time = t

                elif self.dry_run and t - last_print_time >= 10.0:
                    if t >= carla_start_t:
                        status = "INCIDENT" if incident_injected else "PRE-INCIDENT"
                    else:
                        status = "FAST-FORWARD"
                    print(f"  [dry-run] t={t:.1f}s  {status}  "
                          f"vehicles={len(current_vehicles)}",
                          end="\r")
                    last_print_time = t

        except KeyboardInterrupt:
            print("\n[SIM] Interrupted.")
        except Exception as exc:
            print(f"\n[SIM] Error: {exc}")
            import traceback
            traceback.print_exc()
        finally:
            if carla is not None:
                carla._destroy_all_actors()
                carla._teardown_camera()
                # Drain any leftover images from the queue to free memory
                while not carla._image_queue.empty():
                    try:
                        carla._image_queue.get_nowait()
                    except Exception:
                        break
                try:
                    carla._set_synchronous(False)
                except Exception:
                    pass
                carla = None
            import gc
            gc.collect()   # reclaim Python objects accumulated during the scenario
            try:
                traci.close()
                time.sleep(0.5)
            except Exception:
                pass
            for _ in range(3):
                try:
                    if route_file.exists():
                        route_file.unlink()
                    break
                except PermissionError:
                    time.sleep(0.5)

        # Discard everything if incident injection failed
        if injection_failed:
            self.sumo.log_data = []
            reason = f"injection failed: no vehicle near pos={incident_position:.0f}m after 60 retries"
            self.discarded_scenarios.append((scen_label, reason))
            print(f"[DISCARD] {scen_label}: {reason}.")
            return []

        # Accumulate macro data
        if self.sumo.log_data:
            self.all_macro_rows.extend(self.sumo.log_data)
            print(f"[OUT] {scen_label}: {len(self.sumo.log_data)} macro rows accumulated.")
            self.sumo.log_data = []

        # Write per-scenario image metadata CSV with trim
        if metadata_rows:
            metadata_rows = self._trim_incident_frames(
                scen_label, metadata_rows, img_dir
            )
            n_pre      = sum(1 for r in metadata_rows if r.get("capture_window") == "A")
            n_incident = sum(1 for r in metadata_rows if r.get("capture_window") == "B")
            if n_pre < FRAMES_PRE:
                warn = f"only {n_pre}/{FRAMES_PRE} label=0 pre-incident frames captured"
                self.warn_scenarios.append((scen_label, warn))
                print(f"  [WARN] {scen_label}: {warn}")
            if n_incident < FRAMES_INCIDENT:
                warn = f"only {n_incident}/{FRAMES_INCIDENT} label=1 frames captured"
                self.warn_scenarios.append((scen_label, warn))
                print(f"  [WARN] {scen_label}: {warn}")
            scen_csv = DATASET_DIR / scen_label / "metadata.csv"
            _write_csv(scen_csv, metadata_rows)
            print(f"[OUT] {scen_label}: {len(metadata_rows)} frames  "
                  f"(A={n_pre} label=0 / B={n_incident} label=1).")
        else:
            warn = "0 frames captured - possible CARLA error"
            self.warn_scenarios.append((scen_label, warn))
            print(f"  [WARN] {scen_label}: {warn}")

        return metadata_rows

    # ── Post-run trim ─────────────────────────────────────────────────────────

    @staticmethod
    def _trim_incident_frames(
        scen_label: str,
        rows: List[dict],
        img_dir: Path,
    ) -> List[dict]:
        """
        Trim a continuous capture buffer to exactly FRAMES_PRE label=0 frames
        followed by FRAMES_INCIDENT label=1 frames, with no gaps.

        Strategy
        --------
        - label=0 ("A") rows: keep the LAST FRAMES_PRE (closest to incident).
          Delete PNG files for any earlier label=0 rows.
        - label=1 ("B") rows: keep the FIRST FRAMES_INCIDENT.
          Delete PNG files for any later label=1 rows.
        - Renumber remaining rows frame_id 0..N-1 and rename PNG files to match,
          so the output folder is a clean 0-indexed sequence with no holes.

        This guarantees:
        - Frame 60 (index 59) is the last free-flow frame.
        - Frame 61 (index 60) is the first fully-stopped frame.
        - No abrupt jump: frame 60 is captured seconds before frame 61.
        """
        a_rows = [r for r in rows if r.get("capture_window") == "A"]
        b_rows = [r for r in rows if r.get("capture_window") == "B"]

        # Sort by original frame_id (capture order)
        a_rows.sort(key=lambda r: r["frame_id"])
        b_rows.sort(key=lambda r: r["frame_id"])

        # Trim A: keep last FRAMES_PRE, discard earlier ones
        if len(a_rows) > FRAMES_PRE:
            drop_a = a_rows[: len(a_rows) - FRAMES_PRE]
            keep_a = a_rows[len(a_rows) - FRAMES_PRE :]
            for r in drop_a:
                p = img_dir / r["filename"]
                try:
                    p.unlink(missing_ok=True)
                except Exception:
                    pass
            n_trimmed_a = len(drop_a)
        else:
            keep_a = a_rows
            n_trimmed_a = 0

        # Trim B: keep first FRAMES_INCIDENT, discard later ones
        if len(b_rows) > FRAMES_INCIDENT:
            keep_b = b_rows[:FRAMES_INCIDENT]
            drop_b = b_rows[FRAMES_INCIDENT:]
            for r in drop_b:
                p = img_dir / r["filename"]
                try:
                    p.unlink(missing_ok=True)
                except Exception:
                    pass
        else:
            keep_b = b_rows

        kept = keep_a + keep_b

        if n_trimmed_a:
            print(f"  [TRIM] {scen_label}: discarded {n_trimmed_a} earliest label=0 frames "
                  f"({len(kept)} remain)")

        # Renumber frame_ids 0..N-1 and rename PNG files on disk
        for new_id, r in enumerate(kept):
            old_fname = r["filename"]
            new_fname = f"frame_{new_id:06d}.png"
            if old_fname != new_fname:
                old_path = img_dir / old_fname
                new_path = img_dir / new_fname
                try:
                    old_path.rename(new_path)
                except Exception:
                    pass
            r["frame_id"] = new_id
            r["filename"] = new_fname

        return kept




MACRO_H5 = cfg.data_dir / "all_data.h5"   # matches simulation.py output filename


# Columns always written to HDF5 in this exact order (must be stable across all scenarios)
_MACRO_COLUMNS = [
    "scenario_id", "sim_time", "has_incident", "incident_active", "incident_position",
    "flow_total", "speed_factor_mean",
    "det1_speed_mean", "det1_speed_std", "det1_speed_min", "det1_flow", "det1_occupancy", "det1_vehicle_count",
    "det2_speed_mean", "det2_speed_std", "det2_speed_min", "det2_flow", "det2_occupancy", "det2_vehicle_count",
    "det3_speed_mean", "det3_speed_std", "det3_speed_min", "det3_flow", "det3_occupancy", "det3_vehicle_count",
]


def _append_macro_hdf5(df: pd.DataFrame) -> None:
    """Append a scenario's detector rows to the shared HDF5 macro data file."""
    df = df.drop(columns=["step"], errors="ignore")
    for col in _MACRO_COLUMNS:
        if col not in df.columns:
            df[col] = 0
    df = df[_MACRO_COLUMNS]
    try:
        mode = "a" if MACRO_H5.exists() and MACRO_H5.stat().st_size > 1000 else "w"
        df.to_hdf(
            MACRO_H5, key="data", mode=mode, format="table",
            append=(mode == "a"),
            data_columns=["scenario_id", "sim_time", "incident_active", "has_incident"]
        )
    except Exception as e:
        fallback = cfg.data_dir / f"macro_fallback_{df['scenario_id'].iloc[0]}.csv"
        df.to_csv(fallback, index=False)
        print(f"  [WARN] HDF5 append failed ({e}), saved: {fallback.name}")


MASTER_CSV = DATASET_DIR / "master_metadata.csv"


def _write_csv(path: Path, rows: List[dict]) -> None:
    all_fields: list = []
    seen = set()
    for r in rows:
        for k in r.keys():
            if k not in seen and k is not None:
                all_fields.append(k)
                seen.add(k)
    with open(path, "w", newline="", encoding="utf-8") as fh:
        writer = csv.DictWriter(fh, fieldnames=all_fields, extrasaction="ignore")
        writer.writeheader()
        writer.writerows(rows)


def _append_master_csv(rows: List[dict]) -> None:
    if not rows:
        return
    needs_header = not MASTER_CSV.exists()
    with open(MASTER_CSV, "a", newline="", encoding="utf-8") as fh:
        writer = csv.DictWriter(fh, fieldnames=list(rows[0].keys()))
        if needs_header:
            writer.writeheader()
        writer.writerows(rows)


# ============================================================================
# Train / val / test split
# ============================================================================

def write_split_csvs() -> None:
    """
    Rebuild train/val/test split CSVs from master_metadata.csv.

    Split is at the SCENARIO level so no scenario leaks across splits.
    Ratios: cfg.train_ratio / val_ratio / test_ratio (default 70/15/15).
    """
    if not MASTER_CSV.exists():
        print("[SPLIT] master_metadata.csv not found - run scenarios first.")
        return

    with open(MASTER_CSV, newline="", encoding="utf-8") as fh:
        rows = list(csv.DictReader(fh))

    if not rows:
        print("[SPLIT] master_metadata.csv is empty.")
        return

    scen_ids = sorted(set(r["scenario_id"] for r in rows))
    rng      = random.Random(cfg.random_state)
    rng.shuffle(scen_ids)

    n       = len(scen_ids)
    n_train = int(n * cfg.train_ratio)
    n_val   = int(n * cfg.val_ratio)

    train_ids = set(scen_ids[:n_train])
    val_ids   = set(scen_ids[n_train:n_train + n_val])
    test_ids  = set(scen_ids[n_train + n_val:])

    for split_name, id_set in [("train", train_ids),
                                ("val",   val_ids),
                                ("test",  test_ids)]:
        split_rows = [r for r in rows if r["scenario_id"] in id_set]
        out        = DATASET_DIR / f"{split_name}_metadata.csv"
        if split_rows:
            _write_csv(out, split_rows)
        n_scen = len(set(r["scenario_id"] for r in split_rows))
        print(f"[SPLIT] {split_name:5s}: {len(split_rows):6d} frames  "
              f"({n_scen} scenarios)  ->  {out}")


# ============================================================================
# Scenario enumeration
# ============================================================================

def enumerate_scenarios() -> List[dict]:
    """
    Return all scenarios: incident + non-incident.

    Ordering matches simulation.py's run_batch_simulations so scenario_id
    values are identical between the two scripts (important for HDF5 join).
    """
    scenarios = []
    sid       = 0

    sf_values = [
        round(cfg.speed_factor_min + i * cfg.speed_factor_step, 2)
        for i in range(
            int(round((cfg.speed_factor_max - cfg.speed_factor_min)
                      / cfg.speed_factor_step)) + 1
        )
    ]

    # Non-incident first (matches simulation.py iteration order)
    for flow in range(cfg.flow_min, cfg.flow_max + 1, cfg.flow_step):
        for sf in sf_values:
            for _ in cfg.incident_positions:
                scenarios.append(dict(
                    scenario_id       = sid,
                    flow_total        = flow,
                    speed_factor_mean = sf,
                    incident_position = None,
                ))
                sid += 1

    n_noincident = sid

    # Incident scenarios
    for flow in range(cfg.flow_min, cfg.flow_max + 1, cfg.flow_step):
        for sf in sf_values:
            for inc_pos in cfg.incident_positions:
                scenarios.append(dict(
                    scenario_id       = sid,
                    flow_total        = flow,
                    speed_factor_mean = sf,
                    incident_position = float(inc_pos),
                ))
                sid += 1

    n_incident = sid - n_noincident
    print(f"[CONFIG] {len(scenarios)} scenarios: {n_noincident} no-incident (SUMO only) "
          f"+ {n_incident} incident (SUMO + camera).")
    return scenarios


# ============================================================================
# Entry point
# ============================================================================

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Merged SUMO + CARLA AID incident dataset generator."
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Run SUMO only, skip CARLA. Fast way to validate incident injection.",
    )
    parser.add_argument(
        "--limit", type=int, default=None,
        help="Stop after this many scenarios (e.g. --limit 1 for smoke test).",
    )
    parser.add_argument(
        "--split-only", action="store_true",
        help="Skip simulation; only rebuild train/val/test split CSVs.",
    )
    parser.add_argument(
        "--no-incident-only", action="store_true",
        help=(
            "Run ONLY non-incident SUMO scenarios (no CARLA, no incident injection). "
            "Useful for collecting additional macro detector data without images. "
            "Output is still written to all_data.h5 in the data folder."
        ),
    )
    args = parser.parse_args()

    # ── Overall timer ─────────────────────────────────────────────────────────
    wall_start = time.time()

    if args.split_only:
        write_split_csvs()
        elapsed = time.time() - wall_start
        print(f"\n[MAIN] Split rebuild done in {elapsed:.1f}s.")
        return

    scenarios = enumerate_scenarios()

    # ── No-incident-only filter ───────────────────────────────────────────────
    if args.no_incident_only:
        scenarios = [s for s in scenarios if s["incident_position"] is None]
        print(f"[MODE] --no-incident-only: keeping {len(scenarios)} non-incident scenarios "
              f"(incident scenarios skipped).")

    if args.limit:
        scenarios = scenarios[: args.limit]

    print(f"[MAIN] Running {len(scenarios)} scenario(s).  "
          f"dry_run={args.dry_run}  no_incident_only={args.no_incident_only}")
    if not args.dry_run and not args.no_incident_only:
        print()
        print("[CARLA] Before running, start CARLA with this exact command:")
        print(f"  {CARLA_PACKAGED_EXE}"
              f" -quality-level=Low -benchmark -fps=2 -RenderOffScreen"
              f" -carla-port={CARLA_PORT}")
        print("  Wait until the map finishes loading (usually 20-40s), then this")
        print("  script will detect it automatically on port 2000.")
        print()

    # In no-incident-only mode, force dry_run so CARLA is never started.
    effective_dry_run = args.dry_run or args.no_incident_only
    runner = AIDScenarioRunner(dry_run=effective_dry_run)

    try:
        for i, sc in enumerate(scenarios, start=1):
            elapsed_so_far = time.time() - wall_start
            h, m = divmod(int(elapsed_so_far), 3600)
            m, s = divmod(m, 60)
            print(f"\n[MAIN] Scenario {i}/{len(scenarios)}  "
                  f"(elapsed {h:02d}:{m:02d}:{s:02d})")
            rows = runner.run(**sc)
            _append_master_csv(rows)
    except KeyboardInterrupt:
        print("\n[MAIN] Interrupted by user.")
    finally:
        if runner.discarded_scenarios or runner.warn_scenarios:
            print("\n" + "="*60)
            print("[SUMMARY] Issues during run:")
            if runner.discarded_scenarios:
                print(f"  DISCARDED ({len(runner.discarded_scenarios)} scenarios):")
                for sid, reason in runner.discarded_scenarios:
                    print(f"    {sid}: {reason}")
            if runner.warn_scenarios:
                print(f"  WARNINGS ({len(runner.warn_scenarios)} scenarios):")
                for sid, reason in runner.warn_scenarios:
                    print(f"    {sid}: {reason}")
            print("="*60)
        else:
            print("\n[SUMMARY] No discards or warnings.")
        try:
            traci.close()
        except Exception:
            pass
        if not args.no_incident_only:
            import subprocess as _sp
            _sp.run(["taskkill", "/f", "/im", "CarlaUE4.exe"],
                    stdout=_sp.DEVNULL, stderr=_sp.DEVNULL)
        print("[MAIN] Cleanup done (SUMO closed"
              + (", CarlaUE4 killed if script-launched" if not args.no_incident_only else "") + ").")

    # ── Save all macro data at once ──────────────────────────────────────────
    if runner.all_macro_rows:
        print(f"\n[MAIN] Saving macro data: {len(runner.all_macro_rows)} total rows ...")
        combined_df = pd.DataFrame(runner.all_macro_rows)
        combined_df = combined_df.drop(columns=["step"], errors="ignore")
        combined_df.to_hdf(MACRO_H5, key="data", mode="w", format="table",
                           data_columns=["scenario_id", "sim_time", "incident_active", "has_incident"])
        print(f"[MAIN] Macro data saved to {MACRO_H5.name}  ({len(combined_df):,} rows).")

        scenario_ids = combined_df["scenario_id"].unique()
        import numpy as _np
        rng = _np.random.default_rng(cfg.random_state)
        rng.shuffle(scenario_ids)
        n_train = int(len(scenario_ids) * cfg.train_ratio)
        n_val   = int(len(scenario_ids) * cfg.val_ratio)
        train_ids = scenario_ids[:n_train]
        val_ids   = scenario_ids[n_train:n_train+n_val]
        test_ids  = scenario_ids[n_train+n_val:]
        combined_df[combined_df["scenario_id"].isin(train_ids)].to_hdf(
            cfg.train_h5, key="data", mode="w", format="table")
        combined_df[combined_df["scenario_id"].isin(val_ids)].to_hdf(
            cfg.val_h5,   key="data", mode="w", format="table")
        combined_df[combined_df["scenario_id"].isin(test_ids)].to_hdf(
            cfg.test_h5,  key="data", mode="w", format="table")
        print(f"[MAIN] Macro split: train={len(train_ids)} val={len(val_ids)} test={len(test_ids)} scenarios.")

    # ── Integrity check ──────────────────────────────────────────────────────
    print("\n[CHECK] Running integrity checks...")
    issues = []
    if MACRO_H5.exists():
        try:
            df_check = pd.read_hdf(MACRO_H5, key="data")
            n_scenarios = df_check["scenario_id"].nunique()
            n_rows      = len(df_check)
            n_incident  = df_check["has_incident"].sum()
            n_no_inc    = (df_check["has_incident"] == 0).sum()
            print(f"  Macro HDF5:  {n_rows:,} rows  |  {n_scenarios} scenarios  "
                  f"|  {n_incident} incident rows  |  {n_no_inc} no-incident rows")
            if not args.no_incident_only and n_incident == 0:
                issues.append("No incident rows in macro data!")
            if n_no_inc == 0:
                issues.append("No non-incident rows in macro data!")
            missing_cols = [c for c in ["sim_time","det3_speed_mean","incident_active"] if c not in df_check.columns]
            if missing_cols:
                issues.append(f"Missing macro columns: {missing_cols}")
        except Exception as e:
            issues.append(f"Cannot read macro HDF5: {e}")
    else:
        issues.append("macro HDF5 (all_data.h5) not found!")
    if not args.no_incident_only:
        if MASTER_CSV.exists():
            import csv as _csv2
            with open(MASTER_CSV, newline="", encoding="utf-8") as fh:
                rows_img = list(_csv2.DictReader(fh))
            n_img = len(rows_img)
            n_NI   = sum(1 for r in rows_img if r.get("capture_window") == "NI")
            n_A    = sum(1 for r in rows_img if r.get("capture_window") == "A")
            n_B    = sum(1 for r in rows_img if r.get("capture_window") == "B")
            n_scen = len({r["scenario_id"] for r in rows_img})
            total_label0 = n_NI + n_A
            print(f"  Image CSV:   {n_img} frames  |  {n_scen} scenarios  "
                  f"|  label=0: {total_label0} (NI={n_NI} + pre={n_A})  |  label=1: {n_B}")
            if abs(total_label0 - n_B) > n_scen * 2:
                issues.append(f"Class imbalance: {total_label0} label=0 vs {n_B} label=1")
        else:
            issues.append("master_metadata.csv not found - no images captured?")
    if issues:
        print("  [!] Issues found:")
        for iss in issues:
            print(f"      - {iss}")
    else:
        print("  [OK] All checks passed.")

    if not args.no_incident_only:
        print(f"\n[MAIN] Rebuilding train/val/test split CSVs ...")
        write_split_csvs()

    # ── Overall elapsed time ──────────────────────────────────────────────────
    total_elapsed = time.time() - wall_start
    h, rem = divmod(int(total_elapsed), 3600)
    m, s   = divmod(rem, 60)
    print(f"\n[MAIN] All done.  Dataset root: {DATASET_DIR}")
    print(f"[MAIN] Total wall-clock time: {h:02d}h {m:02d}m {s:02d}s  ({total_elapsed/3600:.2f} hours)")


if __name__ == "__main__":
    main()

