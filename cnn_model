class AIDCNNModel:
    """
    Full training + evaluation wrapper for the temporal CNN.

    Mirrors the structure of model.py's AIDModel for consistency.
    """

    def __init__(
        self,
        n_frames:       int   = N_FRAMES_WINDOW,
        dropout:        float = DROPOUT,
        lr_head:        float = LR_HEAD,
        lr_finetune:    float = LR_FINETUNE,
        batch_size:     int   = BATCH_SIZE,
        phase1_epochs:  int   = PHASE1_EPOCHS,
        num_epochs:     int   = NUM_EPOCHS,
        early_stop_pat: int   = EARLY_STOP_PAT,
        weight_decay:   float = WEIGHT_DECAY,
    ) -> None:
        self.n_frames       = n_frames
        self.dropout        = dropout
        self.lr_head        = lr_head
        self.lr_finetune    = lr_finetune
        self.batch_size     = batch_size
        self.phase1_epochs  = phase1_epochs
        self.num_epochs     = num_epochs
        self.early_stop_pat = early_stop_pat
        self.weight_decay   = weight_decay

        self.model:             Optional[TemporalEfficientNet] = None
        self.device:            torch.device                   = self._pick_device()
        self.decision_threshold: float                         = 0.5
        self.history:           Dict[str, list]                = defaultdict(list)
        self.best_val_loss:     float                          = math.inf
        self.best_val_f1:       float                          = 0.0
        self.train_time_s:      float                          = 0.0

    @staticmethod
    def _pick_device() -> torch.device:
        if torch.cuda.is_available():
            name = torch.cuda.get_device_name(0)
            mem  = torch.cuda.get_device_properties(0).total_memory / 1e9
            print(f"  [DEVICE] GPU: {name}  ({mem:.1f} GB VRAM)")
            return torch.device("cuda")
        print("  [DEVICE] No CUDA — using CPU (training will be slow)")
        return torch.device("cpu")

    # ── Data loading ──────────────────────────────────────────────────────

    @staticmethod
    def _load_scenario_splits() -> Tuple[set, set, set]:
        """
        Read scenario IDs from the pre-split metadata CSVs in the dataset folder.
        train_metadata.csv / val_metadata.csv / test_metadata.csv are written by
        carla_capture.py's write_split_csvs() and already partitioned by scenario.

        Falls back to reading the SUMO HDF5 files if the CSVs are absent, so the
        script works whether you have image data or only macro data.

        Returns (train_ids, val_ids, test_ids) as sets of strings.
        """
        csv_paths = {
            "train": DATASET_DIR / "train_metadata.csv",
            "val":   DATASET_DIR / "val_metadata.csv",
            "test":  DATASET_DIR / "test_metadata.csv",
        }
        h5_paths = {
            "train": cfg.train_h5,
            "val":   cfg.val_h5,
            "test":  cfg.test_h5,
        }

        # Prefer the metadata CSVs (lighter, no h5py needed)
        if all(p.exists() for p in csv_paths.values()):
            print("📂 Loading scenario splits from metadata CSVs...")
            splits = {}
            for name, path in csv_paths.items():
                df  = pd.read_csv(path, usecols=["scenario_id"])
                ids = set(df["scenario_id"].unique())
                splits[name] = ids
                print(f"  {name:5s}: {len(ids):4d} scenarios  ({path.name})")
        else:
            # Fall back to SUMO HDF5 splits
            print("📂 Metadata CSVs not found — loading from SUMO HDF5 splits...")
            splits = {}
            for name, h5_path in h5_paths.items():
                if not Path(h5_path).exists():
                    raise FileNotFoundError(
                        f"{name}.h5 not found at {h5_path}\n"
                        "Run carla_capture.py (or simulation.py) first to generate SUMO data."
                    )
                df  = pd.read_hdf(h5_path, key="data", columns=["scenario_id"])
                ids = set(df["scenario_id"].unique())
                splits[name] = ids
                print(f"  {name:5s}: {len(ids):4d} scenarios")

        # Sanity check: no scenario should appear in more than one split
        overlap_tv = splits["train"] & splits["val"]
        overlap_tt = splits["train"] & splits["test"]
        overlap_vt = splits["val"]   & splits["test"]
        if overlap_tv or overlap_tt or overlap_vt:
            raise RuntimeError(
                f"Scenario leakage detected in splits! "
                f"train∩val={len(overlap_tv)}  "
                f"train∩test={len(overlap_tt)}  "
                f"val∩test={len(overlap_vt)}"
            )
        print("  ✅ No scenario overlap between splits (no leakage).")
        return splits["train"], splits["val"], splits["test"]

    def build_dataloaders(
        self,
        train_ids: set,
        val_ids:   set,
        test_ids:  set,
    ) -> Tuple[DataLoader, DataLoader, DataLoader]:
        """Build train/val/test DataLoaders."""
        print("\n📦 Building datasets...")
        train_ds = AIDWindowDataset(train_ids, "train", n_frames=self.n_frames, augment=True)
        val_ds   = AIDWindowDataset(val_ids,   "val",   n_frames=self.n_frames, augment=False)
        test_ds  = AIDWindowDataset(test_ids,  "test",  n_frames=self.n_frames, augment=False)

        # Compute positive class weight for BCE loss to handle any residual imbalance
        labels = [lbl for _, lbl in train_ds.windows]
        n0 = labels.count(0)
        n1 = labels.count(1)
        # pos_weight = n0/n1 (how many negatives per positive); clip to [0.5, 5]
        pos_w = max(0.5, min(5.0, n0 / max(n1, 1)))
        self._pos_weight = torch.tensor([pos_w], device=self.device)
        print(f"  BCE pos_weight = {pos_w:.2f}  (n0={n0:,} n1={n1:,})")

        num_workers = min(4, os.cpu_count() or 1)
        train_loader = DataLoader(
            train_ds, batch_size=self.batch_size,
            shuffle=True,  num_workers=num_workers, pin_memory=True,
            persistent_workers=num_workers > 0,
        )
        val_loader = DataLoader(
            val_ds,   batch_size=self.batch_size,
            shuffle=False, num_workers=num_workers, pin_memory=True,
            persistent_workers=num_workers > 0,
        )
        test_loader = DataLoader(
            test_ds,  batch_size=self.batch_size,
            shuffle=False, num_workers=num_workers, pin_memory=True,
            persistent_workers=num_workers > 0,
        )
        return train_loader, val_loader, test_loader

    # ── Training ──────────────────────────────────────────────────────────

    def _make_optimizer(self, phase: int) -> torch.optim.Optimizer:
        if phase == 1:
            params = [p for p in self.model.parameters() if p.requires_grad]
            return torch.optim.Adam(params, lr=self.lr_head, weight_decay=self.weight_decay)
        else:
            # Differential LR: lower for backbone, higher for head
            backbone_params = list(self.model.features.parameters()) + \
                              list(self.model.avgpool.parameters())
            head_params     = list(self.model.head.parameters())
            return torch.optim.Adam([
                {"params": [p for p in backbone_params if p.requires_grad],
                 "lr": self.lr_finetune},
                {"params": head_params,
                 "lr": self.lr_finetune * 5},
            ], weight_decay=self.weight_decay)

    def _run_epoch(
        self,
        loader:    DataLoader,
        optimizer: Optional[torch.optim.Optimizer],
        training:  bool,
    ) -> Tuple[float, float]:
        """Run one epoch. Returns (avg_loss, f1_score)."""
        self.model.train(training)
        criterion = nn.BCEWithLogitsLoss(pos_weight=self._pos_weight)
        total_loss, all_preds, all_labels = 0.0, [], []

        with torch.set_grad_enabled(training):
            for frames, labels in loader:
                frames = frames.to(self.device, non_blocking=True)
                labels = labels.to(self.device, non_blocking=True)

                if training:
                    optimizer.zero_grad()

                logits = self.model(frames)
                loss   = criterion(logits, labels)

                if training:
                    loss.backward()
                    nn.utils.clip_grad_norm_(self.model.parameters(), max_norm=1.0)
                    optimizer.step()

                total_loss += loss.item() * len(labels)
                probs = torch.sigmoid(logits).detach().cpu().numpy()
                all_preds.extend((probs >= 0.5).astype(int).tolist())
                all_labels.extend(labels.cpu().numpy().astype(int).tolist())

        avg_loss = total_loss / max(len(loader.dataset), 1)
        ep_f1    = f1_score(all_labels, all_preds, zero_division=0)
        return avg_loss, ep_f1

    def train(
        self,
        train_loader: DataLoader,
        val_loader:   DataLoader,
        tag:          str = "",
    ) -> None:
        """
        Full two-phase training loop with early stopping.

        Phase 1 (phase1_epochs):   backbone frozen, head trains from scratch.
        Phase 2 (remaining epochs): last 3 backbone blocks unfrozen, fine-tuned.
        """
        print("\n" + "=" * 60)
        print(f"  CNN TRAINING  {tag}")
        print("=" * 60)

        self.model = TemporalEfficientNet(dropout=self.dropout, n_frames=self.n_frames)
        self.model.to(self.device)

        # ── Phase 1: frozen backbone ──────────────────────────────────────
        print(f"\n── Phase 1: frozen backbone  ({self.phase1_epochs} epochs) ──")
        self.model.freeze_backbone()
        opt1  = self._make_optimizer(phase=1)
        sched1 = ReduceLROnPlateau(opt1, mode="min", factor=0.5, patience=2, verbose=True)

        best_ckpt  = CNN_MODELS / f"best{'_' + tag if tag else ''}.pt"
        no_improve = 0

        t0 = time.time()
        for epoch in range(1, self.phase1_epochs + 1):
            tr_loss, tr_f1 = self._run_epoch(train_loader, opt1, training=True)
            vl_loss, vl_f1 = self._run_epoch(val_loader,   None,  training=False)
            sched1.step(vl_loss)
            self._log_epoch("P1", epoch, tr_loss, tr_f1, vl_loss, vl_f1)

            if vl_loss < self.best_val_loss:
                self.best_val_loss = vl_loss
                self.best_val_f1   = vl_f1
                torch.save(self.model.state_dict(), best_ckpt)
                no_improve = 0
            else:
                no_improve += 1
                if no_improve >= self.early_stop_pat:
                    print(f"  [EARLY STOP] Phase 1 epoch {epoch} — "
                          f"no val improvement for {self.early_stop_pat} epochs.")
                    break

        # ── Phase 2: fine-tune last backbone blocks ───────────────────────
        remaining_epochs = self.num_epochs - self.phase1_epochs
        if remaining_epochs > 0:
            print(f"\n── Phase 2: fine-tune backbone  (up to {remaining_epochs} epochs) ──")
            # Load best phase-1 weights before fine-tuning
            self.model.load_state_dict(
                torch.load(best_ckpt, map_location=self.device, weights_only=True)
            )
            self.model.unfreeze_last_blocks(n_blocks=3)
            opt2   = self._make_optimizer(phase=2)
            sched2 = ReduceLROnPlateau(opt2, mode="min", factor=0.5, patience=2, verbose=True)
            no_improve = 0

            for epoch in range(1, remaining_epochs + 1):
                tr_loss, tr_f1 = self._run_epoch(train_loader, opt2, training=True)
                vl_loss, vl_f1 = self._run_epoch(val_loader,   None,  training=False)
                sched2.step(vl_loss)
                self._log_epoch("P2", epoch, tr_loss, tr_f1, vl_loss, vl_f1)

                if vl_loss < self.best_val_loss:
                    self.best_val_loss = vl_loss
                    self.best_val_f1   = vl_f1
                    torch.save(self.model.state_dict(), best_ckpt)
                    no_improve = 0
                else:
                    no_improve += 1
                    if no_improve >= self.early_stop_pat:
                        print(f"  [EARLY STOP] Phase 2 epoch {epoch} — "
                              f"no val improvement for {self.early_stop_pat} epochs.")
                        break

        self.train_time_s = time.time() - t0
        print(f"\n  Total training time: {self.train_time_s/60:.1f} min")
        print(f"  Best val loss: {self.best_val_loss:.4f}   best val F1: {self.best_val_f1:.4f}")

        # Load best checkpoint for downstream evaluation
        self.model.load_state_dict(torch.load(best_ckpt, map_location=self.device))
        print(f"  Best checkpoint loaded from {best_ckpt.name}")

    def _log_epoch(
        self, phase: str, epoch: int,
        tr_loss: float, tr_f1: float,
        vl_loss: float, vl_f1: float,
    ) -> None:
        self.history["phase"].append(phase)
        self.history["epoch"].append(epoch)
        self.history["train_loss"].append(tr_loss)
        self.history["train_f1"].append(tr_f1)
        self.history["val_loss"].append(vl_loss)
        self.history["val_f1"].append(vl_f1)
        star = " ★" if vl_loss <= self.best_val_loss else ""
        print(
            f"  [{phase}] Epoch {epoch:3d}  "
            f"train_loss={tr_loss:.4f} f1={tr_f1:.3f}  |  "
            f"val_loss={vl_loss:.4f} f1={vl_f1:.3f}{star}"
        )

    # ── Threshold selection (mirrors model.py) ────────────────────────────

    def select_decision_threshold(self, val_loader: DataLoader) -> None:
        """
        Select decision threshold from validation set.
        Criterion: maximise TPR subject to FAR ≤ 0.01%.
        Mirrors the same logic used in model.py for comparability.
        """
        print("\n🎯 Selecting decision threshold from validation set...")
        all_probs, all_labels = self._predict_proba(val_loader)
        fpr, tpr, thresholds = roc_curve(all_labels, all_probs)
        max_far = 0.0001
        valid   = fpr <= max_far

        if not np.any(valid):
            print("  ⚠️  No threshold satisfies FAR ≤ 0.01% — using 0.5")
            self.decision_threshold = 0.5
            return

        best_idx                 = np.argmax(tpr[valid])
        self.decision_threshold  = float(thresholds[valid][best_idx])
        print(f"  ✅ threshold={self.decision_threshold:.3f}  "
              f"FAR={fpr[valid][best_idx]*100:.3f}%  "
              f"Recall={tpr[valid][best_idx]*100:.1f}%")

    # ── Inference helpers ─────────────────────────────────────────────────

    @torch.no_grad()
    def _predict_proba(
        self, loader: DataLoader
    ) -> Tuple[np.ndarray, np.ndarray]:
        """Return (probabilities, true_labels) arrays for a DataLoader."""
        self.model.eval()
        # In eval, we do NOT want gradient checkpointing (no_grad is enough)
        self.model._finetune_mode = False
        all_probs, all_labels = [], []
        for frames, labels in loader:
            frames = frames.to(self.device, non_blocking=True)
            logits = self.model(frames)
            probs  = torch.sigmoid(logits).cpu().numpy()
            all_probs.extend(probs.tolist())
            all_labels.extend(labels.numpy().astype(int).tolist())
        return np.array(all_probs), np.array(all_labels)

    # ── Evaluation ────────────────────────────────────────────────────────

    def evaluate(
        self,
        loader:     DataLoader,
        split_name: str = "test",
        save_plots: bool = True,
    ) -> Dict[str, float]:
        """
        Full evaluation on a DataLoader. Returns metrics dict.
        Mirrors model.py's evaluate() structure.
        """
        print(f"\n{'='*60}")
        print(f"  EVALUATION — {split_name.upper()} SET")
        print(f"{'='*60}")

        all_probs, y_true = self._predict_proba(loader)
        y_pred            = (all_probs >= self.decision_threshold).astype(int)

        acc  = accuracy_score(y_true, y_pred)
        prec = precision_score(y_true, y_pred, zero_division=0)
        rec  = recall_score(y_true, y_pred, zero_division=0)
        f1   = f1_score(y_true, y_pred, zero_division=0)
        auc  = roc_auc_score(y_true, all_probs)
        cm   = confusion_matrix(y_true, y_pred)

        print(f"\n  Threshold : {self.decision_threshold:.3f}")
        print(f"  Accuracy  : {acc:.4f}")
        print(f"  Precision : {prec:.4f}")
        print(f"  Recall    : {rec:.4f}")
        print(f"  F1-score  : {f1:.4f}")
        print(f"  ROC-AUC   : {auc:.4f}")
        print(f"\n  Confusion matrix:")
        print(f"    TN={cm[0,0]:5d}  FP={cm[0,1]:5d}")
        print(f"    FN={cm[1,0]:5d}  TP={cm[1,1]:5d}")
        print(f"\n{classification_report(y_true, y_pred, target_names=['no-incident','incident'])}")

        metrics = dict(
            split=split_name, accuracy=acc, precision=prec,
            recall=rec, f1=f1, auc=auc,
            tn=int(cm[0,0]), fp=int(cm[0,1]),
            fn=int(cm[1,0]), tp=int(cm[1,1]),
        )

        if save_plots:
            self._plot_confusion_matrix(cm, split_name)
            self._plot_roc_curve(y_true, all_probs, auc, split_name)
            if self.history["train_loss"]:
                self._plot_training_history()

        return metrics

    def evaluate_per_scenario(
        self,
        loader:         DataLoader,
        dataset:        AIDWindowDataset,
        split_name:     str,
        min_confirmed:  int = 3,
    ) -> pd.DataFrame:
        """
        Scenario-level metrics: one detection decision per scenario.
        Mirrors model.py's evaluate_per_scenario().
        """
        all_probs, _ = self._predict_proba(loader)
        y_pred        = (all_probs >= self.decision_threshold).astype(int)

        # Map window index → (scenario_id, label of last frame)
        results = []
        # Group windows by scenario
        scenario_windows: Dict[str, List[Tuple[int, int, float]]] = defaultdict(list)
        for i, (paths, label) in enumerate(dataset.windows):
            # scenario_id is the parent folder name, extractable from first path
            scen_id = Path(paths[0]).parts[-3]   # …/dataset/sXXXXX/images/frame_…
            scenario_windows[scen_id].append((i, label, float(all_probs[i])))

        for scen_id, windows_in_scen in scenario_windows.items():
            idxs   = [w[0] for w in windows_in_scen]
            labels = [w[1] for w in windows_in_scen]
            probas = [w[2] for w in windows_in_scen]
            preds  = y_pred[idxs]

            has_incident  = int(max(labels))
            n_detections  = int(preds.sum())
            detected      = n_detections >= min_confirmed

            # Time-to-detection (window index × stride × 0.5s per frame)
            ttd = None
            if has_incident and detected:
                first_det_window = np.where(preds == 1)[0][0]
                # Find first window where label=1 first appears
                first_inc_window = next((j for j, lbl in enumerate(labels) if lbl == 1), None)
                if first_inc_window is not None:
                    ttd = (first_det_window - first_inc_window) * WINDOW_STRIDE * 0.5

            results.append({
                "scenario_id":     scen_id,
                "has_incident":    has_incident,
                "detected":        int(detected),
                "n_windows":       len(windows_in_scen),
                "n_detections":    n_detections,
                "max_prob":        float(max(probas)),
                "time_to_detect":  ttd,
            })

        df = pd.DataFrame(results)
        tp = int(((df.has_incident == 1) & (df.detected == 1)).sum())
        fn = int(((df.has_incident == 1) & (df.detected == 0)).sum())
        fp = int(((df.has_incident == 0) & (df.detected == 1)).sum())
        tn = int(((df.has_incident == 0) & (df.detected == 0)).sum())
        dr  = tp / max(tp + fn, 1)
        far = fp / max(fp + tn, 1)

        print(f"\n📊 SCENARIO-LEVEL — {split_name.upper()}")
        print(f"  TP={tp}  FN={fn}  FP={fp}  TN={tn}")
        print(f"  Detection Rate : {dr:.2%}")
        print(f"  False Alarm Rate: {far:.2%}")
        if df["time_to_detect"].notna().any():
            median_ttd = df["time_to_detect"].median()
            print(f"  Median Time-to-Detection: {median_ttd:.1f}s")

        df.to_csv(CNN_RESULTS / f"scenario_eval_{split_name}.csv", index=False)
        return df

    # ── Plotting ──────────────────────────────────────────────────────────

    def _plot_training_history(self) -> None:
        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 4))
        epochs = list(range(1, len(self.history["train_loss"]) + 1))
        ax1.plot(epochs, self.history["train_loss"], label="Train")
        ax1.plot(epochs, self.history["val_loss"],   label="Val")
        ax1.set_title("Loss")
        ax1.set_xlabel("Epoch")
        ax1.legend()
        ax1.grid(alpha=0.3)
        ax2.plot(epochs, self.history["train_f1"], label="Train")
        ax2.plot(epochs, self.history["val_f1"],   label="Val")
        ax2.set_title("F1-score")
        ax2.set_xlabel("Epoch")
        ax2.legend()
        ax2.grid(alpha=0.3)
        plt.tight_layout()
        plt.savefig(CNN_RESULTS / "training_history.png", dpi=150)
        plt.close()
        print(f"  💾 Training history saved.")

    def _plot_confusion_matrix(self, cm: np.ndarray, split_name: str) -> None:
        import seaborn as sns
        plt.figure(figsize=(5, 4))
        sns.heatmap(
            cm, annot=True, fmt="d", cmap="Blues",
            xticklabels=["No incident", "Incident"],
            yticklabels=["No incident", "Incident"],
        )
        plt.ylabel("True"); plt.xlabel("Predicted")
        plt.title(f"Confusion Matrix — {split_name}")
        plt.tight_layout()
        plt.savefig(CNN_RESULTS / f"confusion_matrix_{split_name}.png", dpi=150)
        plt.close()

    def _plot_roc_curve(
        self, y_true: np.ndarray, probs: np.ndarray,
        auc: float, split_name: str,
    ) -> None:
        fpr, tpr, _ = roc_curve(y_true, probs)
        plt.figure(figsize=(6, 5))
        plt.plot(fpr, tpr, label=f"AUC = {auc:.4f}")
        plt.plot([0, 1], [0, 1], "k--", alpha=0.4)
        plt.xlabel("False Positive Rate")
        plt.ylabel("True Positive Rate")
        plt.title(f"ROC Curve — {split_name}")
        plt.legend()
        plt.grid(alpha=0.3)
        plt.tight_layout()
        plt.savefig(CNN_RESULTS / f"roc_curve_{split_name}.png", dpi=150)
        plt.close()

    # ── Save / load ───────────────────────────────────────────────────────

    def save(self, tag: str = "") -> None:
        suffix = f"_{tag}" if tag else ""
        model_path = CNN_MODELS / f"cnn_model{suffix}.pt"
        meta_path  = CNN_MODELS / f"cnn_meta{suffix}.json"

        torch.save(self.model.state_dict(), model_path)
        meta = {
            "n_frames":          self.n_frames,
            "dropout":           self.dropout,
            "lr_head":           self.lr_head,
            "lr_finetune":       self.lr_finetune,
            "batch_size":        self.batch_size,
            "decision_threshold":self.decision_threshold,
            "best_val_loss":     self.best_val_loss,
            "best_val_f1":       self.best_val_f1,
            "train_time_s":      self.train_time_s,
            "image_size":        IMAGE_SIZE,
            "window_size":       WINDOW_SIZE,
            "window_stride":     WINDOW_STRIDE,
            "norm_mean":         NORM_MEAN,
            "norm_std":          NORM_STD,
        }
        with open(meta_path, "w") as f:
            json.dump(meta, f, indent=2)
        print(f"  💾 Model saved → {model_path.name}")
        print(f"  💾 Metadata saved → {meta_path.name}")

    def load(self, tag: str = "") -> None:
        suffix     = f"_{tag}" if tag else ""
        model_path = CNN_MODELS / f"cnn_model{suffix}.pt"
        meta_path  = CNN_MODELS / f"cnn_meta{suffix}.json"
        with open(meta_path) as f:
            meta = json.load(f)
        self.n_frames            = meta["n_frames"]
        self.dropout             = meta["dropout"]
        self.decision_threshold  = meta["decision_threshold"]
        self.model = TemporalEfficientNet(
            dropout=self.dropout, n_frames=self.n_frames
        )
        self.model.load_state_dict(
            torch.load(model_path, map_location=self.device, weights_only=True)
        )
        self.model.to(self.device)
        print(f"  ✅ CNN model loaded from {model_path.name}")
        print(f"     threshold={self.decision_threshold:.3f}  "
              f"n_frames={self.n_frames}  best_val_f1={meta['best_val_f1']:.4f}")


