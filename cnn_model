# Hyperparameter search
# ============================================================================

def run_hp_search(
    train_loader: DataLoader,
    val_loader:   DataLoader,
    train_ids: set, val_ids: set, test_ids: set,
) -> Dict:
    """
    Grid search over HP_GRID combinations.
    Each combination is trained for phase1_epochs only (frozen backbone)
    to quickly estimate val F1, then the best is fully trained.
    """
    print("\n" + "="*60)
    print("  HYPERPARAMETER SEARCH")
    print("="*60)

    from itertools import product
    keys   = list(HP_GRID.keys())
    values = list(HP_GRID.values())
    combos = list(product(*values))

    print(f"  Searching {len(combos)} combinations × {PHASE1_EPOCHS} epochs each ...")
    results = []

    for i, combo in enumerate(combos, 1):
        hp = dict(zip(keys, combo))
        tag = f"hp{i}"
        print(f"\n── Combo {i}/{len(combos)}: {hp} ──")

        # Build fresh dataloaders with the n_frames for this combo
        nf = hp.get("n_frames", N_FRAMES_WINDOW)
        tr_ds = AIDWindowDataset(train_ids, "train", n_frames=nf, augment=True)
        vl_ds = AIDWindowDataset(val_ids,   "val",   n_frames=nf, augment=False)
        nw    = min(4, os.cpu_count() or 1)
        tr_ld = DataLoader(tr_ds, batch_size=BATCH_SIZE, shuffle=True,
                           num_workers=nw, pin_memory=True)
        vl_ld = DataLoader(vl_ds, batch_size=BATCH_SIZE, shuffle=False,
                           num_workers=nw, pin_memory=True)

        m = AIDCNNModel(
            n_frames=nf,
            dropout=hp.get("dropout", DROPOUT),
            lr_head=hp.get("lr_head", LR_HEAD),
            phase1_epochs=PHASE1_EPOCHS,
            num_epochs=PHASE1_EPOCHS,   # phase 1 only for HP search
        )
        m.train(tr_ld, vl_ld, tag=tag)
        hp["val_f1"]   = m.best_val_f1
        hp["val_loss"] = m.best_val_loss
        results.append(hp.copy())
        print(f"  → val_f1={m.best_val_f1:.4f}  val_loss={m.best_val_loss:.4f}")

        # Free GPU memory between combos
        del m
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    results_df = pd.DataFrame(results).sort_values("val_f1", ascending=False)
    print(f"\n{'='*60}")
    print("  HP SEARCH RESULTS (sorted by val F1)")
    print(results_df.to_string(index=False))
    results_df.to_csv(CNN_RESULTS / "hp_search_results.csv", index=False)

    best = results_df.iloc[0].to_dict()
    print(f"\n  🏆 Best combo: {best}")
    return best


# ============================================================================
# Main pipeline
# ============================================================================

def train_and_evaluate(
    hp_search:     bool = False,
    phase1_only:   bool = False,
    evaluate_only: bool = False,
) -> None:
    print("\n" + "="*60)
    print("  AUTOMATIC INCIDENT DETECTION — CNN TRAINING")
    print("="*60 + "\n")

    # ── 1. Load scenario splits from SUMO HDF5 ────────────────────────────
    train_ids, val_ids, test_ids = AIDCNNModel._load_scenario_splits()

    # ── 2. (Optional) Hyperparameter search ──────────────────────────────
    best_hp = {}
    if hp_search and not evaluate_only:
        # Need dataloaders for search — use defaults, per-combo rebuilt inside
        best_hp = run_hp_search(None, None, train_ids, val_ids, test_ids)
        # Clean GPU
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    # ── 3. Build final model with best (or default) HPs ──────────────────
    n_frames = int(best_hp.get("n_frames",  N_FRAMES_WINDOW))
    dropout  = float(best_hp.get("dropout", DROPOUT))
    lr_head  = float(best_hp.get("lr_head", LR_HEAD))

    cnn = AIDCNNModel(
        n_frames       = n_frames,
        dropout        = dropout,
        lr_head        = lr_head,
        lr_finetune    = LR_FINETUNE,
        batch_size     = BATCH_SIZE,
        phase1_epochs  = PHASE1_EPOCHS,
        num_epochs     = PHASE1_EPOCHS if phase1_only else NUM_EPOCHS,
        early_stop_pat = EARLY_STOP_PAT,
    )

    if evaluate_only:
        cnn.load()
        # Still need dataloaders for evaluation
        _, val_loader, test_loader = cnn.build_dataloaders(train_ids, val_ids, test_ids)
        val_ds  = val_loader.dataset
        test_ds = test_loader.dataset
    else:
        # ── 4. Build dataloaders ─────────────────────────────────────────
        train_loader, val_loader, test_loader = cnn.build_dataloaders(
            train_ids, val_ids, test_ids
        )
        val_ds  = val_loader.dataset
        test_ds = test_loader.dataset

        # ── 5. Train ─────────────────────────────────────────────────────
        cnn.train(train_loader, val_loader, tag="final")

        # ── 6. Select threshold from validation set ──────────────────────
        cnn.select_decision_threshold(val_loader)

        # ── 7. Save ───────────────────────────────────────────────────────
        print(f"\n{'='*60}  SAVING")
        cnn.save(tag="final")

        # ── 8. Validation set evaluation ─────────────────────────────────
        val_metrics = cnn.evaluate(val_loader, split_name="val", save_plots=True)
        cnn.evaluate_per_scenario(val_loader, val_ds, split_name="val")

    # ── 9. Test set evaluation ────────────────────────────────────────────
    print(f"\n{'='*60}")
    print("  FINAL TEST SET EVALUATION")
    print("="*60)
    test_metrics = cnn.evaluate(test_loader, split_name="test", save_plots=True)
    cnn.evaluate_per_scenario(test_loader, test_ds, split_name="test")

    # ── 10. Save final metrics JSON ───────────────────────────────────────
    metrics_path = CNN_RESULTS / "test_metrics.json"
    with open(metrics_path, "w") as f:
        json.dump(test_metrics, f, indent=2)
    print(f"\n  💾 Test metrics → {metrics_path}")

    # ── 11. Summary ───────────────────────────────────────────────────────
    print(f"\n{'='*60}")
    print("  ✅ CNN TRAINING AND EVALUATION COMPLETE")
    print("="*60)
    print(f"  Results folder : {CNN_RESULTS}")
    print(f"  Model folder   : {CNN_MODELS}")
    print(f"\n  Compare with Random Forest results in:")
    print(f"    {_PROJECT / 'results'}")
    print(f"\n  Test F1   : {test_metrics['f1']:.4f}")
    print(f"  Test AUC  : {test_metrics['auc']:.4f}")
    print(f"  Test Rec  : {test_metrics['recall']:.4f}")


