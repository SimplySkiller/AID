if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="CNN training and evaluation for AID image dataset."
    )
    parser.add_argument(
        "--hp-search", action="store_true",
        help="Run hyperparameter grid search before final training.",
    )
    parser.add_argument(
        "--phase1-only", action="store_true",
        help="Only run phase 1 (frozen backbone). Faster; useful for quick validation.",
    )
    parser.add_argument(
        "--evaluate-only", action="store_true",
        help="Skip training; load saved model and run test-set evaluation.",
    )
    args = parser.parse_args()

    train_and_evaluate(
        hp_search     = args.hp_search,
        phase1_only   = args.phase1_only,
        evaluate_only = args.evaluate_only,
    )
