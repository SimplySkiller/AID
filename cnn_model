# ============================================================================
# Camera mask (removes sky / road-shoulder triangles)
# ============================================================================

class TriangleMask:
    """
    PIL transform that blacks-out the two sky/shoulder triangles in each frame.

    Coordinates are for the native 384×640 camera output.  Apply BEFORE the
    Resize so the mask is always pixel-accurate regardless of target image size.

    Triangle vertices (taken from mask_crop.py, verified against camera FOV):
      Left  : (0, 421)─(178, 0)─(0, 0)      top-left  corner (sky + shoulder)
      Right : (383, 437)─(203, 0)─(383, 0)   top-right corner (sky + shoulder)

    The mask is computed once at class load time and reused for every image,
    so there is no per-image overhead from polygon rasterisation.
    """

    # Native camera resolution (must match carla_capture.py CAM_IMAGE_X/Y)
    _W, _H = 384, 640

    # Pre-rasterise the mask once at class definition time
    _mask: "np.ndarray"   # (H, W) bool — True where pixels should be zeroed

    @classmethod
    def _build_mask(cls) -> np.ndarray:
        from PIL import Image as _Image, ImageDraw as _Draw
        m = _Image.new("L", (cls._W, cls._H), 0)
        d = _Draw.Draw(m)
        d.polygon([(0, 421), (178, 0), (0, 0)],       fill=255)
        d.polygon([(383, 437), (203, 0), (383, 0)],    fill=255)
        return np.array(m, dtype=bool)   # True = mask out

    def __call__(self, img: "Image.Image") -> "Image.Image":
        """Apply mask to a PIL Image in native resolution."""
        arr  = np.array(img)                    # (H, W, 3)
        arr[self._mask] = 0                     # black out masked pixels
        return Image.fromarray(arr)


# Build the shared mask array once at import time (negligible cost)
TriangleMask._mask = TriangleMask._build_mask()


# ============================================================================
# Dataset
# ============================================================================

class AIDWindowDataset(Dataset):
    """
    Sliding-window dataset over per-scenario image sequences.

    Each sample is a tuple (frames_tensor, label) where:
      frames_tensor : float32 tensor [N_FRAMES_WINDOW, 3, IMAGE_SIZE, IMAGE_SIZE]
      label         : int (0 or 1), label of the LAST frame in the window

    Construction
    ------------
    1.  Load master_metadata.csv and keep only rows belonging to the given
        scenario_id set (enforced from the SUMO HDF5 split).
    2.  For each scenario, sort frames by frame_id and build windows:
            window k = frames[k*stride : k*stride + WINDOW_SIZE]
        Discard any window shorter than WINDOW_SIZE (tail of sequence).
    3.  From each 60-frame window uniformly sample N_FRAMES_WINDOW indices.
    4.  Label = label of the last frame (index WINDOW_SIZE-1) of the window.

    No-leakage guarantee
    --------------------
    Scenario_ids are partitioned BEFORE constructing windows, so no window
    can include frames from two different scenarios or split sets.
    """

    def __init__(
        self,
        scenario_ids: set,
        split_name:   str,
        n_frames:     int   = N_FRAMES_WINDOW,
        window_size:  int   = WINDOW_SIZE,
        stride:       int   = WINDOW_STRIDE,
        augment:      bool  = False,
    ) -> None:
        self.n_frames    = n_frames
        self.window_size = window_size
        self.augment     = augment

        # ── Load metadata ──────────────────────────────────────────────────
        if not MASTER_CSV.exists():
            raise FileNotFoundError(
                f"master_metadata.csv not found at {MASTER_CSV}\n"
                "Run carla_capture.py first to generate the dataset."
            )
        meta = pd.read_csv(MASTER_CSV)
        # Keep only scenarios in this split
        meta = meta[meta["scenario_id"].isin(scenario_ids)].copy()

        if meta.empty:
            raise ValueError(
                f"No metadata rows found for {split_name} split "
                f"({len(scenario_ids)} scenario IDs). "
                "Check that master_metadata.csv and the SUMO HDF5 splits match."
            )

        # ── Build windows ──────────────────────────────────────────────────
        self.windows: List[Tuple[List[str], int]] = []   # (img_path_list, label)
        skipped_short = 0

        for scen_id, grp in meta.groupby("scenario_id"):
            grp = grp.sort_values("frame_id").reset_index(drop=True)
            n   = len(grp)

            for start in range(0, n - window_size + 1, stride):
                end   = start + window_size
                chunk = grp.iloc[start:end]
                # Uniformly sample n_frames indices from the window
                sample_idx = np.linspace(0, window_size - 1, n_frames, dtype=int)
                paths  = [
                    str(DATASET_DIR / scen_id / "images" / chunk.iloc[i]["filename"])
                    for i in sample_idx
                ]
                label  = int(chunk.iloc[-1]["incident_label"])
                self.windows.append((paths, label))

            remaining = (n - window_size) % stride if n >= window_size else 0
            if n < window_size:
                skipped_short += 1

        n0 = sum(1 for _, lbl in self.windows if lbl == 0)
        n1 = sum(1 for _, lbl in self.windows if lbl == 1)
        print(f"  [{split_name}] {len(self.windows):,} windows  "
              f"({n0:,} label=0  {n1:,} label=1)  "
              f"from {meta['scenario_id'].nunique()} scenarios"
              + (f"  (skipped {skipped_short} short sequences)" if skipped_short else ""))

        # ── Image transforms ───────────────────────────────────────────────
        # TriangleMask is applied first (on native 384×640) so the mask
        # coordinates stay exact before any resize.
        if augment:
            self.transform = transforms.Compose([
                TriangleMask(),
                transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
                transforms.RandomHorizontalFlip(p=0.0),   # horizontal flip OFF
                # (horizontal flip would invert lane geometry — avoid for traffic)
                transforms.ColorJitter(
                    brightness=0.2, contrast=0.2, saturation=0.1, hue=0.0
                ),
                transforms.RandomGrayscale(p=0.05),       # occasional B&W
                transforms.ToTensor(),
                transforms.Normalize(NORM_MEAN, NORM_STD),
            ])
        else:
            self.transform = transforms.Compose([
                TriangleMask(),
                transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
                transforms.ToTensor(),
                transforms.Normalize(NORM_MEAN, NORM_STD),
            ])

    def __len__(self) -> int:
        return len(self.windows)

    def __getitem__(self, idx: int):
        paths, label = self.windows[idx]
        frames = []
        for p in paths:
            img = Image.open(p).convert("RGB")
            frames.append(self.transform(img))
        # Stack into [N_FRAMES, C, H, W]
        frames_tensor = torch.stack(frames)
        return frames_tensor, torch.tensor(label, dtype=torch.float32)


# ============================================================================
# Model
# ============================================================================

class TemporalEfficientNet(nn.Module):
    """
    EfficientNet-B0 backbone with per-frame feature extraction and
    temporal mean-pooling aggregation.

    Forward pass
    ------------
    Input  : [batch, n_frames, 3, H, W]
    Step 1 : Flatten to [batch*n_frames, 3, H, W]
    Step 2 : EfficientNet-B0 feature extractor  → [batch*n_frames, 1280]
    Step 3 : Reshape to [batch, n_frames, 1280]
    Step 4 : Mean pool over frame axis           → [batch, 1280]
    Step 5 : Dropout → Linear(1280, 256) → ReLU → Dropout → Linear(256, 1)
    Output : [batch] raw logit (use with BCEWithLogitsLoss)

    Memory note for GTX 1060 3GB
    -----------------------------
    With backbone frozen (phase 1): activations not stored → ~500 MB peak.
    With fine-tuning (phase 2): gradient checkpointing on backbone blocks
    keeps peak under ~2 GB for batch_size=6, n_frames=8.
    """

    def __init__(self, dropout: float = DROPOUT, n_frames: int = N_FRAMES_WINDOW) -> None:
        super().__init__()
        self.n_frames = n_frames

        # Load pretrained EfficientNet-B0
        weights  = EfficientNet_B0_Weights.IMAGENET1K_V1
        backbone = efficientnet_b0(weights=weights)

        # Keep only the feature extractor (drop the classifier head)
        self.features    = backbone.features       # Conv+MBConv blocks → [B,1280,7,7]
        self.avgpool     = backbone.avgpool         # AdaptiveAvgPool2d → [B,1280,1,1]
        feat_dim         = 1280

        # Classification head
        self.head = nn.Sequential(
            nn.Dropout(p=dropout),
            nn.Linear(feat_dim, 256),
            nn.ReLU(inplace=True),
            nn.Dropout(p=dropout / 2),
            nn.Linear(256, 1),
        )

        # Phase flags (set externally by trainer)
        self._finetune_mode = False

    # ── Backbone freeze / unfreeze ─────────────────────────────────────────

    def freeze_backbone(self) -> None:
        """Phase 1: only the head trains."""
        for p in self.features.parameters():
            p.requires_grad = False
        for p in self.avgpool.parameters():
            p.requires_grad = False
        self._finetune_mode = False
        print("  [MODEL] Backbone frozen — training head only.")

    def unfreeze_last_blocks(self, n_blocks: int = 3) -> None:
        """Phase 2: unfreeze the last n MBConv blocks + head for fine-tuning."""
        # features is an nn.Sequential; blocks are roughly indices 0..8
        # Unfreeze from the end
        modules = list(self.features.children())
        for mod in modules[:-n_blocks]:
            for p in mod.parameters():
                p.requires_grad = False
        for mod in modules[-n_blocks:]:
            for p in mod.parameters():
                p.requires_grad = True
        for p in self.avgpool.parameters():
            p.requires_grad = True
        self._finetune_mode = True
        trainable = sum(p.numel() for p in self.parameters() if p.requires_grad)
        total     = sum(p.numel() for p in self.parameters())
        print(f"  [MODEL] Unfroze last {n_blocks} backbone blocks "
              f"({trainable:,}/{total:,} params trainable).")

    # ── Forward ───────────────────────────────────────────────────────────

    def _extract(self, x: torch.Tensor) -> torch.Tensor:
        """Extract 1280-d feature for a batch of images [B, C, H, W]."""
        feat = self.features(x)
        feat = self.avgpool(feat)
        return feat.flatten(1)            # [B, 1280]

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        # x: [batch, n_frames, C, H, W]
        B, T, C, H, W = x.shape

        if self._finetune_mode:
            # Gradient checkpointing to save VRAM during fine-tuning
            x_flat = x.view(B * T, C, H, W)
            feat   = torch.utils.checkpoint.checkpoint(self._extract, x_flat)
        else:
            with torch.no_grad():
                x_flat = x.view(B * T, C, H, W)
                feat   = self._extract(x_flat)

        feat = feat.view(B, T, -1)         # [B, T, 1280]
        feat = feat.mean(dim=1)            # [B, 1280] — temporal mean pool
        return self.head(feat).squeeze(1)  # [B]


