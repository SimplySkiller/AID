def indent(elem, level=0):
    """Custom indent for Python < 3.9"""
    i = "\n" + level * "  "
    if len(elem):
        if not elem.text or not elem.text.strip():
            elem.text = i + "  "
        if not elem.tail or not elem.tail.strip():
            elem.tail = i
        for sub_elem in elem:
            indent(sub_elem, level + 1)
        if not elem.tail or not elem.tail.strip():
            elem.tail = i
    else:
        if level and (not elem.tail or not elem.tail.strip()):
            elem.tail = i


class SUMOSimulator:
    """Manages SUMO simulations and data collection"""

    def __init__(self, gui_mode: bool = False):
        self.gui_mode = gui_mode
        self.sumo_binary = config.sumo_gui_binary if gui_mode else config.sumo_binary
        self.current_step = 0
        self.vehicle_counter = 0
        self.log_data = []
        self.temp_files = []

        self.logging_active = False
        self.first_vehicle_completed = False
        self.baseline_speeds = {}
        self.baseline_occupancies = {}

        if gui_mode:
            import time as _t
            seed_value = int(_t.time() * 1000) % (2**32 - 1)
            random.seed(seed_value)
            np.random.seed(seed_value)
        else:
            random.seed(config.random_state)
            np.random.seed(config.random_state)

        atexit.register(self.cleanup)

    def cleanup(self):
        try:
            if traci.isLoaded():
                traci.close()
        except Exception:
            pass
        for temp_file in self.temp_files:
            try:
                if temp_file.exists():
                    temp_file.unlink()
            except Exception:
                pass

    def generate_route_file(self,
                            flow_total: int,
                            onramp_flow: int,
                            speed_factor_mean: float,
                            output_file: Path) -> None:
        """
        Generate route file for Map 2.

        Map 2 edge sequence (SUMO cartesian x):
          Mainline : before_det1 → det1 → before_det2a → before_det2b →
                     before_det2ba → before_det2bb → before_det2c →
                     det2 → before_det3 → det3 → after_det3
          On-ramp  : onramp_a → 4 → before_det2b → before_det2ba →
                     before_det2bb → before_det2c → det2 → before_det3 →
                     det3 → after_det3

        Lane indices on Map 2 mainline:
          0 = right / slow lane   (directly usable, no remapping needed)
          1 = left  / fast lane
        """
        root = ET.Element("routes")

        # Mainline route — all sub-edges through the merge zone included
        ET.SubElement(root, "route",
                      id="mainline",
                      edges=("before_det1 det1 "
                             "before_det2a before_det2b before_det2ba "
                             "before_det2bb before_det2c "
                             "det2 before_det3 det3 after_det3"))

        # On-ramp route — starts on onramp_a, merges via edge 4 into before_det2b
        ET.SubElement(root, "route",
                      id="onramp",
                      edges=("onramp_a 4 "
                             "before_det2b before_det2ba "
                             "before_det2bb before_det2c "
                             "det2 before_det3 det3 after_det3"))

        mainline_interval = 3600.0 / flow_total if flow_total > 0 else float('inf')
        onramp_interval   = 3600.0 / onramp_flow if onramp_flow > 0 else float('inf')

        max_time    = 6400   # 30 minutes of insertions
        all_vehicles = []

        # ── Mainline vehicles ──────────────────────────────────────────────────
        if flow_total > 0:
            mainline_time   = 0.0
            mainline_veh_id = 0

            # Option G — dampened anchor approach (friend's formula, tuned):
            # SF=1.0 anchored at speed limit. Deviations dampened by 0.30.
            # slow_base=0.82 → 107 km/h at SF=1.0
            # fast_base=1.00 → 130 km/h at SF=1.0 (exactly the speed limit)
            # Resulting means:
            #   SF=0.7 → slow=97, fast=118 km/h
            #   SF=1.0 → slow=107, fast=130 km/h
            #   SF=1.3 → slow=116, fast=142 km/h
            SLOW_LANE_BASE = 0.82
            FAST_LANE_BASE = 1.00
            SF_SENSITIVITY = 0.30
            sf_factor = 1.0 + (speed_factor_mean - 1.0) * SF_SENSITIVITY

            while mainline_time < max_time:
                # Lane 0 = right / slow, lane 1 = left / fast (Map 2 direct indices)
                is_slow_lane = random.random() < config.lane0_preference
                target_lane  = 0 if is_slow_lane else 1

                lane_mean = (SLOW_LANE_BASE if is_slow_lane else FAST_LANE_BASE) * sf_factor
                lane_std  = (config.speed_factor_lane0_std if is_slow_lane
                             else config.speed_factor_lane1_std)

                speed_factor = float(np.clip(
                    np.random.normal(lane_mean, lane_std),
                    config.speed_factor_clip_min,
                    config.speed_factor_clip_max,
                ))
                all_vehicles.append({
                    'depart':      mainline_time,
                    'id':          f"mainline_{mainline_veh_id}",
                    'type':        'car',
                    'route':       'mainline',
                    'departLane':  str(target_lane),
                    'departSpeed': 'max',
                    'speedFactor': f"{speed_factor:.3f}",
                })
                mainline_veh_id += 1
                jitter = random.uniform(config.insertion_jitter_min,
                                        config.insertion_jitter_max)
                mainline_time += mainline_interval * jitter
        else:
            mainline_veh_id = 0

        # ── On-ramp vehicles ───────────────────────────────────────────────────
        onramp_veh_id = 0
        if onramp_flow > 0:
            onramp_time = 0.0
            while onramp_time < max_time:
                speed_factor = float(np.clip(
                    np.random.normal(config.speed_factor_onramp_mean,
                                     config.speed_factor_onramp_std),
                    config.speed_factor_clip_min,
                    config.speed_factor_clip_max,
                ))
                all_vehicles.append({
                    'depart':      onramp_time,
                    'id':          f"onramp_{onramp_veh_id}",
                    'type':        'car',
                    'route':       'onramp',
                    'departLane':  '0',   # single lane on onramp_a
                    'departSpeed': 'max',
                    'speedFactor': f"{speed_factor:.3f}",
                })
                onramp_veh_id += 1
                jitter = random.uniform(config.insertion_jitter_min,
                                        config.insertion_jitter_max)
                onramp_time += onramp_interval * jitter

        # Sort by depart time (critical for SUMO)
        all_vehicles.sort(key=lambda v: v['depart'])

        for veh_data in all_vehicles:
            veh_elem = ET.SubElement(root, "vehicle",
                                     id=veh_data['id'],
                                     type=veh_data['type'],
                                     route=veh_data['route'],
                                     depart=f"{veh_data['depart']:.2f}",
                                     departSpeed=veh_data['departSpeed'])
            veh_elem.set("speedFactor", veh_data['speedFactor'])
            if 'departLane' in veh_data:
                veh_elem.set("departLane", veh_data['departLane'])

        tree = ET.ElementTree(root)
        indent(root)
        tree.write(output_file, encoding="utf-8", xml_declaration=True)
        self.temp_files.append(output_file)

        print(f"  Generated {mainline_veh_id} mainline + {onramp_veh_id} onramp vehicles")
        if all_vehicles:
            print(f"  Vehicles sorted by depart time: "
                  f"first at {all_vehicles[0]['depart']:.2f}s, "
                  f"last at {all_vehicles[-1]['depart']:.2f}s")

    def start_simulation(self, route_file: Path, scenario_id: int = 0) -> None:
        try:
            if traci.isLoaded():
                traci.close()
                time.sleep(0.5)
        except Exception:
            pass

        sumo_cmd = [
            self.sumo_binary,
            "-c", str(config.sumo_cfg_file),
            "--route-files", str(route_file),
            "--step-length", str(config.sim_step_length),
            "--no-warnings", "true",
            "--no-step-log", "true",
            "--time-to-teleport", "-1",
            "--collision.action", "warn",
        ]
        if not self.gui_mode:
            sumo_cmd.append("--start")

        unique_port = 8813 + (scenario_id % 10000)
        traci.start(sumo_cmd, port=unique_port, label=str(scenario_id))
        self.current_step = 0
        self.log_data = []

    def inject_incident(self,
                        position: float,
                        lane: int,
                        current_time: float) -> Optional[Tuple[str, Dict]]:
        """
        Inject an incident by stopping a vehicle completely.
        Edge starts updated for Map 2 geometry.
        """
        # Map 2 edge starts in SUMO cartesian x (from highway2_net.xml shapes)
        edge_starts = {
            "before_det1":   0.0,
            "det1":          1200.0,
            "before_det2a":  1300.0,
            "before_det2b":  1352.1,
            "before_det2ba": 1743.7,
            "before_det2bb": 1745.4,
            "before_det2c":  1754.0,
            "det2":          1800.0,
            "before_det3":   1900.0,
            "det3":          2400.0,
            "after_det3":    2500.0,
        }

        all_vehicles = traci.vehicle.getIDList()
        best_vehicle = None
        min_distance = float('inf')
        best_abs_pos = None

        for veh_id in all_vehicles:
            try:
                veh_edge = traci.vehicle.getRoadID(veh_id)
                veh_lane = traci.vehicle.getLaneIndex(veh_id)
                veh_pos  = traci.vehicle.getLanePosition(veh_id)
                if veh_edge not in edge_starts:
                    continue
                abs_pos  = edge_starts[veh_edge] + veh_pos
                if veh_lane == lane:
                    distance = abs(abs_pos - position)
                    if distance < min_distance:
                        min_distance = distance
                        best_vehicle = veh_id
                        best_abs_pos = abs_pos
            except traci.exceptions.TraCIException:
                continue

        if best_vehicle and min_distance < 100:
            current_speed     = traci.vehicle.getSpeed(best_vehicle)
            current_speed_kmh = current_speed * 3.6
            veh_edge          = traci.vehicle.getRoadID(best_vehicle)

            traci.vehicle.setSpeed(best_vehicle, 0.0)
            traci.vehicle.setLaneChangeMode(best_vehicle, 0)
            traci.vehicle.setColor(best_vehicle, (255, 0, 0, 255))

            if self.gui_mode:
                try:
                    view_id = traci.gui.getIDList()[0] if traci.gui.getIDList() else None
                    if view_id:
                        traci.gui.trackVehicle(view_id, best_vehicle)
                        traci.gui.setZoom(view_id, 2000)
                        time.sleep(0.1)
                        traci.gui.trackVehicle(view_id, "")
                except Exception:
                    pass

            incident_info = {
                'vehicle_id':       best_vehicle,
                'time':             current_time,
                'position':         best_abs_pos,
                'target_position':  position,
                'lane':             lane,
                'edge':             veh_edge,
                'speed_before_kmh': current_speed_kmh,
                'speed_before_ms':  current_speed,
                'speed_after_kmh':  0.0,
                'severity':         1.0,
            }

            if config.show_incident_details and (self.gui_mode or config.debug_mode):
                lane_name = "Right (slow)" if lane == 0 else "Left (fast)"
                print(f"\n{'='*60}")
                print(f"INCIDENT INJECTED")
                print(f"{'='*60}")
                print(f"  Time:        {current_time:.1f}s")
                print(f"  Vehicle ID:  {best_vehicle}")
                print(f"  Location:    {best_abs_pos:.1f}m (target: {position}m)")
                print(f"  Lane:        {lane} ({lane_name})")
                print(f"  Edge:        {veh_edge}")
                print(f"  Speed:       {current_speed_kmh:.1f} km/h → 0.0 km/h")
                print(f"{'='*60}\n")

            return best_vehicle, incident_info

        return None, None

    def collect_detector_data(self, update_baseline: bool = False) -> Dict:
        data = {
            'sim_time': traci.simulation.getTime(),
            'step':     self.current_step,
        }
        for det_edge in config.detector_edges:
            try:
                speed_mean    = traci.edge.getLastStepMeanSpeed(det_edge)
                vehicle_count = traci.edge.getLastStepVehicleNumber(det_edge)
                occupancy     = traci.edge.getLastStepOccupancy(det_edge)
                vehicle_ids   = traci.edge.getLastStepVehicleIDs(det_edge)
                speeds        = [traci.vehicle.getSpeed(v) for v in vehicle_ids]
                speed_std     = float(np.std(speeds))  if speeds else 0.0
                speed_min     = float(np.min(speeds))  if speeds else 0.0

                data[f'{det_edge}_speed_mean']    = speed_mean
                data[f'{det_edge}_speed_std']     = speed_std
                data[f'{det_edge}_speed_min']     = speed_min
                data[f'{det_edge}_flow']          = vehicle_count
                data[f'{det_edge}_occupancy']     = occupancy
                data[f'{det_edge}_vehicle_count'] = vehicle_count

                if update_baseline and speed_mean > 0:
                    self.baseline_speeds[det_edge]      = speed_mean
                    self.baseline_occupancies[det_edge] = occupancy
            except traci.exceptions.TraCIException as e:
                if config.debug_mode:
                    print(f"  Warning: Could not read {det_edge}: {e}")
                data[f'{det_edge}_speed_mean']    = 0.0
                data[f'{det_edge}_speed_std']     = 0.0
                data[f'{det_edge}_speed_min']     = 0.0
                data[f'{det_edge}_flow']          = 0
                data[f'{det_edge}_occupancy']     = 0.0
                data[f'{det_edge}_vehicle_count'] = 0
        return data

    def check_traffic_recovery(self, current_time: float,
                                recovery_start_time: float) -> bool:
        if current_time - recovery_start_time < config.recovery_detection_window:
            return False
        for det_edge in config.detector_edges:
            try:
                current_speed     = traci.edge.getLastStepMeanSpeed(det_edge)
                current_occupancy = traci.edge.getLastStepOccupancy(det_edge)
                baseline_speed    = self.baseline_speeds.get(
                    det_edge, config.speed_limit_ms * 0.9)
                baseline_occupancy = self.baseline_occupancies.get(det_edge, 0.1)
                speed_ok  = current_speed >= (baseline_speed * config.recovery_speed_threshold)
                occ_ok    = current_occupancy <= (baseline_occupancy +
                                                  config.recovery_occupancy_threshold)
                if not (speed_ok and occ_ok):
                    return False
            except traci.exceptions.TraCIException:
                continue
        return True

    def run_scenario(self,
                     flow_total: int,
                     onramp_flow: int,
                     speed_factor_mean: float,
                     has_incident: bool,
                     incident_position: float,
                     scenario_id: int,
                     total_scenarios: int) -> Optional[pd.DataFrame]:
        if config.show_progress:
            incident_str = "WITH" if has_incident else "NO"
            print(f"Scenario {scenario_id}/{config.total_scenarios}: "
                  f"Mainline={flow_total} veh/h, Onramp={onramp_flow} veh/h, "
                  f"Speed={speed_factor_mean:.1f}, {incident_str} incident @ {incident_position}m")
        try:
            route_file = config.base_dir / f"routes_temp_{scenario_id-1}.rou.xml"
            self.generate_route_file(flow_total, onramp_flow, speed_factor_mean, route_file)
            self.start_simulation(route_file, scenario_id)

            self.logging_active          = False
            self.first_vehicle_completed = False
            self.baseline_speeds         = {}
            self.baseline_occupancies    = {}

            incident_injected         = False
            incident_vehicle          = None
            incident_info             = None
            incident_time             = None
            incident_lane             = random.choice(config.incident_lane_distribution)
            incident_cleared_naturally = False
            incident_vehicle_left_map  = False
            recovery_check_start_time  = None
            completed_vehicles         = set()
            all_spawned_vehicles       = set()

            if has_incident:
                incident_time     = random.uniform(config.incident_start_time_min,
                                                   config.incident_start_time_max)
                recovery_duration = random.uniform(900, 1800)
                incident_clear_time = incident_time + recovery_duration

            last_log_time   = 0.0
            last_print_time = 0.0
            steady_state_achieved_time = None

            while True:
                traci.simulationStep()
                self.current_step += 1
                current_time = traci.simulation.getTime()

                if current_time > config.max_simulation_time:
                    if config.debug_mode:
                        print(f"\n  Hard timeout at {current_time:.1f}s")
                    break

                current_vehicles = set(traci.vehicle.getIDList())
                all_spawned_vehicles.update(current_vehicles)
                newly_completed = (all_spawned_vehicles - current_vehicles
                                   - completed_vehicles)
                completed_vehicles.update(newly_completed)

                if not self.first_vehicle_completed and completed_vehicles:
                    self.first_vehicle_completed = True
                    steady_state_achieved_time   = (current_time
                                                    + config.steady_state_buffer_time)

                if (not self.logging_active
                        and self.first_vehicle_completed
                        and steady_state_achieved_time
                        and current_time >= steady_state_achieved_time):
                    self.logging_active = True

                if (config.show_timestep_updates
                        and current_time - last_print_time
                        >= config.timestep_update_interval):
                    print(f"  t={current_time:.1f}s  vehicles={len(current_vehicles)}  "
                          f"{'LOGGING' if self.logging_active else 'PRE-LOG'}", end='\r')
                    last_print_time = current_time

                if (has_incident and not incident_injected
                        and self.logging_active
                        and current_time >= incident_time):
                    incident_vehicle, incident_info = self.inject_incident(
                        incident_position, incident_lane, current_time)
                    if incident_vehicle:
                        incident_injected = True

                if (incident_injected and not incident_cleared_naturally
                        and incident_clear_time
                        and current_time >= incident_clear_time):
                    if incident_vehicle in traci.vehicle.getIDList():
                        original_speed = incident_info['speed_before_ms']
                        traci.vehicle.setSpeed(incident_vehicle, original_speed)
                        traci.vehicle.setLaneChangeMode(incident_vehicle, 597)
                        traci.vehicle.setColor(incident_vehicle, (255, 255, 255, 255))
                        if self.gui_mode:
                            try:
                                view_id = (traci.gui.getIDList()[0]
                                           if traci.gui.getIDList() else None)
                                if view_id:
                                    traci.gui.trackVehicle(view_id, "")
                            except Exception:
                                pass
                        incident_cleared_naturally = True
                        recovery_check_start_time  = current_time

                if (incident_injected and not incident_vehicle_left_map
                        and incident_vehicle not in current_vehicles):
                    incident_vehicle_left_map = True
                    recovery_check_start_time  = current_time

                update_baseline = self.logging_active and not incident_injected
                data_point      = self.collect_detector_data(update_baseline)

                if (self.logging_active
                        and current_time - last_log_time >= config.log_frequency):
                    data_point['scenario_id']      = scenario_id - 1
                    data_point['flow_total']        = flow_total
                    data_point['onramp_flow']       = onramp_flow
                    data_point['speed_factor_mean'] = speed_factor_mean
                    data_point['has_incident']      = 1 if has_incident else 0
                    data_point['incident_position'] = incident_position if has_incident else 0
                    incident_still_active = (incident_injected
                                             and not incident_cleared_naturally
                                             and not incident_vehicle_left_map)
                    data_point['incident_active'] = 1 if incident_still_active else 0
                    self.log_data.append(data_point)
                    last_log_time = current_time

                should_end = False
                if len(current_vehicles) == 0 and all_spawned_vehicles:
                    should_end = True
                elif (has_incident and incident_injected
                      and incident_vehicle_left_map and recovery_check_start_time):
                    if self.check_traffic_recovery(current_time,
                                                   recovery_check_start_time):
                        should_end = True
                elif (has_incident and incident_injected
                      and incident_cleared_naturally and recovery_check_start_time):
                    if self.check_traffic_recovery(current_time,
                                                   recovery_check_start_time):
                        should_end = True
                elif not has_incident and self.logging_active:
                    if current_time - steady_state_achieved_time >= 1650:
                        should_end = True
                        print(f"\n  Non-incident complete: "
                              f"{current_time - steady_state_achieved_time:.0f}s logged")

                if should_end:
                    break

            if config.show_timestep_updates:
                print()

            traci.close()
            time.sleep(0.5)

            if route_file.exists():
                for attempt in range(3):
                    try:
                        route_file.unlink()
                        break
                    except PermissionError:
                        if attempt < 2:
                            time.sleep(0.5)

            if len(self.log_data) == 0:
                print(f"  Warning: No data logged for scenario {scenario_id}")
                return None

            df = pd.DataFrame(self.log_data)
            self.log_data = []
            return df

        except Exception as e:
            print(f"\n  Error in scenario {scenario_id}: {e}")
            import traceback
            traceback.print_exc()
            try:
                if traci.isLoaded():
                    traci.close()
                time.sleep(0.5)
            except Exception:
                pass
            try:
                rf = config.base_dir / f"routes_temp_{scenario_id-1}.rou.xml"
                if rf.exists():
                    rf.unlink()
            except Exception:
                pass
            return None


def _run_single_scenario_wrapper(scenario: Dict) -> Optional[pd.DataFrame]:
    simulator = SUMOSimulator(gui_mode=False)
    try:
        return simulator.run_scenario(**scenario)
    except Exception as e:
        print(f"  Error in scenario {scenario['scenario_id']}: {e}")
        return None


def run_batch_simulations(start_idx: int = 0,
                          end_idx: Optional[int] = None,
                          use_multiprocessing: bool = True):
    print("\n" + "="*60)
    print("STARTING BATCH SIMULATION MODE  (Map 2 — with on-ramp)")
    if use_multiprocessing:
        print(f"Using {config.num_workers} parallel workers")
    print("="*60 + "\n")

    scenarios  = []
    scenario_id = 0

    for has_incident in [False, True]:
        for flow in range(config.flow_min, config.flow_max + 1, config.flow_step):
            for onramp in range(config.onramp_flow_min,
                                config.onramp_flow_max + 1,
                                config.onramp_flow_step):
                for speed_factor in np.arange(config.speed_factor_min,
                                              config.speed_factor_max + 0.01,
                                              config.speed_factor_step):
                    current_positions = (config.incident_positions
                                         if has_incident else [None])
                    for incident_pos in current_positions:
                        scenarios.append({
                            'scenario_id':       scenario_id + 1,
                            'flow_total':        flow,
                            'onramp_flow':       onramp,
                            'speed_factor_mean': round(float(speed_factor), 1),
                            'has_incident':      has_incident,
                            'incident_position': incident_pos if has_incident else 0,
                            'total_scenarios':   config.total_scenarios,
                        })
                        scenario_id += 1

    if end_idx is None:
        end_idx = len(scenarios)
    scenarios = scenarios[start_idx:end_idx]
    for sc in scenarios:
        sc['total_scenarios'] = len(scenarios)
    print(f"Running scenarios {start_idx+1} to {end_idx} ({len(scenarios)} total)\n")

    start_time = time.time()

    if use_multiprocessing and config.num_workers > 1:
        print(f"Running in parallel with {config.num_workers} workers...\n")
        with Pool(processes=config.num_workers) as pool:
            all_data = list(pool.imap(_run_single_scenario_wrapper, scenarios))
    else:
        print("Running sequentially...\n")
        all_data = []
        for scenario in scenarios:
            df = _run_single_scenario_wrapper(scenario)
            all_data.append(df)

    all_data = [df for df in all_data if df is not None and len(df) > 0]
    print(f"\nSimulation Summary:  "
          f"{len(all_data)}/{len(scenarios)} successful")

    if not all_data:
        print("No data collected — all simulations failed.")
        return

    combined_df = pd.concat(all_data, ignore_index=True)
    combined_h5 = config.data_dir / "all_data.h5"
    combined_df.to_hdf(combined_h5, key='data', mode='w', format='table')
    print(f"Complete dataset saved to {combined_h5}.  "
          f"Total samples: {len(combined_df):,}")

    scenario_ids = combined_df['scenario_id'].unique()
    np.random.shuffle(scenario_ids)
    n_train   = int(len(scenario_ids) * config.train_ratio)
    n_val     = int(len(scenario_ids) * config.val_ratio)
    train_ids = scenario_ids[:n_train]
    val_ids   = scenario_ids[n_train:n_train+n_val]
    test_ids  = scenario_ids[n_train+n_val:]

    combined_df[combined_df['scenario_id'].isin(train_ids)].to_hdf(
        config.train_h5, key='data', mode='w', format='table')
    combined_df[combined_df['scenario_id'].isin(val_ids)].to_hdf(
        config.val_h5,   key='data', mode='w', format='table')
    combined_df[combined_df['scenario_id'].isin(test_ids)].to_hdf(
        config.test_h5,  key='data', mode='w', format='table')

    elapsed = time.time() - start_time
    print(f"\nBatch complete in {elapsed/60:.1f} min.  "
          f"Train={len(train_ids)}  Val={len(val_ids)}  Test={len(test_ids)} scenarios.")


def run_single_simulation(flow_total: int = 1200,
                           onramp_flow: int = 200,
                           speed_factor_mean: float = 1.0,
                           has_incident: bool = False,
                           incident_position: float = 2460):
    """GUI mode single-scenario debug run."""
    print("\n" + "="*60)
    print("SINGLE SIMULATION MODE (GUI)  — Map 2")
    print("="*60)
    simulator = SUMOSimulator(gui_mode=True)
    df = simulator.run_scenario(
        flow_total        = flow_total,
        onramp_flow       = onramp_flow,
        speed_factor_mean = speed_factor_mean,
        has_incident      = has_incident,
        incident_position = incident_position,
        scenario_id       = 1,
        total_scenarios   = 1,
    )
    if df is not None:
        print(f"\nDone. {len(df)} data points collected.")
        print(df.head())
    else:
        print("\nSimulation failed.")
    return df


